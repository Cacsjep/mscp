<external:ViewItemWpfUserControl
    xmlns:external="clr-namespace:VideoOS.Platform.Client;assembly=VideoOS.Platform"
    x:Class="CertWatchdog.Client.CertWatchdogViewItemWpfUserControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    mc:Ignorable="d"
    d:DesignHeight="600"
    d:DesignWidth="900">
    <Grid Background="#FF1C2326">
        <Grid.Resources>
            <!-- Shared DataGrid column header style -->
            <Style x:Key="GridColumnHeaderStyle" TargetType="DataGridColumnHeader">
                <Setter Property="Background" Value="#FF252A2E"/>
                <Setter Property="Foreground" Value="#FF8B949E"/>
                <Setter Property="FontWeight" Value="SemiBold"/>
                <Setter Property="FontSize" Value="12"/>
                <Setter Property="Padding" Value="10,8"/>
                <Setter Property="BorderBrush" Value="#FF30363D"/>
                <Setter Property="BorderThickness" Value="0,0,1,1"/>
            </Style>
            <!-- Shared DataGrid cell style -->
            <Style x:Key="GridCellStyle" TargetType="DataGridCell">
                <Setter Property="Padding" Value="10,6"/>
                <Setter Property="BorderBrush" Value="Transparent"/>
                <Setter Property="BorderThickness" Value="0"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="DataGridCell">
                            <Border Background="{TemplateBinding Background}"
                                    Padding="{TemplateBinding Padding}">
                                <ContentPresenter VerticalAlignment="Center"/>
                            </Border>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
                <Style.Triggers>
                    <Trigger Property="IsSelected" Value="True">
                        <Setter Property="Background" Value="#FF2A3A4A"/>
                        <Setter Property="Foreground" Value="White"/>
                    </Trigger>
                </Style.Triggers>
            </Style>
            <!-- Shared DataGrid row style -->
            <Style x:Key="GridRowStyle" TargetType="DataGridRow">
                <Style.Triggers>
                    <Trigger Property="IsMouseOver" Value="True">
                        <Setter Property="Background" Value="#FF2A2F35"/>
                    </Trigger>
                </Style.Triggers>
            </Style>
            <!-- Days Left column style (color-coded) -->
            <Style x:Key="DaysLeftStyle" TargetType="TextBlock">
                <Setter Property="FontWeight" Value="Bold"/>
                <Style.Triggers>
                    <DataTrigger Binding="{Binding Status}" Value="OK">
                        <Setter Property="Foreground" Value="#FF3FB950"/>
                    </DataTrigger>
                    <DataTrigger Binding="{Binding Status}" Value="Expiring">
                        <Setter Property="Foreground" Value="#FFD29922"/>
                    </DataTrigger>
                    <DataTrigger Binding="{Binding Status}" Value="Critical">
                        <Setter Property="Foreground" Value="#FFF85149"/>
                    </DataTrigger>
                    <DataTrigger Binding="{Binding Status}" Value="Expired">
                        <Setter Property="Foreground" Value="#FFF85149"/>
                    </DataTrigger>
                    <DataTrigger Binding="{Binding Status}" Value="Error">
                        <Setter Property="Foreground" Value="#FF8B949E"/>
                    </DataTrigger>
                </Style.Triggers>
            </Style>
            <!-- Status column style (color-coded) -->
            <Style x:Key="StatusStyle" TargetType="TextBlock">
                <Setter Property="FontWeight" Value="SemiBold"/>
                <Style.Triggers>
                    <DataTrigger Binding="{Binding Status}" Value="OK">
                        <Setter Property="Foreground" Value="#FF3FB950"/>
                    </DataTrigger>
                    <DataTrigger Binding="{Binding Status}" Value="Expiring">
                        <Setter Property="Foreground" Value="#FFD29922"/>
                    </DataTrigger>
                    <DataTrigger Binding="{Binding Status}" Value="Critical">
                        <Setter Property="Foreground" Value="#FFF85149"/>
                    </DataTrigger>
                    <DataTrigger Binding="{Binding Status}" Value="Expired">
                        <Setter Property="Foreground" Value="#FFF85149"/>
                    </DataTrigger>
                    <DataTrigger Binding="{Binding Status}" Value="Error">
                        <Setter Property="Foreground" Value="#FF8B949E"/>
                    </DataTrigger>
                </Style.Triggers>
            </Style>
        </Grid.Resources>

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="#FF252A2E" Padding="16,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Orientation="Horizontal">
                    <TextBlock Text="&#128274;" FontSize="18" VerticalAlignment="Center" Margin="0,0,10,0"/>
                    <TextBlock Text="Certificate Watchdog" Foreground="White" FontSize="16" FontWeight="Bold"
                               VerticalAlignment="Center"/>
                </StackPanel>
                <Button x:Name="refreshButton" Grid.Column="1" Content="&#8635; Refresh"
                        Background="#FF3A3F44" Foreground="White" BorderBrush="#FF555555"
                        Padding="12,6" MinHeight="28" Cursor="Hand" Click="OnRefreshClick"
                        VerticalAlignment="Center" FontSize="12"/>
            </Grid>
        </Border>

        <!-- Tables area -->
        <Grid Grid.Row="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="*" MinHeight="60"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*" MinHeight="60"/>
            </Grid.RowDefinitions>

            <!-- Server Certificates -->
            <DockPanel Grid.Row="0">
                <Border DockPanel.Dock="Top" Background="#FF252A2E" Padding="12,6" BorderBrush="#FF30363D" BorderThickness="0,0,0,1">
                    <TextBlock Text="Server Certificates" Foreground="#FF8B949E" FontSize="12" FontWeight="SemiBold"/>
                </Border>
                <DataGrid x:Name="serverDataGrid"
                      AutoGenerateColumns="False" IsReadOnly="True" SelectionMode="Single"
                      Background="#FF1C2326" Foreground="#FFE6EDF3"
                      RowBackground="#FF1C2326" AlternatingRowBackground="#FF222830"
                      BorderBrush="#FF30363D" BorderThickness="0"
                      GridLinesVisibility="Horizontal" HorizontalGridLinesBrush="#FF30363D"
                      HeadersVisibility="Column"
                      CanUserSortColumns="True" CanUserResizeColumns="True" CanUserReorderColumns="False"
                      RowHeaderWidth="0" FontSize="13"
                      ColumnHeaderStyle="{StaticResource GridColumnHeaderStyle}"
                      CellStyle="{StaticResource GridCellStyle}"
                      RowStyle="{StaticResource GridRowStyle}"
                      VirtualizingStackPanel.IsVirtualizing="True">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Service" Binding="{Binding ServiceType}" Width="2*"/>
                    <DataGridTextColumn Header="Endpoint" Binding="{Binding Endpoint}" Width="2*"/>
                    <DataGridTextColumn Header="URL" Binding="{Binding Url}" Width="3*"/>
                    <DataGridTextColumn Header="Issuer" Binding="{Binding Issuer}" Width="2*"/>
                    <DataGridTextColumn Header="Expires" Binding="{Binding NotAfter, StringFormat='{}{0:yyyy-MM-dd}'}" Width="1.2*"/>
                    <DataGridTextColumn Header="Days Left" Binding="{Binding DaysLeft}" Width="1*"
                                        ElementStyle="{StaticResource DaysLeftStyle}"/>
                    <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="1*"
                                        ElementStyle="{StaticResource StatusStyle}"/>
                </DataGrid.Columns>
                </DataGrid>
            </DockPanel>

            <!-- Splitter -->
            <GridSplitter Grid.Row="1" Height="4" HorizontalAlignment="Stretch"
                          Background="#FF30363D" ResizeDirection="Rows"/>

            <!-- Hardware Certificates -->
            <DockPanel Grid.Row="2">
                <Border DockPanel.Dock="Top" Background="#FF252A2E" Padding="12,6" BorderBrush="#FF30363D" BorderThickness="0,0,0,1">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="Hardware Certificates" Foreground="#FF8B949E" FontSize="12" FontWeight="SemiBold"/>
                        <TextBlock x:Name="hwCountText" Foreground="#FF666666" FontSize="12" Margin="8,0,0,0" VerticalAlignment="Center"/>
                    </StackPanel>
                </Border>
                <DataGrid x:Name="hwDataGrid"
                      AutoGenerateColumns="False" IsReadOnly="True" SelectionMode="Single"
                      Background="#FF1C2326" Foreground="#FFE6EDF3"
                      RowBackground="#FF1C2326" AlternatingRowBackground="#FF222830"
                      BorderBrush="#FF30363D" BorderThickness="0"
                      GridLinesVisibility="Horizontal" HorizontalGridLinesBrush="#FF30363D"
                      HeadersVisibility="Column"
                      CanUserSortColumns="True" CanUserResizeColumns="True" CanUserReorderColumns="False"
                      RowHeaderWidth="0" FontSize="13"
                      ColumnHeaderStyle="{StaticResource GridColumnHeaderStyle}"
                      CellStyle="{StaticResource GridCellStyle}"
                      RowStyle="{StaticResource GridRowStyle}"
                      VirtualizingStackPanel.IsVirtualizing="True"
                      EnableRowVirtualization="True">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Name" Binding="{Binding ServiceType}" Width="3*"/>
                    <DataGridTextColumn Header="URL" Binding="{Binding Url}" Width="2*"/>
                    <DataGridTextColumn Header="Issuer" Binding="{Binding Issuer}" Width="2*"/>
                    <DataGridTextColumn Header="Expires" Binding="{Binding NotAfter, StringFormat='{}{0:yyyy-MM-dd}'}" Width="1.2*"/>
                    <DataGridTextColumn Header="Days Left" Binding="{Binding DaysLeft}" Width="1*"
                                        ElementStyle="{StaticResource DaysLeftStyle}"/>
                    <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="1*"
                                        ElementStyle="{StaticResource StatusStyle}"/>
                </DataGrid.Columns>
                </DataGrid>
            </DockPanel>
        </Grid>

        <!-- Loading overlay -->
        <Grid x:Name="loadingOverlay" Grid.Row="1" Background="#FF1C2326" Visibility="Visible">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <TextBlock Text="&#128274;" FontSize="48" HorizontalAlignment="Center" Margin="0,0,0,16"
                           Foreground="#FF58A6FF"/>
                <TextBlock x:Name="loadingText" Text="Loading certificate data..."
                           Foreground="#FF88BBFF" FontSize="14" HorizontalAlignment="Center"/>
            </StackPanel>
        </Grid>

        <!-- Status bar -->
        <Border Grid.Row="2" Background="#FF252A2E" Padding="12,6" BorderBrush="#FF30363D" BorderThickness="0,1,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock x:Name="statusText" Grid.Column="0" Foreground="#FF8B949E" FontSize="11"
                           VerticalAlignment="Center"/>
                <TextBlock x:Name="lastUpdatedText" Grid.Column="1" Foreground="#FF666666" FontSize="11"
                           VerticalAlignment="Center"/>
            </Grid>
        </Border>
    </Grid>
</external:ViewItemWpfUserControl>
