<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net48</TargetFramework>
    <OutputType>Exe</OutputType>
    <RootNamespace>RTMPStreamerHelper</RootNamespace>
    <AssemblyName>RTMPStreamerHelper</AssemblyName>
    <LangVersion>latest</LangVersion>
    <RuntimeIdentifier>win-x64</RuntimeIdentifier>
    <EnableDefaultCompileItems>false</EnableDefaultCompileItems>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="MilestoneSystems.VideoOS.Platform" Version="*-*" />
    <PackageReference Include="MilestoneSystems.VideoOS.Platform.SDK" Version="*-*" />
  </ItemGroup>

  <ItemGroup>
    <Reference Include="System" />
    <Reference Include="System.Core" />
    <Reference Include="System.Xml" />
    <Reference Include="System.Xml.Linq" />
  </ItemGroup>

  <ItemGroup>
    <Compile Include="Program.cs" />
    <Compile Include="PluginLog.cs" />
    <Compile Include="..\Rtmp\Amf0.cs" Link="Rtmp\Amf0.cs" />
    <Compile Include="..\Rtmp\RtmpPublisher.cs" Link="Rtmp\RtmpPublisher.cs" />
    <Compile Include="..\Rtmp\FlvMuxer.cs" Link="Rtmp\FlvMuxer.cs" />
    <Compile Include="..\Rtmp\SilentAacGenerator.cs" Link="Rtmp\SilentAacGenerator.cs" />
    <Compile Include="..\Rtmp\RtmpChunkWriter.cs" Link="Rtmp\RtmpChunkWriter.cs" />
    <Compile Include="..\Streaming\CameraFrameSource.cs" Link="Streaming\CameraFrameSource.cs" />
    <Compile Include="..\Streaming\GenericByteDataParser.cs" Link="Streaming\GenericByteDataParser.cs" />
    <Compile Include="..\Streaming\StreamSession.cs" Link="Streaming\StreamSession.cs" />
  </ItemGroup>

</Project>
