<?xml version="1.0" encoding="UTF-8"?>
<configuration>
  <system.webServer>
    <!-- Tell IIS to serve index.html when the URL points at the directory -->
    <defaultDocument enabled="true">
      <files>
        <clear />
        <add value="index.html" />
      </files>
    </defaultDocument>

    <!-- Hand the .msi off to the static file handler with the right MIME type
         so it streams as a download instead of being rejected by an unrelated
         handler. application/octet-stream is the conventional MSI MIME type. -->
    <staticContent>
      <remove fileExtension=".msi" />
      <mimeMap fileExtension=".msi" mimeType="application/octet-stream" />
    </staticContent>
    <!-- Note: do NOT add <handlers accessPolicy="..."/> here. Doing so removes
         Script from the inherited access policy and breaks the DefaultDocument
         module's URL rewrite, which causes /mscp/ directory requests to fall
         through to the ASP.NET extensionless URL handler and return 403.1. -->
  </system.webServer>

  <!-- Extras subfolder: drop point for arbitrary admin-supplied files (EXEs,
       ZIPs, certs, helper scripts) that should appear on the download page.
       Directory browsing is enabled so /mscp/extras/ returns a parseable
       HTML listing; the index page fetches that listing, scrapes the <a>
       entries, and renders them as an Additional downloads card. The default
       document is disabled here so IIS doesn't fall through to an inherited
       index.html (we want the listing). Requires the "Directory Browsing"
       IIS role feature; if it's absent the index page silently hides the
       card on fetch failure. -->
  <location path="extras">
    <system.webServer>
      <directoryBrowse enabled="true" />
      <defaultDocument enabled="false" />
    </system.webServer>
  </location>
</configuration>
