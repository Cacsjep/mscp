<?xml version="1.0" encoding="UTF-8"?>
<!--
  MSCPlugins WiX v5 Installer
  Produces an MSI with feature-based component selection.
  Component fragments are auto-generated by: pwsh installer/generate-wix.ps1
-->
<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs"
     xmlns:ui="http://wixtoolset.org/schemas/v4/wxs/ui"
     xmlns:util="http://wixtoolset.org/schemas/v4/wxs/util">

  <Package Name="MSC Community Plugins"
           Manufacturer="MSC Community Plugins"
           Version="$(var.Version)"
           UpgradeCode="A1B2C3D4-E5F6-7890-ABCD-EF1234567890"
           Scope="perMachine"
           InstallerVersion="500">

    <!-- Major upgrade: remove previous versions before install -->
    <MajorUpgrade DowngradeErrorMessage="A newer version of MSC Community Plugins is already installed."
                  Schedule="afterInstallInitialize" />

    <!-- Enable verbose MSI logging to %TEMP%\MSCPlugins-install.log -->
    <Property Id="MsiLogging" Value="voicewarmupx!" />
    <Property Id="MsiLogFileLocation" Value="[%TEMP]\MSCPlugins-install.log" />

    <!-- Embed the cab into the MSI with max compression -->
    <MediaTemplate EmbedCab="yes" CompressionLevel="high" />

    <!-- License -->
    <WixVariable Id="WixUILicenseRtf" Value="License.rtf" />

    <!-- Custom UI sequence: Welcome → License → InstallDir → FeatureTree → Install -->
    <ui:WixUI Id="WixUI_FeatureTree" />

    <!-- Progress text shown in the installer UI during custom actions -->
    <UI>
      <ProgressText Action="CA_StopSmartClient" Message="Closing XProtect Smart Client..." />
      <ProgressText Action="CA_StopManagementClient" Message="Closing XProtect Management Client..." />
      <ProgressText Action="CA_StopDriverFramework" Message="Closing Driver Framework Process..." />
      <ProgressText Action="CA_StopRecordingServer" Message="Stopping Milestone XProtect Recording Server..." />
      <ProgressText Action="CA_StopEventServer" Message="Stopping Milestone Event Server..." />
      <ProgressText Action="CA_StartRecordingServer" Message="Starting Milestone XProtect Recording Server..." />
      <ProgressText Action="CA_StartEventServer" Message="Starting Milestone Event Server..." />
    </UI>

    <!-- ══════════════════════════════════════════════════════════ -->
    <!-- Install directories                                       -->
    <!-- ══════════════════════════════════════════════════════════ -->
    <StandardDirectory Id="ProgramFiles64Folder">
      <Directory Id="MILESTONEDIR" Name="Milestone">
        <Directory Id="MIPPLUGINS" Name="MIPPlugins" />
        <Directory Id="MIPDRIVERS" Name="MIPDrivers" />
      </Directory>
    </StandardDirectory>

    <!-- ══════════════════════════════════════════════════════════ -->
    <!-- Custom Actions: Kill processes and Stop/Start services    -->
    <!-- Uses WixQuietExec64 — runs silently, no cmd window        -->
    <!-- ══════════════════════════════════════════════════════════ -->

    <!-- ── Kill Smart Client ── -->
    <SetProperty Id="CA_StopSmartClient"
                 Before="CA_StopSmartClient"
                 Sequence="execute"
                 Value="&quot;[SystemFolder]cmd.exe&quot; /c taskkill /F /IM &quot;Client.exe&quot; 2&gt;nul &amp; exit /b 0" />
    <CustomAction Id="CA_StopSmartClient"
                  DllEntry="WixQuietExec64"
                  BinaryRef="Wix4UtilCA_X86"
                  Execute="deferred"
                  Impersonate="no"
                  Return="ignore" />

    <!-- ── Kill Management Client ── -->
    <SetProperty Id="CA_StopManagementClient"
                 Before="CA_StopManagementClient"
                 Sequence="execute"
                 Value="&quot;[SystemFolder]cmd.exe&quot; /c taskkill /F /IM &quot;VideoOS.Platform.Administration.exe&quot; 2&gt;nul &amp; exit /b 0" />
    <CustomAction Id="CA_StopManagementClient"
                  DllEntry="WixQuietExec64"
                  BinaryRef="Wix4UtilCA_X86"
                  Execute="deferred"
                  Impersonate="no"
                  Return="ignore" />

    <!-- ── Kill Driver Framework Process ── -->
    <SetProperty Id="CA_StopDriverFramework"
                 Before="CA_StopDriverFramework"
                 Sequence="execute"
                 Value="&quot;[SystemFolder]cmd.exe&quot; /c taskkill /F /IM &quot;VideoOS.IO.Drivers.DriverFrameworkProcess.exe&quot; 2&gt;nul &amp; exit /b 0" />
    <CustomAction Id="CA_StopDriverFramework"
                  DllEntry="WixQuietExec64"
                  BinaryRef="Wix4UtilCA_X86"
                  Execute="deferred"
                  Impersonate="no"
                  Return="ignore" />

    <!-- ── Stop Recording Server service ── -->
    <SetProperty Id="CA_StopRecordingServer"
                 Before="CA_StopRecordingServer"
                 Sequence="execute"
                 Value="&quot;[SystemFolder]cmd.exe&quot; /c net stop &quot;Milestone XProtect Recording Server&quot; /y 2&gt;nul &amp; exit /b 0" />
    <CustomAction Id="CA_StopRecordingServer"
                  DllEntry="WixQuietExec64"
                  BinaryRef="Wix4UtilCA_X86"
                  Execute="deferred"
                  Impersonate="no"
                  Return="ignore" />

    <!-- ── Stop Event Server service ── -->
    <SetProperty Id="CA_StopEventServer"
                 Before="CA_StopEventServer"
                 Sequence="execute"
                 Value="&quot;[SystemFolder]cmd.exe&quot; /c net stop &quot;MilestoneEventServerService&quot; /y 2&gt;nul &amp; exit /b 0" />
    <CustomAction Id="CA_StopEventServer"
                  DllEntry="WixQuietExec64"
                  BinaryRef="Wix4UtilCA_X86"
                  Execute="deferred"
                  Impersonate="no"
                  Return="ignore" />

    <!-- ── Start Recording Server service ── -->
    <SetProperty Id="CA_StartRecordingServer"
                 Before="CA_StartRecordingServer"
                 Sequence="execute"
                 Value="&quot;[SystemFolder]cmd.exe&quot; /c net start &quot;Milestone XProtect Recording Server&quot; 2&gt;nul &amp; exit /b 0" />
    <CustomAction Id="CA_StartRecordingServer"
                  DllEntry="WixQuietExec64"
                  BinaryRef="Wix4UtilCA_X86"
                  Execute="deferred"
                  Impersonate="no"
                  Return="ignore" />

    <!-- ── Start Event Server service ── -->
    <SetProperty Id="CA_StartEventServer"
                 Before="CA_StartEventServer"
                 Sequence="execute"
                 Value="&quot;[SystemFolder]cmd.exe&quot; /c net start &quot;MilestoneEventServerService&quot; 2&gt;nul &amp; exit /b 0" />
    <CustomAction Id="CA_StartEventServer"
                  DllEntry="WixQuietExec64"
                  BinaryRef="Wix4UtilCA_X86"
                  Execute="deferred"
                  Impersonate="no"
                  Return="ignore" />

    <!-- ══════════════════════════════════════════════════════════ -->
    <!-- Features (generated from plugins.json)                    -->
    <!-- ══════════════════════════════════════════════════════════ -->
    <FeatureRef Id="SmartClientPlugins" />
    <FeatureRef Id="DeviceDrivers" />
    <FeatureRef Id="AdminPlugins" />

    <!-- ══════════════════════════════════════════════════════════ -->
    <!-- Install sequence                                          -->
    <!--   1. Kill processes (SC, MC, DFP)                         -->
    <!--   2. Stop services (RS, ES)                               -->
    <!--   3. Install files                                        -->
    <!--   4. Start services (RS, ES)                              -->
    <!-- ══════════════════════════════════════════════════════════ -->
    <InstallExecuteSequence>
      <!-- Pre-install: kill processes, then stop services -->
      <Custom Action="CA_StopSmartClient"       Before="CA_StopManagementClient" Condition="NOT REMOVE=&quot;ALL&quot;" />
      <Custom Action="CA_StopManagementClient"  Before="CA_StopDriverFramework"  Condition="NOT REMOVE=&quot;ALL&quot;" />
      <Custom Action="CA_StopDriverFramework"   Before="CA_StopRecordingServer"  Condition="NOT REMOVE=&quot;ALL&quot;" />
      <Custom Action="CA_StopRecordingServer"   Before="CA_StopEventServer"      Condition="NOT REMOVE=&quot;ALL&quot;" />
      <Custom Action="CA_StopEventServer"       Before="InstallFiles"            Condition="NOT REMOVE=&quot;ALL&quot;" />

      <!-- Post-install: restart services -->
      <Custom Action="CA_StartRecordingServer"  After="InstallFiles"             Condition="NOT REMOVE=&quot;ALL&quot;" />
      <Custom Action="CA_StartEventServer"      After="CA_StartRecordingServer"  Condition="NOT REMOVE=&quot;ALL&quot;" />
    </InstallExecuteSequence>

  </Package>
</Wix>
