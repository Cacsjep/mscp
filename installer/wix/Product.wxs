<?xml version="1.0" encoding="UTF-8"?>
<!--
  MSCPlugins WiX v5 Installer
  Produces an MSI with feature-based component selection.
  Component fragments are auto-generated by: pwsh installer/generate-wix.ps1
-->
<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs"
     xmlns:ui="http://wixtoolset.org/schemas/v4/wxs/ui"
     xmlns:util="http://wixtoolset.org/schemas/v4/wxs/util"
     xmlns:iis="http://wixtoolset.org/schemas/v4/wxs/iis">

  <Package Name="MSC Community Plugins"
           Manufacturer="MSC Community Plugins"
           Version="$(var.Version)"
           UpgradeCode="A1B2C3D4-E5F6-7890-ABCD-EF1234567890"
           Scope="perMachine"
           InstallerVersion="500">

    <!-- Major upgrade: remove previous versions before install -->
    <MajorUpgrade DowngradeErrorMessage="A newer version of MSC Community Plugins is already installed."
                  Schedule="afterInstallInitialize" />

    <!-- Enable verbose MSI logging to %TEMP%\MSCPlugins-install.log -->
    <Property Id="MsiLogging" Value="voicewarmupx!" />
    <Property Id="MsiLogFileLocation" Value="[%TEMP]\MSCPlugins-install.log" />

    <!-- Embed the cab into the MSI with max compression -->
    <MediaTemplate EmbedCab="yes" CompressionLevel="high" />

    <Binary Id="InstallerCustomActions"
            SourceFile="..\customactions\bin\Release\net48\InstallerCustomActions.CA.dll" />

    <!-- License -->
    <WixVariable Id="WixUILicenseRtf" Value="License.rtf" />

    <!-- Custom UI sequence: Welcome → License → OemModeDlg → FeatureTree → Install -->
    <ui:WixUI Id="WixUI_FeatureTree" />

    <!-- Suppress reboot prompts and FilesInUse dialogs — our custom actions already
         stop all locked processes/services before InstallFiles. -->
    <Property Id="MSIRESTARTMANAGERCONTROL" Value="Disable" />
    <Property Id="REBOOT" Value="ReallySuppress" />
    <Property Id="ARPNORESTARTMANAGER" Value="1" />
    <Property Id="MSIFASTINSTALL" Value="7" />

    <!-- ══════════════════════════════════════════════════════════ -->
    <!-- Custom install paths                                      -->
    <!--                                                           -->
    <!-- Properties named the SAME as Directory Ids function as   -->
    <!-- MSI directory overrides: the property value becomes the  -->
    <!-- physical path of that directory. The PathEdit controls    -->
    <!-- and the folder-picker (DirectoryCombo / DirectoryList in  -->
    <!-- MscpBrowseDlg) both require the bound name to be a real  -->
    <!-- Directory Id  using a separate *DIR property broke the   -->
    <!-- Browse dialog with MSI error 2727.                         -->
    <!-- Silent installs can still override with                    -->
    <!--   msiexec /i ... MIPPLUGINS="..." MIPDRIVERS="..."        -->
    <!-- Both are Secure so edits survive the UI-to-Execute hop.  -->
    <!-- ══════════════════════════════════════════════════════════ -->
    <Property Id="MIPPLUGINS" Secure="yes" />
    <Property Id="MIPDRIVERS" Secure="yes" />

    <!-- ══════════════════════════════════════════════════════════ -->
    <!-- IIS Hosting feature support                                -->
    <!--                                                            -->
    <!-- IIS_PRESENT is set if appcmd.exe exists on this machine.   -->
    <!-- The IISHosting feature components are conditioned on it,   -->
    <!-- so the install fails clean on management servers without   -->
    <!-- IIS. MSCP_PUBLIC is the physical folder served by the      -->
    <!-- /mscp virtual directory. MSCP_MSI_NAME is the versioned     -->
    <!-- file name we copy the running MSI to.                       -->
    <!-- ══════════════════════════════════════════════════════════ -->
    <Property Id="IIS_PRESENT" Secure="yes">
      <DirectorySearch Id="iisInetsrv" Path="[SystemFolder]inetsrv">
        <FileSearch Name="appcmd.exe" />
      </DirectorySearch>
    </Property>

    <Property Id="MSCP_PUBLIC" Secure="yes" />
    <SetProperty Id="MSCP_PUBLIC"
                 Value="[WindowsVolume]inetpub\wwwroot\mscp\"
                 Before="CostFinalize"
                 Sequence="both"
                 Condition="NOT MSCP_PUBLIC" />

    <Property Id="MSCP_MSI_NAME" Secure="yes" Value="MscpCommunityPlugins-$(var.Version).msi" />

    <!-- Fill the defaults from [ProgramFiles64Folder] only if the user or
         caller hasn't already set them. Before CostFinalize on both sequences
         so they resolve correctly in both UI and Execute phases. -->
    <SetProperty Id="MIPPLUGINS"
                 Value="[ProgramFiles64Folder]Milestone\MIPPlugins\"
                 Before="CostFinalize"
                 Sequence="both"
                 Condition="NOT MIPPLUGINS" />
    <SetProperty Id="MIPDRIVERS"
                 Value="[ProgramFiles64Folder]Milestone\MIPDrivers\"
                 Before="CostFinalize"
                 Sequence="both"
                 Condition="NOT MIPDRIVERS" />

    <!-- Progress text shown in the installer UI during custom actions, plus
         the install-paths dialog spliced between License and Customize. -->
    <UI>
      <ProgressText Action="CA_StopSmartClient" Message="Closing XProtect Smart Client..." />
      <ProgressText Action="CA_StopManagementClient" Message="Closing XProtect Management Client..." />
      <ProgressText Action="CA_StopDriverFramework" Message="Closing Driver Framework Process..." />
      <ProgressText Action="CA_StopRecordingServer" Message="Stopping Milestone XProtect Recording Server and waiting up to 3 minutes..." />
      <ProgressText Action="CA_StopEventServer" Message="Stopping Milestone Event Server and waiting up to 3 minutes..." />
      <ProgressText Action="CA_StartRecordingServer" Message="Starting Milestone XProtect Recording Server and waiting up to 3 minutes..." />
      <ProgressText Action="CA_StartEventServer" Message="Starting Milestone Event Server and waiting up to 3 minutes..." />

      <!--
        InstallPathsDlg - shown between LicenseAgreementDlg and CustomizeDlg.
        Two PathEdit fields pre-filled with the default Milestone paths; the
        bound MIPPLUGINSDIR / MIPDRIVERSDIR properties drive the SetDirectory
        redirects declared above.

        Navigation Publishes on the License Next button and the Customize Back
        button at Order=10 beat the stock Order=3 entries so our dialog lands
        in between.
      -->
      <!--
        OemInfoDlg - dedicated informational page shown between License and
        InstallPaths. Spells out the OEM-install caveats explicitly so they
        aren't missed: manual Smart Client close, manual service stop/start.
        Pure reference  Next always enabled. The subsequent InstallPathsDlg
        stays focused on the two path inputs with no OEM block.
      -->
      <Dialog Id="OemInfoDlg" Width="370" Height="270" Title="[ProductName] Setup">
        <Control Id="BannerBitmap" Type="Bitmap" X="0" Y="0" Width="370" Height="44"
                 TabSkip="no" Text="!(loc.InstallDirDlgBannerBitmap)" />
        <Control Id="BannerLine" Type="Line" X="0" Y="44" Width="370" Height="0" />
        <Control Id="BottomLine" Type="Line" X="0" Y="234" Width="370" Height="0" />

        <Control Id="Title" Type="Text" X="15" Y="6" Width="340" Height="15"
                 Transparent="yes" NoPrefix="yes"
                 Text="{\DlgTitleFont}OEM installations" />
        <Control Id="Description" Type="Text" X="25" Y="23" Width="340" Height="15"
                 Transparent="yes"
                 Text="Please read if your XProtect system is an OEM / rebranded edition." />

        <Control Id="Intro" Type="Text" X="25" Y="60" Width="320" Height="30"
                 Transparent="yes"
                 Text="On OEM rebrands the install root may differ from the Milestone defaults, and Event Server / Recording Server services may run under different names." />

        <Control Id="Step1" Type="Text" X="25" Y="100" Width="320" Height="26"
                 Transparent="yes"
                 Text="1. On the next page, set the MIP Plugins and MIP Drivers folders to match the OEM's MIP host scan location." />

        <Control Id="Step2" Type="Text" X="25" Y="132" Width="320" Height="26"
                 Transparent="yes"
                 Text="2. Close any OEM-branded Smart Client and Management Client before continuing  the installer's taskkill only matches Milestone's executable names." />

        <Control Id="Step3" Type="Text" X="25" Y="164" Width="320" Height="55"
                 Transparent="yes"
                 Text="3. Stop the OEM's Event Server and Recording Server services before clicking Install on the last page, and start them again after this installer finishes. The automatic service stop/start only targets Milestone's default service names." />

        <Control Id="Back" Type="PushButton" X="180" Y="243" Width="56" Height="17" Text="&amp;Back">
          <Publish Event="NewDialog" Value="LicenseAgreementDlg" Condition="1" />
        </Control>
        <Control Id="Next" Type="PushButton" X="236" Y="243" Width="56" Height="17" Default="yes" Text="&amp;Next">
          <Publish Event="NewDialog" Value="InstallPathsDlg" Condition="1" />
        </Control>
        <Control Id="Cancel" Type="PushButton" X="304" Y="243" Width="56" Height="17" Cancel="yes" Text="Cancel">
          <Publish Event="SpawnDialog" Value="CancelDlg" Condition="1" />
        </Control>
      </Dialog>

      <Dialog Id="InstallPathsDlg" Width="370" Height="270" Title="[ProductName] Setup">
        <Control Id="BannerBitmap" Type="Bitmap" X="0" Y="0" Width="370" Height="44"
                 TabSkip="no" Text="!(loc.InstallDirDlgBannerBitmap)" />
        <Control Id="BannerLine" Type="Line" X="0" Y="44" Width="370" Height="0" />
        <Control Id="BottomLine" Type="Line" X="0" Y="234" Width="370" Height="0" />

        <Control Id="Title" Type="Text" X="15" Y="6" Width="280" Height="15"
                 Transparent="yes" NoPrefix="yes"
                 Text="{\DlgTitleFont}Install locations" />
        <Control Id="Description" Type="Text" X="25" Y="23" Width="340" Height="15"
                 Transparent="yes"
                 Text="Defaults follow the Milestone convention. Adjust for OEM systems per the previous page." />

        <Control Id="PluginsLabel" Type="Text" X="25" Y="70" Width="320" Height="15"
                 Transparent="yes"
                 Text="MIP Plugins folder:" />
        <Control Id="PluginsEdit" Type="PathEdit" X="25" Y="88" Width="290" Height="18"
                 Property="MIPPLUGINS" />
        <Control Id="PluginsBrowse" Type="PushButton" X="320" Y="88" Width="25" Height="18" Text="...">
          <Publish Property="_BrowseProperty" Value="MIPPLUGINS" Order="1" Condition="1" />
          <Publish Event="SpawnDialog" Value="MscpBrowseDlg" Order="2" Condition="1" />
        </Control>

        <Control Id="DriversLabel" Type="Text" X="25" Y="120" Width="320" Height="15"
                 Transparent="yes"
                 Text="MIP Drivers folder:" />
        <Control Id="DriversEdit" Type="PathEdit" X="25" Y="138" Width="290" Height="18"
                 Property="MIPDRIVERS" />
        <Control Id="DriversBrowse" Type="PushButton" X="320" Y="138" Width="25" Height="18" Text="...">
          <Publish Property="_BrowseProperty" Value="MIPDRIVERS" Order="1" Condition="1" />
          <Publish Event="SpawnDialog" Value="MscpBrowseDlg" Order="2" Condition="1" />
        </Control>

        <Control Id="Hint" Type="Text" X="25" Y="175" Width="320" Height="40"
                 Transparent="yes"
                 Text="Paths must end with a backslash. Missing folders are created automatically. OEM systems: see the previous page for manual steps." />

        <Control Id="Back" Type="PushButton" X="180" Y="243" Width="56" Height="17" Text="&amp;Back">
          <Publish Event="NewDialog" Value="OemInfoDlg" Condition="1" />
        </Control>
        <Control Id="Next" Type="PushButton" X="236" Y="243" Width="56" Height="17" Default="yes" Text="&amp;Next">
          <Publish Event="NewDialog" Value="CustomizeDlg" Condition="1" />
        </Control>
        <Control Id="Cancel" Type="PushButton" X="304" Y="243" Width="56" Height="17" Cancel="yes" Text="Cancel">
          <Publish Event="SpawnDialog" Value="CancelDlg" Condition="1" />
        </Control>
      </Dialog>

      <Publish Dialog="LicenseAgreementDlg" Control="Next" Event="NewDialog"
               Value="OemInfoDlg" Order="10"
               Condition="LicenseAccepted = &quot;1&quot;" />
      <Publish Dialog="CustomizeDlg" Control="Back" Event="NewDialog"
               Value="InstallPathsDlg" Order="10"
               Condition="1" />

      <!--
        MscpBrowseDlg - generic folder picker modeled on the stock MSI BrowseDlg.
        WixUI_FeatureTree does not bundle a BrowseDlg (only WixUI_InstallDir does),
        so we author our own minimal one. The caller (each Browse button on
        InstallPathsDlg) stashes the target property name in _BrowseProperty,
        then spawns this dialog; the controls below bind to _BrowseProperty via
        Indirect="yes", and OK writes the picked path back via SetTargetPath.
      -->
      <Dialog Id="MscpBrowseDlg" Width="370" Height="270" Title="[ProductName] Setup">
        <Control Id="BannerBitmap" Type="Bitmap" X="0" Y="0" Width="370" Height="44"
                 TabSkip="no" Text="!(loc.InstallDirDlgBannerBitmap)" />
        <Control Id="BannerLine" Type="Line" X="0" Y="44" Width="370" Height="0" />
        <Control Id="BottomLine" Type="Line" X="0" Y="234" Width="370" Height="0" />

        <Control Id="Title" Type="Text" X="15" Y="6" Width="280" Height="15"
                 Transparent="yes" NoPrefix="yes"
                 Text="{\DlgTitleFont}Browse for folder" />
        <Control Id="Description" Type="Text" X="25" Y="23" Width="340" Height="15"
                 Transparent="yes"
                 Text="Choose a destination folder." />

        <Control Id="DirectoryCombo" Type="DirectoryCombo" X="25" Y="58" Width="220" Height="80"
                 Property="_BrowseProperty" Indirect="yes"
                 Fixed="yes" Remote="yes" />
        <Control Id="DirectoryList" Type="DirectoryList" X="25" Y="85" Width="320" Height="110"
                 Property="_BrowseProperty" Indirect="yes"
                 Sunken="yes" TabSkip="no" />
        <Control Id="PathEdit" Type="PathEdit" X="25" Y="202" Width="320" Height="18"
                 Property="_BrowseProperty" Indirect="yes" />

        <Control Id="OK" Type="PushButton" X="240" Y="243" Width="56" Height="17"
                 Default="yes" Text="OK">
          <Publish Event="SetTargetPath" Value="[_BrowseProperty]" Order="1" Condition="1" />
          <Publish Event="EndDialog" Value="Return" Order="2" Condition="1" />
        </Control>
        <Control Id="Cancel" Type="PushButton" X="304" Y="243" Width="56" Height="17"
                 Cancel="yes" Text="Cancel">
          <Publish Event="Reset" Value="0" Order="1" Condition="1" />
          <Publish Event="EndDialog" Value="Return" Order="2" Condition="1" />
        </Control>
      </Dialog>
    </UI>

    <!-- ══════════════════════════════════════════════════════════ -->
    <!-- Install directories                                       -->
    <!-- ══════════════════════════════════════════════════════════ -->
    <StandardDirectory Id="ProgramFiles64Folder">
      <Directory Id="MILESTONEDIR" Name="Milestone">
        <Directory Id="MIPPLUGINS" Name="MIPPlugins" />
        <Directory Id="MIPDRIVERS" Name="MIPDrivers" />
      </Directory>
    </StandardDirectory>

    <!-- ══════════════════════════════════════════════════════════ -->
    <!-- Custom Actions: Kill processes and Stop/Start services    -->
    <!-- Uses WixQuietExec64 — runs silently, no cmd window        -->
    <!-- ══════════════════════════════════════════════════════════ -->

    <!-- ── Kill Smart Client ── -->
    <SetProperty Id="CA_StopSmartClient"
                 Before="CA_StopSmartClient"
                 Sequence="execute"
                 Value="&quot;[SystemFolder]cmd.exe&quot; /c taskkill /F /IM &quot;Client.exe&quot; 2&gt;nul &amp; exit /b 0" />
    <CustomAction Id="CA_StopSmartClient"
                  DllEntry="WixQuietExec64"
                  BinaryRef="Wix4UtilCA_X86"
                  Execute="deferred"
                  Impersonate="no"
                  Return="ignore" />

    <!-- ── Kill Management Client ── -->
    <SetProperty Id="CA_StopManagementClient"
                 Before="CA_StopManagementClient"
                 Sequence="execute"
                 Value="&quot;[SystemFolder]cmd.exe&quot; /c taskkill /F /IM &quot;VideoOS.Platform.Administration.exe&quot; 2&gt;nul &amp; exit /b 0" />
    <CustomAction Id="CA_StopManagementClient"
                  DllEntry="WixQuietExec64"
                  BinaryRef="Wix4UtilCA_X86"
                  Execute="deferred"
                  Impersonate="no"
                  Return="ignore" />

    <!-- ── Kill Driver Framework Process ── -->
    <SetProperty Id="CA_StopDriverFramework"
                 Before="CA_StopDriverFramework"
                 Sequence="execute"
                 Value="&quot;[SystemFolder]cmd.exe&quot; /c taskkill /F /IM &quot;VideoOS.IO.Drivers.DriverFrameworkProcess.exe&quot; 2&gt;nul &amp; exit /b 0" />
    <CustomAction Id="CA_StopDriverFramework"
                  DllEntry="WixQuietExec64"
                  BinaryRef="Wix4UtilCA_X86"
                  Execute="deferred"
                  Impersonate="no"
                  Return="ignore" />

    <!-- ── Stop Recording Server service ── -->
    <SetProperty Id="CA_StopRecordingServer"
                 Before="CA_StopRecordingServer"
                 Sequence="execute"
                 Value="ServiceName=RecordingServerService;DisplayName=Milestone XProtect Recording Server;Operation=Stop;TimeoutSeconds=180" />
    <CustomAction Id="CA_StopRecordingServer"
                  BinaryRef="InstallerCustomActions"
                  DllEntry="EnsureServiceState"
                  Execute="deferred"
                  Impersonate="no"
                  Return="check" />

    <!-- ── Stop Event Server service ── -->
    <SetProperty Id="CA_StopEventServer"
                 Before="CA_StopEventServer"
                 Sequence="execute"
                 Value="ServiceName=MilestoneEventServerService;DisplayName=Milestone Event Server;Operation=Stop;TimeoutSeconds=180" />
    <CustomAction Id="CA_StopEventServer"
                  BinaryRef="InstallerCustomActions"
                  DllEntry="EnsureServiceState"
                  Execute="deferred"
                  Impersonate="no"
                  Return="check" />

    <!-- ── Start Recording Server service ── -->
    <SetProperty Id="CA_StartRecordingServer"
                 Before="CA_StartRecordingServer"
                 Sequence="execute"
                 Value="ServiceName=RecordingServerService;DisplayName=Milestone XProtect Recording Server;Operation=Start;TimeoutSeconds=180" />
    <CustomAction Id="CA_StartRecordingServer"
                  BinaryRef="InstallerCustomActions"
                  DllEntry="EnsureServiceState"
                  Execute="deferred"
                  Impersonate="no"
                  Return="check" />

    <!-- ── Start Event Server service ── -->
    <SetProperty Id="CA_StartEventServer"
                 Before="CA_StartEventServer"
                 Sequence="execute"
                 Value="ServiceName=MilestoneEventServerService;DisplayName=Milestone Event Server;Operation=Start;TimeoutSeconds=180" />
    <CustomAction Id="CA_StartEventServer"
                  BinaryRef="InstallerCustomActions"
                  DllEntry="EnsureServiceState"
                  Execute="deferred"
                  Impersonate="no"
                  Return="check" />

    <!-- ══════════════════════════════════════════════════════════ -->
    <!-- Features (generated from plugins.json)                    -->
    <!-- ══════════════════════════════════════════════════════════ -->
    <FeatureRef Id="SmartClientPlugins" />
    <FeatureRef Id="DeviceDrivers" />
    <FeatureRef Id="AdminPlugins" />
    <FeatureRef Id="IISHosting" />

    <!-- ══════════════════════════════════════════════════════════ -->
    <!-- IIS Publishing custom actions                              -->
    <!--                                                            -->
    <!-- The MSI cannot embed itself as a <File>, so a deferred CA  -->
    <!-- copies the running MSI ([OriginalDatabase]) into MSCP_PUBLIC -->
    <!-- under MSCP_MSI_NAME. Mirror CA on uninstall removes it.   -->
    <!-- Both are non-fatal: a publish failure never aborts the   -->
    <!-- install/uninstall of the actual plugins.                 -->
    <!-- ══════════════════════════════════════════════════════════ -->
    <SetProperty Id="CA_PublishMsi"
                 Before="CA_PublishMsi"
                 Sequence="execute"
                 Value="SourceMsi=[OriginalDatabase];DestinationFolder=[MSCP_PUBLIC];FileName=[MSCP_MSI_NAME]" />
    <CustomAction Id="CA_PublishMsi"
                  BinaryRef="InstallerCustomActions"
                  DllEntry="CopyMsiToPublicFolder"
                  Execute="deferred"
                  Impersonate="no"
                  Return="ignore" />

    <SetProperty Id="CA_UnpublishMsi"
                 Before="CA_UnpublishMsi"
                 Sequence="execute"
                 Value="DestinationFolder=[MSCP_PUBLIC];FileName=[MSCP_MSI_NAME]" />
    <CustomAction Id="CA_UnpublishMsi"
                  BinaryRef="InstallerCustomActions"
                  DllEntry="RemoveMsiFromPublicFolder"
                  Execute="deferred"
                  Impersonate="no"
                  Return="ignore" />

    <!-- ══════════════════════════════════════════════════════════ -->
    <!-- Install sequence                                          -->
    <!--   1. Kill processes (SC, MC, DFP)                         -->
    <!--   2. Stop services (RS, ES)                               -->
    <!--   3. Install files                                        -->
    <!--   4. Start services (RS, ES)                              -->
    <!-- ══════════════════════════════════════════════════════════ -->
    <!-- Service stop/start is gated on the feature action state so a Smart
         Client-only install doesn't stop the Recording / Event Server.
           &Feature=3 = feature is being installed/upgraded (going to local)
           &Feature=2 = feature is being removed (going to absent)
         Recording Server only matters when DeviceDrivers changes; Event Server
         only when AdminPlugins changes. The process kills (Smart Client,
         Management Client, Driver Framework) are cheap and run unconditionally
         on any install. -->
    <InstallExecuteSequence>
      <!-- Pre-install: kill processes (cheap, always run on install) -->
      <Custom Action="CA_StopSmartClient"       Before="CA_StopManagementClient" Condition="NOT REMOVE=&quot;ALL&quot;" />
      <Custom Action="CA_StopManagementClient"  Before="CA_StopDriverFramework"  Condition="NOT REMOVE=&quot;ALL&quot;" />
      <Custom Action="CA_StopDriverFramework"   Before="CA_StopRecordingServer"  Condition="NOT REMOVE=&quot;ALL&quot;" />

      <!-- Stop services (only when their feature is changing) -->
      <Custom Action="CA_StopRecordingServer"   Before="CA_StopEventServer"
              Condition="(&amp;DeviceDrivers=3 OR &amp;DeviceDrivers=2) AND NOT REMOVE=&quot;ALL&quot;" />
      <Custom Action="CA_StopEventServer"       Before="InstallFiles"
              Condition="(&amp;AdminPlugins=3 OR &amp;AdminPlugins=2) AND NOT REMOVE=&quot;ALL&quot;" />

      <!-- Post-install: restart services (mirror of the stop conditions) -->
      <Custom Action="CA_StartRecordingServer"  After="InstallFiles"
              Condition="(&amp;DeviceDrivers=3 OR &amp;DeviceDrivers=2) AND NOT REMOVE=&quot;ALL&quot;" />
      <Custom Action="CA_StartEventServer"      After="CA_StartRecordingServer"
              Condition="(&amp;AdminPlugins=3 OR &amp;AdminPlugins=2) AND NOT REMOVE=&quot;ALL&quot;" />

      <!-- IIS publishing (only if user opted in to IISHosting AND IIS exists).
           &amp;IISHosting=3 means "feature is going to local install in this transaction".
           &amp;IISHosting=2 means "feature was installed and is now being removed". -->
      <Custom Action="CA_PublishMsi"
              After="InstallFiles"
              Condition="(&amp;IISHosting=3) AND IIS_PRESENT" />
      <Custom Action="CA_UnpublishMsi"
              Before="RemoveFiles"
              Condition="((&amp;IISHosting=2) OR REMOVE=&quot;ALL&quot;) AND IIS_PRESENT" />
    </InstallExecuteSequence>

  </Package>
</Wix>
