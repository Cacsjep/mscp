  <Fragment>
    <Feature Id="SmartClientPlugins" Description="Plugins for the XProtect Smart Client. Installs to C:\Program Files\Milestone\MIPPlugins\" AllowAdvertise="no" Display="expand" Level="1" Title="Smart Client Plugins" AllowAbsent="yes">
      <Feature Id="Feature_Weather" Description="Display live weather in Smart Client view items (Open-Meteo)" AllowAdvertise="no" Level="1" Title="Weather Plugin" AllowAbsent="yes">
        <ComponentRef Id="cmpZip_Weather" />
      </Feature>
      <Feature Id="Feature_Notepad" Description="Simple text editor for operator notes in Smart Client view items" AllowAdvertise="no" Level="1" Title="Notepad Plugin" AllowAbsent="yes">
        <ComponentRef Id="cmpZip_Notepad" />
      </Feature>
      <Feature Id="Feature_SnapReport" Description="Select cameras and generate PDF snapshot reports for site surveys and compliance" AllowAdvertise="no" Level="1" Title="Snapshot Report Plugin" AllowAbsent="yes">
        <ComponentRef Id="cmpZip_SnapReport" />
      </Feature>
      <Feature Id="Feature_MonitorRTMPStreamer" Description="Capture desktop monitors and stream via RTMP" AllowAdvertise="no" Level="1" Title="Monitor RTMP Streamer" AllowAbsent="yes">
        <ComponentRef Id="cmpZip_MonitorRTMPStreamer" />
      </Feature>
      <Feature Id="Feature_SmartBar" Description="Workspace toolbar button for Smart Client" AllowAdvertise="no" Level="1" Title="Smart Bar" AllowAbsent="yes">
        <ComponentRef Id="cmpZip_SmartBar" />
      </Feature>
      <Feature Id="Feature_FlexView" Description="Freeform grid-based view layout designer with drag-and-drop pane creation, resizing, and editing" AllowAdvertise="no" Level="1" Title="FlexView" AllowAbsent="yes">
        <ComponentRef Id="cmpZip_FlexView" />
      </Feature>
      <Feature Id="Feature_ViewCarousel" Description="Cycle through XProtect Smart Client views inside a single view item slot" AllowAdvertise="no" Level="1" Title="View Carousel" AllowAbsent="yes">
        <ComponentRef Id="cmpZip_ViewCarousel" />
      </Feature>
      <Feature Id="Feature_SCRemoteControl" Description="Control Smart Client remotely via REST API with Swagger UI (views, cameras, workspaces, modes)" AllowAdvertise="no" Level="1" Title="Remote Control" AllowAbsent="yes">
        <ComponentRef Id="cmpZip_SCRemoteControl" />
      </Feature>
      <Feature Id="Feature_Timelapse" Description="Generate timelapse videos from recorded cameras with multi-camera stitch support" AllowAdvertise="no" Level="1" Title="Timelapse" AllowAbsent="yes">
        <ComponentRef Id="cmpZip_Timelapse" />
      </Feature>
      <Feature Id="Feature_RemoteManager" Description="Unified workspace for hardware web interfaces, custom websites, and RDP connections with tag-based filtering" AllowAdvertise="no" Level="1" Title="Remote Manager" AllowAbsent="yes">
        <ComponentRef Id="cmpZip_RemoteManager" />
      </Feature>
      <Feature Id="Feature_TimelineJump" Description="Toolbar flyout to jump the playback timeline backward or forward by configurable increments (seconds, minutes, hours, days)" AllowAdvertise="no" Level="1" Title="Timeline Jump" AllowAbsent="yes">
        <ComponentRef Id="cmpZip_TimelineJump" />
      </Feature>
      <Feature Id="Feature_MetadataDisplay" Description="Display ONVIF metadata values as live and playback dashboard widgets (lamp, number with thresholds, gauge, text) in Smart Client view items" AllowAdvertise="no" Level="1" Title="Metadata Display" AllowAbsent="yes">
        <ComponentRef Id="cmpZip_MetadataDisplay" />
      </Feature>
      <Feature Id="Feature_WebViewer" Description="Embed a single web page in a Smart Client view item via Microsoft Edge WebView2 (per-item URL, optional title, HTTP Basic credentials)" AllowAdvertise="no" Level="1" Title="Web Viewer" AllowAbsent="yes">
        <ComponentRef Id="cmpZip_WebViewer" />
      </Feature>
    </Feature>
  </Fragment>
  <Fragment>
