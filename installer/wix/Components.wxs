      <Feature Id="Feature_RTMPStreamer" Description="Stream XProtect™ cameras to RTMP destinations (YouTube, Twitch, etc.)" AllowAdvertise="no" Level="1" Title="RTMP Streamer Plugin" AllowAbsent="yes">
