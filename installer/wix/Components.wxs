  <Fragment>
    <Feature Id="SmartClientPlugins" Title="Smart Client Plugins" Description="Plugins for the XProtectâ„¢ Smart Client" Level="1" Display="expand" AllowAbsent="yes" AllowAdvertise="no">
      <Feature Id="Feature_Weather" Title="Weather Plugin" Description="Display live weather in Smart Client view items (Open-Meteo)" Level="1" AllowAbsent="yes" AllowAdvertise="no">
        <ComponentGroupRef Id="CG_Weather" />
      </Feature>
      <Feature Id="Feature_RDP" Title="RDP Plugin" Description="Embed interactive RDP sessions in Smart Client view items" Level="1" AllowAbsent="yes" AllowAdvertise="no">
        <ComponentGroupRef Id="CG_RDP" />
      </Feature>
      <Feature Id="Feature_Notepad" Title="Notepad Plugin" Description="Simple text editor for operator notes in Smart Client view items" Level="1" AllowAbsent="yes" AllowAdvertise="no">
        <ComponentGroupRef Id="CG_Notepad" />
      </Feature>
      <Feature Id="Feature_SnapReport" Title="SnapReport Plugin" Description="Select cameras and generate PDF snapshot reports for site surveys and compliance" Level="1" AllowAbsent="yes" AllowAdvertise="no">
        <ComponentGroupRef Id="CG_SnapReport" />
      </Feature>
      <Feature Id="Feature_MonitorRTMPStreamer" Title="Monitor RTMP Streamer" Description="Capture desktop monitors and stream via RTMP" Level="1" AllowAbsent="yes" AllowAdvertise="no">
        <ComponentGroupRef Id="CG_MonitorRTMPStreamer" />
      </Feature>
      <Feature Id="Feature_SmartBar" Title="Smart Bar" Description="Workspace toolbar button for Smart Client" Level="1" AllowAbsent="yes" AllowAdvertise="no">
        <ComponentGroupRef Id="CG_SmartBar" />
      </Feature>
    </Feature>
  </Fragment>
  <Fragment>
    <Feature Id="DeviceDrivers" Title="Device Drivers" Description="Device drivers for the XProtectâ„¢ Recording Server" Level="1" Display="expand" AllowAbsent="yes" AllowAdvertise="no">
      <Feature Id="Feature_RTMPDriver" Title="RTMP Push Driver" Description="Receive RTMP push streams (H.264) directly into XProtect™" Level="1" AllowAbsent="yes" AllowAdvertise="no">
        <ComponentGroupRef Id="CG_RTMPDriver" />
      </Feature>
      <Feature Id="Feature_RTSPDriver" Title="RTSP Pull Driver" Description="4-channel RTSP pull driver with rich diagnostics (H.264/H.265)" Level="1" AllowAbsent="yes" AllowAdvertise="no">
        <ComponentGroupRef Id="CG_RTSPDriver" />
      </Feature>
    </Feature>
  </Fragment>
  <Fragment>
    <Feature Id="AdminPlugins" Title="Admin Plugins" Description="Plugins for the XProtectâ„¢ Management Client / Event Server" Level="1" Display="expand" AllowAbsent="yes" AllowAdvertise="no">
      <Feature Id="Feature_RTMPStreamer" Title="RTMP Streamer Plugin" Description="Stream XProtect™ cameras to RTMP destinations (YouTube, Twitch, etc.)" Level="1" AllowAbsent="yes" AllowAdvertise="no">
        <ComponentGroupRef Id="CG_RTMPStreamer" />
      </Feature>
      <Feature Id="Feature_CertWatchdog" Title="Certificate Watchdog Plugin" Description="Monitor SSL certificate expiry for all XProtect™ HTTPS endpoints and devices with dashboard and alerts" Level="1" AllowAbsent="yes" AllowAdvertise="no">
        <ComponentGroupRef Id="CG_CertWatchdog" />
      </Feature>
      <Feature Id="Feature_Auditor" Title="Auditor Plugin" Description="Audit user access to recorded video with per-user rules and reason prompts" Level="1" AllowAbsent="yes" AllowAdvertise="no">
        <ComponentGroupRef Id="CG_Auditor" />
      </Feature>
      <Feature Id="Feature_HttpRequests" Title="HTTP Requests Plugin" Description="Configure and execute HTTP requests as rule actions with custom payloads, authentication, and batch execution" Level="1" AllowAbsent="yes" AllowAdvertise="no">
