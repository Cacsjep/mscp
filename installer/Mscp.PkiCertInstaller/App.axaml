<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:fa="using:FluentAvalonia.UI.Controls"
             x:Class="Mscp.PkiCertInstaller.App"
             RequestedThemeVariant="Dark">
  <Application.Resources>
    <ResourceDictionary>
      <ResourceDictionary.ThemeDictionaries>
        <!-- Milestone-style brand blue. We override the Fluent system
             accent so every Classes="accent" button picks up the
             corporate palette automatically. -->
        <ResourceDictionary x:Key="Dark">
          <Color x:Key="SystemAccentColor">#FF0099DA</Color>
          <Color x:Key="SystemAccentColorDark1">#FF0085BE</Color>
          <Color x:Key="SystemAccentColorDark2">#FF0072A2</Color>
          <Color x:Key="SystemAccentColorDark3">#FF005E86</Color>
          <Color x:Key="SystemAccentColorLight1">#FF1FA9E2</Color>
          <Color x:Key="SystemAccentColorLight2">#FF40B7E8</Color>
          <Color x:Key="SystemAccentColorLight3">#FF66C7EE</Color>
        </ResourceDictionary>
      </ResourceDictionary.ThemeDictionaries>
    </ResourceDictionary>
  </Application.Resources>

  <Application.Styles>
    <FluentTheme />
    <StyleInclude Source="avares://FluentAvalonia/Styling/FluentAvaloniaTheme.axaml" />
    <StyleInclude Source="avares://Avalonia.Controls.DataGrid/Themes/Fluent.xaml" />

    <!-- Force white text on every Classes="accent" button. Without this
         FluentAvalonia auto-picks black for the WCAG contrast on a
         medium-bright accent like Milestone blue, which the brand
         guidelines (and the user) specifically reject. -->
    <Style Selector="Button.accent">
      <Setter Property="Foreground" Value="White" />
    </Style>
    <Style Selector="Button.accent /template/ ContentPresenter#PART_ContentPresenter">
      <Setter Property="Foreground" Value="White" />
    </Style>

    <!-- Row-only selection. Avalonia's DataGrid theme draws a per-cell
         "current cell" rectangle and a focus rectangle that float on
         top of the row highlight, and the theme re-asserts IsVisible
         under the :current pseudo-class - so plain IsVisible=False
         loses the specificity fight. We instead make those Rectangles
         draw nothing by zeroing both the stroke and the stroke
         thickness; they remain in the visual tree but are invisible
         in every state. The CellBorder gets the same treatment so
         the cell never paints its own outline either. -->
    <Style Selector="DataGridCell">
      <Setter Property="Focusable" Value="False" />
      <Setter Property="IsTabStop" Value="False" />
      <Setter Property="FocusAdorner" Value="{x:Null}" />
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="BorderBrush" Value="Transparent" />
    </Style>
    <Style Selector="DataGridCell:focus, DataGridCell:focus-within, DataGridCell:current, DataGridCell:selected">
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="BorderBrush" Value="Transparent" />
    </Style>
    <Style Selector="DataGridCell /template/ Rectangle#CurrencyVisual">
      <Setter Property="Stroke" Value="Transparent" />
      <Setter Property="StrokeThickness" Value="0" />
      <Setter Property="Opacity" Value="0" />
    </Style>
    <Style Selector="DataGridCell:current /template/ Rectangle#CurrencyVisual">
      <Setter Property="Stroke" Value="Transparent" />
      <Setter Property="StrokeThickness" Value="0" />
      <Setter Property="Opacity" Value="0" />
    </Style>
    <Style Selector="DataGridCell /template/ Rectangle#FocusVisual">
      <Setter Property="Stroke" Value="Transparent" />
      <Setter Property="StrokeThickness" Value="0" />
      <Setter Property="Opacity" Value="0" />
    </Style>
    <Style Selector="DataGridCell:focus /template/ Rectangle#FocusVisual">
      <Setter Property="Stroke" Value="Transparent" />
      <Setter Property="StrokeThickness" Value="0" />
      <Setter Property="Opacity" Value="0" />
    </Style>
    <Style Selector="DataGridCell /template/ Border#CellBorder">
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="BorderBrush" Value="Transparent" />
    </Style>

    <!-- Cell background overrides for every focus/selection state the
         theme paints. Combined with the SelectionChanged handler in
         CertListView.axaml.cs (which clears the selection right after
         it lands), this guarantees no cell ever shows as "picked". -->
    <Style Selector="DataGridCell:selected">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="Foreground" Value="{DynamicResource SystemControlForegroundBaseHighBrush}" />
    </Style>
    <Style Selector="DataGridCell:current">
      <Setter Property="Background" Value="Transparent" />
    </Style>
    <Style Selector="DataGridCell:focus">
      <Setter Property="Background" Value="Transparent" />
    </Style>
    <Style Selector="DataGridCell:pressed">
      <Setter Property="Background" Value="Transparent" />
    </Style>

    <!-- We rely on per-row checkboxes for selection, so kill the Fluent
         theme's row-selection background. Hover still tints the row
         (left intact via DataGridRow:pointerover). Selected and
         pointer-pressed states paint the same background as the idle
         row so clicking a row produces no visible "selection". -->
    <Style Selector="DataGridRow:selected /template/ Rectangle#BackgroundRectangle">
      <Setter Property="Fill" Value="Transparent" />
      <Setter Property="Opacity" Value="0" />
    </Style>
    <Style Selector="DataGridRow:selected:pointerover /template/ Rectangle#BackgroundRectangle">
      <Setter Property="Opacity" Value="0.04" />
    </Style>
  </Application.Styles>
</Application>

