<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Mscp.PkiCertInstaller.ViewModels"
             x:Class="Mscp.PkiCertInstaller.Views.CertListView"
             x:DataType="vm:CertListViewModel">

  <UserControl.Resources>
    <!-- Inline path data so the buttons have icons regardless of which
         icon font is or isn't loaded at runtime. PathIcon ships with
         Avalonia core. -->
    <StreamGeometry x:Key="IconRefresh">M17.65,6.35C16.2,4.9 14.21,4 12,4A8,8 0 0,0 4,12A8,8 0 0,0 12,20C15.73,20 18.84,17.45 19.73,14H17.65C16.83,16.33 14.61,18 12,18A6,6 0 0,1 6,12A6,6 0 0,1 12,6C13.66,6 15.14,6.69 16.22,7.78L13,11H20V4L17.65,6.35Z</StreamGeometry>
    <StreamGeometry x:Key="IconDownload">M5,20H19V18H5M19,9H15V3H9V9H5L12,16L19,9Z</StreamGeometry>
    <StreamGeometry x:Key="IconDelete">M6,19A2,2 0 0,0 8,21H16A2,2 0 0,0 18,19V7H6V19M19,4H15.5L14.5,3H9.5L8.5,4H5V6H19V4Z</StreamGeometry>
    <StreamGeometry x:Key="IconOpenInNew">M14,3V5H17.59L7.76,14.83L9.17,16.24L19,6.41V10H21V3M19,19H5V5H12V3H5C3.89,3 3,3.9 3,5V19A2,2 0 0,0 5,21H19A2,2 0 0,0 21,19V12H19V19Z</StreamGeometry>
    <StreamGeometry x:Key="IconSearch">M9.5,3A6.5,6.5 0 0,1 16,9.5C16,11.11 15.41,12.59 14.44,13.73L14.71,14H15.5L20.5,19L19,20.5L14,15.5V14.71L13.73,14.44C12.59,15.41 11.11,16 9.5,16A6.5,6.5 0 0,1 3,9.5A6.5,6.5 0 0,1 9.5,3M9.5,5C7,5 5,7 5,9.5C5,12 7,14 9.5,14C12,14 14,12 14,9.5C14,7 12,5 9.5,5Z</StreamGeometry>
  </UserControl.Resources>

  <!-- No card backgrounds: toolbar and grid render directly on the
       main window backdrop. Borders / fills only appear on hover. -->
  <Grid RowDefinitions="Auto,*" Margin="20">

    <!-- Single consolidated toolbar: search + filter on the left,
         every primary action on the right. The brand/header row is
         gone - the title bar already has the app icon and name. -->
    <Grid Grid.Row="0" Margin="0,0,0,8"
          ColumnDefinitions="Auto,Auto,Auto,Auto,*,Auto,Auto,Auto,Auto"
          VerticalAlignment="Center">
      <Grid Grid.Column="0" VerticalAlignment="Center">
        <PathIcon Data="{StaticResource IconSearch}" Width="14" Height="14"
                  Foreground="#8A93A6"
                  HorizontalAlignment="Left" VerticalAlignment="Center"
                  Margin="10,0,0,0" />
        <TextBox Text="{Binding SearchText}" Width="320"
                 Padding="30,4,8,4" />
      </Grid>
      <TextBlock Grid.Column="1" Text="Folder:" VerticalAlignment="Center"
                 Foreground="#8A93A6" Margin="14,0,8,0" />
      <ComboBox Grid.Column="2"
                ItemsSource="{Binding FolderOptions}"
                SelectedItem="{Binding FolderFilter, Mode=TwoWay}"
                Width="170" />
      <TextBlock Grid.Column="3"
                 Text="{Binding Items.Count, StringFormat='{}{0} match(es)'}"
                 VerticalAlignment="Center" Foreground="#8A93A6"
                 Margin="12,0,0,0" />

      <!-- Spacer -->

      <Button Grid.Column="5"
              Command="{Binding ReloadCommand}"
              IsEnabled="{Binding !IsBusy}"
              ToolTip.Tip="Refresh certificate list"
              Margin="0,0,8,0">
        <StackPanel Orientation="Horizontal" Spacing="6">
          <PathIcon Data="{StaticResource IconRefresh}" Width="14" Height="14" Foreground="#E0E6F0" />
          <TextBlock Text="Reload" />
        </StackPanel>
      </Button>
      <Button Grid.Column="6"
              Command="{Binding InstallCommand}"
              Classes="accent"
              Margin="0,0,8,0">
        <StackPanel Orientation="Horizontal" Spacing="6">
          <PathIcon Data="{StaticResource IconDownload}" Width="14" Height="14" Foreground="White" />
          <TextBlock Text="Install" />
        </StackPanel>
      </Button>
      <Button Grid.Column="7"
              Command="{Binding UninstallCommand}"
              Margin="0,0,8,0">
        <StackPanel Orientation="Horizontal" Spacing="6">
          <PathIcon Data="{StaticResource IconDelete}" Width="14" Height="14" Foreground="#E0E6F0" />
          <TextBlock Text="Uninstall" />
        </StackPanel>
      </Button>
      <Button Grid.Column="8"
              Command="{Binding OpenServerConfiguratorCommand}">
        <StackPanel Orientation="Horizontal" Spacing="6">
          <PathIcon Data="{StaticResource IconOpenInNew}" Width="14" Height="14" Foreground="#E0E6F0" />
          <TextBlock Text="Open Server Configurator" />
        </StackPanel>
      </Button>
    </Grid>

    <!-- Grid sits directly on the window background. Double-tap on a
         row opens the cert details dialog (handled in code-behind).
         HorizontalScrollBarVisibility=Disabled forces the * columns to
         consume all leftover width on the very first layout pass; with
         Auto the grid sometimes settled at minimum width until the user
         resized the window. SelectionChanged in code-behind clears the
         selection so cell focus / row highlight never sticks - selection
         is driven solely by the leftmost checkbox column. -->
    <DataGrid Grid.Row="1"
              Name="Grid"
              ItemsSource="{Binding Items}"
              AutoGenerateColumns="False"
              GridLinesVisibility="Horizontal"
              HeadersVisibility="Column"
              IsReadOnly="True"
              CanUserResizeColumns="True"
              CanUserSortColumns="True"
              SelectionMode="Single"
              FontSize="12"
              Background="Transparent"
              RowBackground="Transparent"
              HorizontalScrollBarVisibility="Disabled"
              HorizontalAlignment="Stretch"
              DoubleTapped="OnRowDoubleTapped"
              SelectionChanged="OnGridSelectionChanged">
      <DataGrid.Columns>
        <DataGridTemplateColumn Width="44" MinWidth="44"
                                CanUserSort="False" CanUserReorder="False" CanUserResize="False">
          <DataGridTemplateColumn.Header>
            <CheckBox IsThreeState="True"
                      MinWidth="0" Padding="0" Margin="0"
                      IsChecked="{Binding $parent[DataGrid].((vm:CertListViewModel)DataContext).AllChecked, Mode=TwoWay}"
                      ToolTip.Tip="Select all visible" />
          </DataGridTemplateColumn.Header>
          <DataGridTemplateColumn.CellTemplate>
            <DataTemplate>
              <CheckBox IsChecked="{Binding IsChecked, Mode=TwoWay}"
                        MinWidth="0" Padding="0" Margin="0"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center" />
            </DataTemplate>
          </DataGridTemplateColumn.CellTemplate>
        </DataGridTemplateColumn>
        <DataGridTemplateColumn Header="Installed" Width="120"
                                CanUserSort="True" SortMemberPath="StatusText">
          <DataGridTemplateColumn.CellTemplate>
            <DataTemplate>
              <StackPanel Orientation="Horizontal" Spacing="8" Margin="10,0"
                          VerticalAlignment="Center">
                <Ellipse Width="10" Height="10" Fill="{Binding StatusBrush}" />
                <TextBlock Text="{Binding StatusText}" />
              </StackPanel>
            </DataTemplate>
          </DataGridTemplateColumn.CellTemplate>
        </DataGridTemplateColumn>
        <DataGridTemplateColumn Header="Machine Match" Width="140"
                                CanUserSort="True" SortMemberPath="MachineMatchText">
          <DataGridTemplateColumn.CellTemplate>
            <DataTemplate>
              <StackPanel Orientation="Horizontal" Spacing="8" Margin="10,0"
                          VerticalAlignment="Center"
                          ToolTip.Tip="{Binding MachineMatchTooltip}">
                <Ellipse Width="10" Height="10" Fill="{Binding MachineMatchBrush}" />
                <TextBlock Text="{Binding MachineMatchText}" />
              </StackPanel>
            </DataTemplate>
          </DataGridTemplateColumn.CellTemplate>
        </DataGridTemplateColumn>
        <DataGridTextColumn Header="Name"   Binding="{Binding Name}"      Width="*" MinWidth="180" />
        <DataGridTextColumn Header="Folder" Binding="{Binding KindLabel}" Width="130" />
        <DataGridTemplateColumn Header="SANs" Width="2*" MinWidth="180"
                                CanUserSort="True" SortMemberPath="SansShort">
          <DataGridTemplateColumn.CellTemplate>
            <DataTemplate>
              <TextBlock Text="{Binding SansShort}"
                         ToolTip.Tip="{Binding Sans}"
                         VerticalAlignment="Center"
                         Margin="10,0"
                         TextTrimming="CharacterEllipsis" />
            </DataTemplate>
          </DataGridTemplateColumn.CellTemplate>
        </DataGridTemplateColumn>
        <DataGridTextColumn Header="Remaining" Binding="{Binding Remaining}" Width="110" />
      </DataGrid.Columns>
    </DataGrid>
  </Grid>
</UserControl>
