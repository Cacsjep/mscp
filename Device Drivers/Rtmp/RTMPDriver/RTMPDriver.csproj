<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net47</TargetFramework>
    <OutputType>Library</OutputType>
    <RootNamespace>RTMPDriver</RootNamespace>
    <AssemblyName>RTMPDriver</AssemblyName>
    <LangVersion>latest</LangVersion>
    <PluginName>RTMPDriver</PluginName>
    <MIPPluginDir>$(MIPDriversRoot)\$(PluginName)\</MIPPluginDir>
    <StopRecordingServer>true</StopRecordingServer>
    <StartRecordingServer>true</StartRecordingServer>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="MilestoneSystems.VideoOS.Platform.DriverFramework" Version="*" />
  </ItemGroup>

  <ItemGroup>
    <Reference Include="System.ServiceModel" />
  </ItemGroup>

  <ItemGroup>
    <Content Include="RTMPDriver.def">
      <CopyToOutputDirectory>Always</CopyToOutputDirectory>
    </Content>
  </ItemGroup>

</Project>
