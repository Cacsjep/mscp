<Window x:Class="FlexView.Client.ViewBrowserWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Browse Views" Width="420" Height="500"
        WindowStartupLocation="CenterOwner"
        Background="#FF1C2326" ResizeMode="CanResizeWithGrip">
    <Window.Resources>
        <Style TargetType="TreeViewItem">
            <Setter Property="Foreground" Value="#FFE6EDF3"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Padding" Value="2,3"/>
            <Setter Property="IsExpanded" Value="True"/>
        </Style>
    </Window.Resources>
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock x:Name="headerText" Grid.Row="0" Text="Select a folder"
                   Foreground="White" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,10"/>

        <Border Grid.Row="1" BorderBrush="#FF30363D" BorderThickness="1" CornerRadius="4" Background="#FF161B22">
            <TreeView x:Name="tree" Background="Transparent" BorderThickness="0"
                      SelectedItemChanged="Tree_SelectedItemChanged"/>
        </Border>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
            <Button x:Name="btnSelect" Content="Select" IsEnabled="False"
                    Background="#FF238636" Foreground="White" BorderBrush="#FF2EA043"
                    Padding="18,8" Cursor="Hand" Click="OnSelectClick" Margin="0,0,8,0"
                    MinHeight="32" MinWidth="80" FontSize="12"/>
            <Button Content="Cancel"
                    Background="#FF3A3F44" Foreground="White" BorderBrush="#FF555555"
                    Padding="18,8" Cursor="Hand" Click="OnCancelClick"
                    MinHeight="32" MinWidth="80" FontSize="12"/>
        </StackPanel>
    </Grid>
</Window>
