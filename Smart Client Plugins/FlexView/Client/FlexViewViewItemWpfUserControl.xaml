<external:ViewItemWpfUserControl
    xmlns:external="clr-namespace:VideoOS.Platform.Client;assembly=VideoOS.Platform"
    x:Class="FlexView.Client.FlexViewViewItemWpfUserControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    mc:Ignorable="d"
    d:DesignHeight="700"
    d:DesignWidth="900"
    Focusable="True"
    PreviewKeyDown="OnPreviewKeyDown"
    Background="#FF070809">
    <Grid Background="#FF070809">
        <Grid.Resources>
            <!-- Flat dark button template (no hover color change from system) -->
            <ControlTemplate x:Key="FlatButtonTemplate" TargetType="Button">
                <Border x:Name="border" Background="{TemplateBinding Background}"
                        BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="1"
                        Padding="{TemplateBinding Padding}" SnapsToDevicePixels="True">
                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
                <ControlTemplate.Triggers>
                    <Trigger Property="IsMouseOver" Value="True">
                        <Setter TargetName="border" Property="Background" Value="#FF4A4F54"/>
                        <Setter TargetName="border" Property="BorderBrush" Value="#FF666666"/>
                    </Trigger>
                    <Trigger Property="IsPressed" Value="True">
                        <Setter TargetName="border" Property="Background" Value="#FF555A5F"/>
                    </Trigger>
                </ControlTemplate.Triggers>
            </ControlTemplate>
            <ControlTemplate x:Key="AccentButtonTemplate" TargetType="Button">
                <Border x:Name="border" Background="{TemplateBinding Background}"
                        BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="1"
                        Padding="{TemplateBinding Padding}" SnapsToDevicePixels="True">
                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
                <ControlTemplate.Triggers>
                    <Trigger Property="IsMouseOver" Value="True">
                        <Setter TargetName="border" Property="Background" Value="#FF2EA043"/>
                    </Trigger>
                    <Trigger Property="IsPressed" Value="True">
                        <Setter TargetName="border" Property="Background" Value="#FF3AB550"/>
                    </Trigger>
                </ControlTemplate.Triggers>
            </ControlTemplate>

            <Style x:Key="ToolButton" TargetType="Button">
                <Setter Property="Background" Value="#FF3A3F44"/>
                <Setter Property="Foreground" Value="White"/>
                <Setter Property="BorderBrush" Value="#FF555555"/>
                <Setter Property="Padding" Value="12,6"/>
                <Setter Property="MinHeight" Value="28"/>
                <Setter Property="Cursor" Value="Hand"/>
                <Setter Property="FontSize" Value="12"/>
                <Setter Property="Template" Value="{StaticResource FlatButtonTemplate}"/>
            </Style>
            <Style x:Key="AccentButton" TargetType="Button">
                <Setter Property="Background" Value="#FF238636"/>
                <Setter Property="Foreground" Value="White"/>
                <Setter Property="BorderBrush" Value="#FF2EA043"/>
                <Setter Property="Padding" Value="14,6"/>
                <Setter Property="MinHeight" Value="28"/>
                <Setter Property="Cursor" Value="Hand"/>
                <Setter Property="FontSize" Value="12"/>
                <Setter Property="FontWeight" Value="SemiBold"/>
                <Setter Property="Template" Value="{StaticResource AccentButtonTemplate}"/>
            </Style>
        </Grid.Resources>

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header toolbar -->
        <Border Grid.Row="0" Background="#FF070809" Padding="12,8" BorderBrush="#FF30363D" BorderThickness="0,0,0,0.5">
            <Grid>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                    <Button Content="&#x2795; New" Style="{StaticResource ToolButton}"
                            Click="OnNewClick" Margin="0,0,4,0"
                            Background="#FF1565C0" BorderBrush="#FF1976D2"/>
                    <Button Content="&#x1F4C2; Open View" Style="{StaticResource ToolButton}"
                            Click="OnOpenClick" Margin="0,0,4,0"/>
<Button Content="&#x1F4BE; Save" Style="{StaticResource AccentButton}"
                            Click="OnSaveClick"/>
                </StackPanel>
                <TextBlock x:Name="viewNameLabel" Foreground="#FF58A6FF" FontSize="12"
                           VerticalAlignment="Center" HorizontalAlignment="Left" FontWeight="SemiBold"/>
                <TextBlock x:Name="statusText" Foreground="#FF8B949E" FontSize="12"
                           VerticalAlignment="Center" HorizontalAlignment="Right"/>
            </Grid>
        </Border>

        <!-- Grid canvas area -->
        <Grid Grid.Row="1">
            <!-- Hint overlay shown when no panes -->
            <Border x:Name="hintOverlay" VerticalAlignment="Center" HorizontalAlignment="Center"
                    Background="#FF1C2326" CornerRadius="6" Padding="24,16" Panel.ZIndex="10">
                <StackPanel>
                    <TextBlock Text="Click and drag on the grid to create panes"
                               Foreground="#FFAAAAAA" FontSize="16" HorizontalAlignment="Center"/>
                    <TextBlock Text="Right-click a pane to delete it  |  Drag to move  |  Drag edges to resize"
                               Foreground="#FF888888" FontSize="12" HorizontalAlignment="Center" Margin="0,6,0,0"/>
                </StackPanel>
            </Border>

            <!-- The grid canvas inside a Viewbox for uniform scaling -->
            <Viewbox Stretch="Uniform" Margin="4">
                <Canvas x:Name="gridCanvas" Width="800" Height="450"
                        Background="Transparent" ClipToBounds="True"
                        MouseLeftButtonDown="Canvas_MouseLeftButtonDown"
                        MouseMove="Canvas_MouseMove"
                        MouseLeftButtonUp="Canvas_MouseLeftButtonUp"
                        MouseRightButtonDown="Canvas_MouseRightButtonDown"/>
            </Viewbox>
        </Grid>
    </Grid>
</external:ViewItemWpfUserControl>
