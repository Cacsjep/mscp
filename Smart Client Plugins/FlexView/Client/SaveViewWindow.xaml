<Window x:Class="FlexView.Client.SaveViewWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Save View" Width="420" Height="220"
        WindowStartupLocation="CenterOwner"
        Background="#FF1C2326" ResizeMode="NoResize">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Save View" Foreground="White" FontSize="14"
                   FontWeight="SemiBold" Margin="0,0,0,14"/>

        <!-- View Name -->
        <DockPanel Grid.Row="1" Margin="0,0,0,10">
            <TextBlock Text="Name:" Foreground="#FFB0B0B0" VerticalAlignment="Center"
                       Width="60" FontSize="12"/>
            <TextBox x:Name="nameBox" Background="#FF0D1117" Foreground="White"
                     BorderBrush="#FF30363D" Padding="6,4" FontSize="12"
                     VerticalContentAlignment="Center"/>
        </DockPanel>

        <!-- Folder -->
        <DockPanel Grid.Row="2" Margin="0,0,0,10">
            <TextBlock Text="Folder:" Foreground="#FFB0B0B0" VerticalAlignment="Center"
                       Width="60" FontSize="12"/>
            <Button DockPanel.Dock="Right" Content="Browse" Click="OnBrowseFolder"
                    Background="#FF3A3F44" Foreground="White" BorderBrush="#FF555555"
                    Padding="10,4" Margin="8,0,0,0" Cursor="Hand" FontSize="12"
                    MinHeight="26"/>
            <TextBlock x:Name="folderLabel" Foreground="#FF58A6FF" VerticalAlignment="Center"
                       FontSize="12" Text="(none selected)" TextTrimming="CharacterEllipsis"/>
        </DockPanel>

        <!-- Buttons -->
        <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,6,0,0">
            <Button Content="Save" Click="OnSaveClick"
                    Background="#FF238636" Foreground="White" BorderBrush="#FF2EA043"
                    Padding="18,6" Cursor="Hand" FontSize="12" FontWeight="SemiBold"
                    Margin="0,0,8,0" MinHeight="28"/>
            <Button Content="Cancel" Click="OnCancelClick"
                    Background="#FF3A3F44" Foreground="White" BorderBrush="#FF555555"
                    Padding="18,6" Cursor="Hand" FontSize="12" MinHeight="28"/>
        </StackPanel>
    </Grid>
</Window>
