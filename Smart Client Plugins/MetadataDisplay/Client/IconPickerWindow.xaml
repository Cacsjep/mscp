<Window
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:fa="http://schemas.fontawesome.com/icons/"
    x:Class="MetadataDisplay.Client.IconPickerWindow"
    Title="Pick icon"
    Width="640" Height="540"
    WindowStartupLocation="CenterOwner"
    Background="#FF1E1E1E"
    Foreground="#FFD0D0D0"
    FontSize="13">
    <Window.Resources>
        <Style x:Key="DarkButton" TargetType="Button">
            <Setter Property="Background" Value="#FF2A2A2A"/>
            <Setter Property="Foreground" Value="#FFD0D0D0"/>
            <Setter Property="BorderBrush" Value="#FF444444"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="12,4"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="3"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#FF363636"/>
                                <Setter TargetName="bd" Property="BorderBrush" Value="#FF555555"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#FF404040"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="IconButton" TargetType="Button" BasedOn="{StaticResource DarkButton}">
            <Setter Property="Width" Value="44"/>
            <Setter Property="Height" Value="44"/>
            <Setter Property="Margin" Value="2"/>
            <Setter Property="Padding" Value="6"/>
        </Style>
    </Window.Resources>
    <DockPanel>
        <Border DockPanel.Dock="Bottom" Background="#FF252525" BorderBrush="#FF333333" BorderThickness="0,1,0,0" Padding="12,8">
            <DockPanel>
                <TextBlock x:Name="selectedText" DockPanel.Dock="Left" VerticalAlignment="Center" Foreground="#FFA9B5BB"/>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="None" MinWidth="80" Margin="0,0,8,0" Style="{StaticResource DarkButton}" Click="OnClear"/>
                    <Button Content="Cancel" MinWidth="80" Margin="0,0,8,0" Style="{StaticResource DarkButton}" Click="OnCancel"/>
                    <Button Content="OK" MinWidth="80" IsDefault="True" Style="{StaticResource DarkButton}" Click="OnOk"/>
                </StackPanel>
            </DockPanel>
        </Border>
        <Border DockPanel.Dock="Top" Padding="12,8" BorderBrush="#FF333333" BorderThickness="0,0,0,1">
            <TextBox x:Name="searchBox" Background="#FF2A2A2A" Foreground="#FFD0D0D0"
                     BorderBrush="#FF444444" BorderThickness="1" Padding="6,4"
                     CaretBrush="#FFD0D0D0"
                     TextChanged="OnSearchChanged"/>
        </Border>
        <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="12,8">
            <ItemsControl x:Name="iconGrid">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
            </ItemsControl>
        </ScrollViewer>
    </DockPanel>
</Window>
