<Window x:Class="MetadataDisplay.Client.PacketImportDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Import packet"
        Width="900" Height="700"
        WindowStartupLocation="CenterOwner"
        Background="#1E1E1E"
        Foreground="#E6EAEC"
        ShowInTaskbar="False">
    <Window.Resources>
        <Style TargetType="Button">
            <Setter Property="Background" Value="#FF2A2A2A"/>
            <Setter Property="Foreground" Value="#FFD0D0D0"/>
            <Setter Property="BorderBrush" Value="#FF444444"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="14,4"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="MinHeight" Value="26"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="3"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#FF363636"/>
                                <Setter TargetName="bd" Property="BorderBrush" Value="#FF555555"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#FF404040"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="bd" Property="Opacity" Value="0.5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>
    <Grid Margin="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   TextWrapping="Wrap"
                   Foreground="#CFD7DA"
                   Margin="0,0,0,10"
                   Text="Paste a metadata XML packet below. Topics and fields discovered in the packet will be added to the dropdowns - no live listening required."/>

        <Border Grid.Row="1"
                Background="#1A1A1A"
                BorderBrush="#333"
                BorderThickness="1"
                Padding="2">
            <RichTextBox x:Name="packetRtb"
                         Background="Transparent"
                         BorderThickness="0"
                         Foreground="#E6EAEC"
                         CaretBrush="#E6EAEC"
                         FontFamily="Consolas"
                         FontSize="12"
                         AcceptsReturn="True"
                         AcceptsTab="True"
                         VerticalScrollBarVisibility="Auto"
                         HorizontalScrollBarVisibility="Auto"
                         TextChanged="OnPacketTextChanged">
                <RichTextBox.Resources>
                    <Style TargetType="Paragraph">
                        <Setter Property="Margin" Value="0"/>
                    </Style>
                </RichTextBox.Resources>
            </RichTextBox>
        </Border>

        <TextBlock Grid.Row="2"
                   x:Name="statusText"
                   Margin="2,10,0,10"
                   FontSize="12"
                   Foreground="#7A8388"
                   TextWrapping="Wrap"
                   Text="Paste an XML packet to begin."/>

        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button x:Name="importButton" Content="Import"
                    Margin="0,0,8,0" Click="OnImport"
                    IsDefault="True" IsEnabled="False"/>
            <Button Content="Cancel" Click="OnCancel" IsCancel="True"/>
        </StackPanel>
    </Grid>
</Window>
