<external:ViewItemWpfUserControl
    xmlns:external="clr-namespace:VideoOS.Platform.Client;assembly=VideoOS.Platform"
    x:Class="MetadataDisplay.Client.MetadataDisplayViewItemWpfUserControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    PreviewMouseLeftButtonUp="OnMouseLeftUp"
    PreviewMouseDoubleClick="OnMouseDoubleClick">
    <Grid Background="#FF1C2326">
        <Viewbox Stretch="Uniform" Margin="12">
            <Grid x:Name="rootGrid" Width="320" Height="200">
                <Grid.RowDefinitions>
                    <RowDefinition x:Name="titleRow" Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <TextBlock x:Name="titleText"
                           Grid.Row="0"
                           Foreground="#FFCFD7DA"
                           FontSize="14"
                           Margin="0,0,0,4"
                           HorizontalAlignment="Left"/>
                <Grid x:Name="renderHost" Grid.Row="1"/>
                <StackPanel x:Name="setupPanel"
                            Grid.Row="1"
                            Orientation="Vertical"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Visibility="Collapsed">
                    <TextBlock x:Name="setupHint"
                               Foreground="#FF7A8388"
                               FontSize="14"
                               TextAlignment="Center"
                               Margin="0,0,0,12"/>
                    <Button x:Name="openConfigButton"
                            Content="Open configuration..."
                            HorizontalAlignment="Center"
                            Padding="14,6"
                            Cursor="Hand"
                            Background="#FF2A2A2A"
                            Foreground="#FFD0D0D0"
                            BorderBrush="#FF555555"
                            BorderThickness="1"
                            FontSize="13"
                            Click="OnOpenConfigClick"/>
                </StackPanel>
                <Border x:Name="staleBadge"
                        Grid.Row="0"
                        Background="#88000000"
                        CornerRadius="3"
                        Padding="6,2"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Top"
                        Visibility="Collapsed">
                    <TextBlock Text="stale" Foreground="#FFCFD7DA" FontSize="10"/>
                </Border>
            </Grid>
        </Viewbox>
    </Grid>
</external:ViewItemWpfUserControl>
