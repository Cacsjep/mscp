<external:ViewItemWpfUserControl
    xmlns:external="clr-namespace:VideoOS.Platform.Client;assembly=VideoOS.Platform"
    x:Class="MetadataDisplay.Client.MetadataDisplayViewItemWpfUserControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    PreviewMouseLeftButtonUp="OnMouseLeftUp"
    PreviewMouseDoubleClick="OnMouseDoubleClick">
    <Grid Background="#FF1C2326" ClipToBounds="True">
        <Viewbox x:Name="renderViewbox" Stretch="Uniform" Margin="6">
            <Grid x:Name="rootGrid" Width="320" Background="Transparent">
                <Grid.RowDefinitions>
                    <RowDefinition x:Name="titleRow" Height="Auto"/>
                    <RowDefinition Height="200"/>
                </Grid.RowDefinitions>
                <TextBlock x:Name="titleText"
                           Grid.Row="0"
                           Foreground="#FFCFD7DA"
                           FontSize="14"
                           Margin="0,0,0,2"
                           HorizontalAlignment="Center"
                           TextAlignment="Center"/>
                <Grid x:Name="renderHost" Grid.Row="1" Background="Transparent"/>
                <Border x:Name="staleBadge"
                        Grid.Row="0"
                        Background="#88000000"
                        CornerRadius="3"
                        Padding="6,2"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Top"
                        Visibility="Collapsed">
                    <TextBlock Text="stale" Foreground="#FFCFD7DA" FontSize="10"/>
                </Border>
            </Grid>
        </Viewbox>
        <StackPanel x:Name="setupPanel"
                    Orientation="Vertical"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Visibility="Collapsed">
            <TextBlock x:Name="setupHint"
                       Foreground="#FF7A8388"
                       FontSize="14"
                       TextAlignment="Center"
                       Margin="0,0,0,12"/>
            <Border x:Name="openConfigButton"
                    Background="#FF2A2A2A"
                    BorderBrush="#FF555555"
                    BorderThickness="1"
                    CornerRadius="3"
                    Padding="16,8"
                    Cursor="Hand"
                    HorizontalAlignment="Center"
                    MouseLeftButtonUp="OnOpenConfigClick">
                <TextBlock Text="Open configuration..."
                           Foreground="#FFD0D0D0"
                           FontSize="13"
                           HorizontalAlignment="Center"/>
            </Border>
        </StackPanel>
    </Grid>
</external:ViewItemWpfUserControl>
