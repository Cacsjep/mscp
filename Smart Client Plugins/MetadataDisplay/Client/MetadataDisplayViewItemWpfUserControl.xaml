<external:ViewItemWpfUserControl
    xmlns:external="clr-namespace:VideoOS.Platform.Client;assembly=VideoOS.Platform"
    x:Class="MetadataDisplay.Client.MetadataDisplayViewItemWpfUserControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    PreviewMouseLeftButtonUp="OnMouseLeftUp"
    PreviewMouseDoubleClick="OnMouseDoubleClick">
    <Grid Background="#FF1C2326" ClipToBounds="True">
        <Viewbox x:Name="renderViewbox" Stretch="Uniform" Margin="6">
            <Grid x:Name="rootGrid" Width="320" Background="Transparent">
                <Grid.RowDefinitions>
                    <RowDefinition x:Name="titleRow" Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <TextBlock x:Name="titleText"
                           Grid.Row="0"
                           Foreground="#FFCFD7DA"
                           FontSize="14"
                           Margin="0,0,0,2"
                           HorizontalAlignment="Center"
                           TextAlignment="Center"/>
                <Grid x:Name="renderHost" Grid.Row="1" Background="Transparent"/>
                <Border x:Name="staleBadge"
                        Grid.Row="0"
                        Background="#88000000"
                        CornerRadius="3"
                        Padding="6,2"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Top"
                        Visibility="Collapsed">
                    <TextBlock Text="stale" Foreground="#FFCFD7DA" FontSize="10"/>
                </Border>
            </Grid>
        </Viewbox>
        <!-- Native-resolution host for renderers (LineChart) that draw with SkiaSharp.
             Bypasses the 320-wide Viewbox so Skia paints at the actual pane size
             instead of being bitmap-scaled and looking pixelated. The title bar
             above doesn't apply here — chart renderers handle their own labels. -->
        <Grid x:Name="chartRoot" Margin="6" Visibility="Collapsed">
            <Grid.RowDefinitions>
                <RowDefinition x:Name="chartTitleRow" Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <TextBlock x:Name="chartTitleText"
                       Grid.Row="0"
                       Foreground="#FFCFD7DA"
                       FontSize="14"
                       Margin="0,0,0,2"
                       HorizontalAlignment="Center"
                       TextAlignment="Center"/>
            <Grid x:Name="chartHost" Grid.Row="1" Background="Transparent"/>
        </Grid>
        <Grid x:Name="noDataPanel"
              HorizontalAlignment="Center"
              VerticalAlignment="Center"
              Visibility="Collapsed">
            <StackPanel Orientation="Vertical" HorizontalAlignment="Center">
                <Ellipse Width="14" Height="14"
                         Fill="#FFE69500"
                         Margin="0,0,0,6"
                         HorizontalAlignment="Center">
                    <Ellipse.Triggers>
                        <EventTrigger RoutedEvent="Ellipse.Loaded">
                            <BeginStoryboard>
                                <Storyboard RepeatBehavior="Forever">
                                    <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                     From="0.25" To="1.0" Duration="0:0:0.9" AutoReverse="True"/>
                                </Storyboard>
                            </BeginStoryboard>
                        </EventTrigger>
                    </Ellipse.Triggers>
                </Ellipse>
                <TextBlock Text="Waiting for data..."
                           Foreground="#FFA9B5BB"
                           FontSize="13"
                           HorizontalAlignment="Center"/>
                <TextBlock x:Name="noDataDetail"
                           Text=""
                           Foreground="#FF7A8388"
                           FontSize="11"
                           HorizontalAlignment="Center"
                           Margin="0,4,0,0"
                           TextAlignment="Center"
                           TextWrapping="Wrap"
                           MaxWidth="320"/>
            </StackPanel>
        </Grid>
        <Viewbox x:Name="setupPanel"
                 Stretch="Uniform"
                 StretchDirection="DownOnly"
                 Margin="12"
                 Visibility="Collapsed">
        <StackPanel Orientation="Vertical"
                    MaxWidth="480">
            <TextBlock x:Name="setupHeader"
                       Foreground="#FFE6EAEC"
                       FontSize="14"
                       FontWeight="SemiBold"
                       HorizontalAlignment="Left"
                       Margin="0,0,0,4"
                       Text="Metadata Display"/>
            <TextBlock x:Name="setupSubheader"
                       Foreground="#FF7A8388"
                       FontSize="11"
                       HorizontalAlignment="Left"
                       Margin="0,0,0,12"/>
            <Grid x:Name="setupSummary" HorizontalAlignment="Left" Margin="0,0,0,16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <TextBlock Grid.Row="0" Grid.Column="0" Text="Channel"  Foreground="#FF7A8388" FontSize="12" Margin="0,0,16,4"/>
                <TextBlock Grid.Row="0" Grid.Column="1" x:Name="summaryChannel" Foreground="#FFCFD7DA" FontSize="12" Margin="0,0,0,4"/>
                <TextBlock Grid.Row="1" Grid.Column="0" Text="Render"   Foreground="#FF7A8388" FontSize="12" Margin="0,0,16,4"/>
                <TextBlock Grid.Row="1" Grid.Column="1" x:Name="summaryRender"  Foreground="#FFCFD7DA" FontSize="12" Margin="0,0,0,4"/>
                <TextBlock Grid.Row="2" Grid.Column="0" Text="Topic"    Foreground="#FF7A8388" FontSize="12" Margin="0,0,16,4"/>
                <TextBlock Grid.Row="2" Grid.Column="1" x:Name="summaryTopic"   Foreground="#FFCFD7DA" FontSize="12" Margin="0,0,0,4" TextTrimming="CharacterEllipsis"/>
                <TextBlock Grid.Row="3" Grid.Column="0" Text="Data key" Foreground="#FF7A8388" FontSize="12" Margin="0,0,16,0"/>
                <TextBlock Grid.Row="3" Grid.Column="1" x:Name="summaryDataKey" Foreground="#FFCFD7DA" FontSize="12"/>
            </Grid>
            <Border x:Name="openConfigButton"
                    Background="#FF2A2A2A"
                    BorderBrush="#FF555555"
                    BorderThickness="1"
                    CornerRadius="3"
                    Padding="16,8"
                    Cursor="Hand"
                    HorizontalAlignment="Left"
                    MouseLeftButtonUp="OnOpenConfigClick">
                <TextBlock Text="Open configuration..."
                           Foreground="#FFD0D0D0"
                           FontSize="13"/>
            </Border>
            <TextBlock x:Name="setupHint"
                       Foreground="#FF7A8388"
                       FontSize="11"
                       HorizontalAlignment="Left"
                       Margin="0,8,0,0"
                       Visibility="Collapsed"
                       TextWrapping="Wrap"/>
        </StackPanel>
        </Viewbox>
    </Grid>
</external:ViewItemWpfUserControl>
