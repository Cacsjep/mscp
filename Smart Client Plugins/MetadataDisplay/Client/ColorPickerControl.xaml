<UserControl
    x:Class="MetadataDisplay.Client.ColorPickerControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    HorizontalAlignment="Left">
    <Border x:Name="swatch"
            Width="38" Height="22"
            CornerRadius="3"
            Background="#FF777777"
            BorderBrush="#FF555555"
            BorderThickness="1"
            Cursor="Hand"
            ToolTip="Click to pick a color"
            MouseLeftButtonUp="OnSwatchClick"/>
</UserControl>
