<UserControl x:Class="SmartBar.Client.SmartBarSettingsPanelControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:fa5="http://schemas.fontawesome.com/icons/"
             Background="#FF1E1E1E">

    <UserControl.Resources>
        <Style x:Key="SectionHeader" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#FF2196F3" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Margin" Value="0,16,0,8" />
        </Style>
        <Style x:Key="LabelText" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#FFD0D0D0" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>
        <Style x:Key="SmallButton" TargetType="Button">
            <Setter Property="Background" Value="#FF2A2A2A" />
            <Setter Property="Foreground" Value="#FFD0D0D0" />
            <Setter Property="BorderBrush" Value="#FF444444" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="12,4" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="3" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#FF363636" />
                                <Setter TargetName="bd" Property="BorderBrush" Value="#FF555555" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#FF404040" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="SaveButton" TargetType="Button">
            <Setter Property="Foreground" Value="White" />
            <Setter Property="Background" Value="#FF3399FF" />
            <Setter Property="BorderBrush" Value="#FF2277CC" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="20,8" />
            <Setter Property="MinHeight" Value="32" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="3" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#FF2288DD" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#FF1166AA" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="bd" Property="Background" Value="#FF2A2A2A" />
                                <Setter TargetName="bd" Property="BorderBrush" Value="#FF444444" />
                                <Setter Property="Foreground" Value="#FF666666" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="DarkTextBox" TargetType="TextBox">
            <Setter Property="Background" Value="#FF2A2A2A" />
            <Setter Property="Foreground" Value="#FFD0D0D0" />
            <Setter Property="BorderBrush" Value="#FF444444" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="6,4" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="CaretBrush" Value="#FFD0D0D0" />
        </Style>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="20">
        <StackPanel MaxWidth="600">

            <!-- General -->
            <TextBlock Text="General" Style="{StaticResource SectionHeader}" />
            <Border Background="#FF252525" CornerRadius="6" Padding="14,10" Margin="0,0,0,4">
                <DockPanel>
                    <TextBlock Text="Invoke key:" Style="{StaticResource LabelText}" />
                    <Border x:Name="keyRecorderBorder"
                            DockPanel.Dock="Right" HorizontalAlignment="Right"
                            Background="#FF2A2A2A" BorderBrush="#FF444444" BorderThickness="1"
                            CornerRadius="3" Padding="12,4" MinWidth="80" Cursor="Hand"
                            MouseLeftButtonUp="OnKeyRecorderClick"
                            Focusable="True" KeyDown="OnKeyRecorderKeyDown"
                            LostFocus="OnKeyRecorderLostFocus">
                        <TextBlock x:Name="keyRecorderText" Foreground="#FFD0D0D0" FontSize="13"
                                   HorizontalAlignment="Center" />
                    </Border>
                </DockPanel>
            </Border>
            <TextBlock Text="Click to change, then press the desired key. Letters, digits, Esc, Enter, arrows, and Tab are reserved."
                       Foreground="#FF666666" FontSize="11" Margin="4,0,0,0" TextWrapping="Wrap" />

            <!-- History Settings -->
            <TextBlock Text="History" Style="{StaticResource SectionHeader}" />
            <Border Background="#FF252525" CornerRadius="6" Padding="14,10" Margin="0,0,0,4">
                <DockPanel>
                    <TextBlock Text="Max undo history entries:" Style="{StaticResource LabelText}" />
                    <ComboBox x:Name="maxHistoryCombo"
                              DockPanel.Dock="Right"
                              HorizontalAlignment="Right"
                              Width="80"
                              Background="#FF2A2A2A"
                              Foreground="#FFD0D0D0"
                              BorderBrush="#FF444444"
                              FontSize="13" />
                </DockPanel>
            </Border>
            <TextBlock Text="Number of view and camera changes to remember for undo."
                       Foreground="#FF666666" FontSize="11" Margin="4,0,0,0" />

            <Border Background="#FF252525" CornerRadius="6" Padding="14,10" Margin="0,4,0,4">
                <DockPanel>
                    <TextBlock Text="Max recent items:" Style="{StaticResource LabelText}" />
                    <ComboBox x:Name="maxRecentCombo"
                              DockPanel.Dock="Right"
                              HorizontalAlignment="Right"
                              Width="80"
                              Background="#FF2A2A2A"
                              Foreground="#FFD0D0D0"
                              BorderBrush="#FF444444"
                              FontSize="13" />
                </DockPanel>
            </Border>
            <TextBlock Text="Number of recently used cameras and views shown at the top."
                       Foreground="#FF666666" FontSize="11" Margin="4,0,0,0" />

            <!-- Programs -->
            <TextBlock Text="Programs" Style="{StaticResource SectionHeader}" Margin="0,24,0,8" />
            <TextBlock Text="Programs listed here appear in the Smart Bar as launchable items."
                       Foreground="#FF666666" FontSize="11" Margin="4,0,0,4" />

            <!-- Column headers -->
            <Grid Margin="4,8,0,4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="1.5*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="Name" Foreground="#FF888888" FontSize="11" />
                <TextBlock Grid.Column="1" Text="Executable path" Foreground="#FF888888" FontSize="11" />
            </Grid>

            <ItemsControl x:Name="programList">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Background="#FF252525" CornerRadius="6" Padding="10,8" Margin="0,0,0,4">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="1.5*" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBox Grid.Column="0"
                                         Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}"
                                         Style="{StaticResource DarkTextBox}"
                                         Margin="0,0,6,0" />
                                <TextBox Grid.Column="1"
                                         Text="{Binding Path, UpdateSourceTrigger=PropertyChanged}"
                                         Style="{StaticResource DarkTextBox}"
                                         Margin="0,0,6,0" />
                                <Button Grid.Column="2"
                                        Width="24" Height="24"
                                        Style="{StaticResource SmallButton}"
                                        Padding="0"
                                        Click="OnBrowseProgram"
                                        ToolTip="Browse for executable"
                                        Margin="0,0,4,0">
                                    <fa5:ImageAwesome Icon="Solid_FolderOpen"
                                                      Foreground="#FF2196F3"
                                                      Width="10" Height="10"
                                                      HorizontalAlignment="Center"
                                                      VerticalAlignment="Center" />
                                </Button>
                                <Button Grid.Column="3"
                                        Width="24" Height="24"
                                        Style="{StaticResource SmallButton}"
                                        Padding="0"
                                        Click="OnRemoveProgram"
                                        ToolTip="Remove program">
                                    <fa5:ImageAwesome Icon="Solid_Times"
                                                      Foreground="#FFE05050"
                                                      Width="9" Height="9"
                                                      HorizontalAlignment="Center"
                                                      VerticalAlignment="Center" />
                                </Button>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <Button x:Name="addButton"
                    Click="OnAddProgram"
                    Style="{StaticResource SmallButton}"
                    HorizontalAlignment="Left"
                    Margin="0,8,0,0">
                <StackPanel Orientation="Horizontal">
                    <fa5:ImageAwesome Icon="Solid_Plus" Foreground="#FF2196F3" Width="10" Height="10"
                                      VerticalAlignment="Center" Margin="0,0,6,0" />
                    <TextBlock Text="Add program" VerticalAlignment="Center" />
                </StackPanel>
            </Button>

            <!-- Save -->
            <StackPanel Margin="0,24,0,0">
                <Button x:Name="saveButton"
                        Content="Save"
                        Click="OnSave"
                        Style="{StaticResource SaveButton}"
                        HorizontalAlignment="Left" />
                <TextBlock x:Name="validationHint"
                           Foreground="#FFE05050" FontSize="11" Margin="2,6,0,0"
                           Visibility="Collapsed" />
                <TextBlock x:Name="savedHint"
                           Text="Settings saved" Foreground="#FF4CAF50" FontSize="11"
                           Margin="2,6,0,0" Visibility="Collapsed" />
            </StackPanel>

        </StackPanel>
    </ScrollViewer>
</UserControl>
