<Window x:Class="SmartBar.Client.SmartBarWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:fa5="http://schemas.fontawesome.com/icons/"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False"
        ResizeMode="NoResize"
        PreviewKeyDown="OnPreviewKeyDown"
        MouseDown="OnBackdropMouseDown">

    <!-- Full-screen dark backdrop -->
    <Grid Background="#CC000000">

        <!-- Command palette -->
        <Border Background="#FF121212"
                BorderBrush="#FF333333"
                BorderThickness="1"
                CornerRadius="10"
                HorizontalAlignment="Center"
                VerticalAlignment="Top"
                Margin="0,120,0,0"
                Width="620"
                MaxHeight="480">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!-- Search bar -->
                <Border Grid.Row="0"
                        BorderBrush="#FF282828"
                        BorderThickness="0,0,0,1"
                        Padding="14,11">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <fa5:ImageAwesome Grid.Column="0"
                                          Icon="Solid_Search"
                                          Foreground="#FF666666"
                                          Width="14"
                                          Height="14"
                                          VerticalAlignment="Center"
                                          Margin="0,0,10,0" />
                        <TextBox x:Name="searchBox"
                                 Grid.Column="1"
                                 Foreground="#FFD0D0D0"
                                 CaretBrush="#FFD0D0D0"
                                 FontSize="14"
                                 VerticalAlignment="Center"
                                 TextChanged="OnSearchTextChanged">
                            <TextBox.Template>
                                <ControlTemplate TargetType="TextBox">
                                    <ScrollViewer x:Name="PART_ContentHost"
                                                  Background="Transparent" />
                                </ControlTemplate>
                            </TextBox.Template>
                        </TextBox>
                        <TextBlock x:Name="searchPlaceholder"
                                   Grid.Column="1"
                                   Text="Search cameras, views..."
                                   Foreground="#FF555555"
                                   FontSize="14"
                                   VerticalAlignment="Center"
                                   Margin="5,0,0,0"
                                   IsHitTestVisible="False" />
                    </Grid>
                </Border>

                <!-- Selection info bar (hidden when no cameras selected) -->
                <Border x:Name="selectionBar" Grid.Row="1"
                        BorderBrush="#FF282828"
                        BorderThickness="0,0,0,1"
                        Padding="14,6"
                        Visibility="Collapsed">
                    <DockPanel>
                        <TextBlock x:Name="selectionText"
                                   Foreground="#FF58A6FF"
                                   FontSize="11"
                                   VerticalAlignment="Center" />
                        <TextBlock Foreground="#FF444444" FontSize="11"
                                   VerticalAlignment="Center"
                                   HorizontalAlignment="Right"
                                   Text="Enter to create view  ·  Esc to clear" />
                    </DockPanel>
                </Border>

                <!-- Results -->
                <ScrollViewer Grid.Row="2"
                              VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled"
                              Focusable="False"
                              MaxHeight="370">
                    <StackPanel x:Name="resultPanel"
                                Margin="6,2,6,4" />
                </ScrollViewer>

                <!-- Footer -->
                <Border Grid.Row="3"
                        BorderBrush="#FF282828"
                        BorderThickness="0,1,0,0"
                        Padding="14,7">
                    <StackPanel Orientation="Horizontal">
                        <Border Background="#FF1E1E1E" CornerRadius="3" Padding="5,2" Margin="0,0,2,0">
                            <TextBlock Text="&#x2191;" Foreground="#FF505050" FontSize="10" />
                        </Border>
                        <Border Background="#FF1E1E1E" CornerRadius="3" Padding="5,2" Margin="0,0,6,0">
                            <TextBlock Text="&#x2193;" Foreground="#FF505050" FontSize="10" />
                        </Border>
                        <TextBlock Text="Navigate" Foreground="#FF505050" FontSize="10"
                                   VerticalAlignment="Center" Margin="0,0,14,0" />
                        <Border Background="#FF1E1E1E" CornerRadius="3" Padding="5,2" Margin="0,0,6,0">
                            <TextBlock Text="&#x23CE;" Foreground="#FF505050" FontSize="10" />
                        </Border>
                        <TextBlock Text="Select" Foreground="#FF505050" FontSize="10"
                                   VerticalAlignment="Center" Margin="0,0,14,0" />
                        <Border Background="#FF1E1E1E" CornerRadius="3" Padding="5,2" Margin="0,0,6,0">
                            <TextBlock Text="Tab" Foreground="#FF505050" FontSize="10" />
                        </Border>
                        <TextBlock Text="Multi-select" Foreground="#FF505050" FontSize="10"
                                   VerticalAlignment="Center" Margin="0,0,14,0" />
                        <Border Background="#FF1E1E1E" CornerRadius="3" Padding="5,2" Margin="0,0,6,0">
                            <TextBlock Text="Esc" Foreground="#FF505050" FontSize="10" />
                        </Border>
                        <TextBlock Text="Close" Foreground="#FF505050" FontSize="10"
                                   VerticalAlignment="Center" />
                    </StackPanel>
                </Border>
            </Grid>
        </Border>
    </Grid>
</Window>
