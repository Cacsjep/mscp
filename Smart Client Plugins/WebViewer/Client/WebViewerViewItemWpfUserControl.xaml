<external:ViewItemWpfUserControl
    xmlns:external="clr-namespace:VideoOS.Platform.Client;assembly=VideoOS.Platform"
    x:Class="WebViewer.Client.WebViewerViewItemWpfUserControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
    PreviewMouseLeftButtonUp="OnMouseLeftUp"
    PreviewMouseDoubleClick="OnMouseDoubleClick">
    <Grid Background="#FF1C2326" ClipToBounds="True">
        <!-- Live / playback view: title bar over the WebView2. -->
        <Grid x:Name="liveRoot">
            <Grid.RowDefinitions>
                <RowDefinition x:Name="titleRow" Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <TextBlock x:Name="titleText"
                       Grid.Row="0"
                       Foreground="#FFCFD7DA"
                       FontSize="14"
                       Margin="6,4,6,2"
                       HorizontalAlignment="Center"
                       TextAlignment="Center"
                       Visibility="Collapsed"/>
            <Grid x:Name="webHost" Grid.Row="1" Background="#FF1C2326"/>
            <!-- Loading and error overlays sit on top of webHost. -->
            <Grid x:Name="loadingPanel"
                  Grid.Row="1"
                  Background="#FF1C2326"
                  HorizontalAlignment="Stretch"
                  VerticalAlignment="Stretch"
                  Visibility="Collapsed">
                <StackPanel Orientation="Vertical" HorizontalAlignment="Center" VerticalAlignment="Center">
                    <Ellipse Width="14" Height="14"
                             Fill="#FF42A5F5"
                             Margin="0,0,0,8"
                             HorizontalAlignment="Center">
                        <Ellipse.Triggers>
                            <EventTrigger RoutedEvent="Ellipse.Loaded">
                                <BeginStoryboard>
                                    <Storyboard RepeatBehavior="Forever">
                                        <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                         From="0.25" To="1.0" Duration="0:0:0.9" AutoReverse="True"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                        </Ellipse.Triggers>
                    </Ellipse>
                    <TextBlock x:Name="loadingText"
                               Text="Loading..."
                               Foreground="#FFA9B5BB"
                               FontSize="13"
                               HorizontalAlignment="Center"/>
                </StackPanel>
            </Grid>
            <Grid x:Name="errorPanel"
                  Grid.Row="1"
                  Background="#FF1C2326"
                  HorizontalAlignment="Stretch"
                  VerticalAlignment="Stretch"
                  Visibility="Collapsed">
                <StackPanel Orientation="Vertical" HorizontalAlignment="Center" VerticalAlignment="Center">
                    <TextBlock Text="Failed to load page"
                               Foreground="#FFFF6B6B"
                               FontSize="13"
                               FontWeight="SemiBold"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,4"/>
                    <TextBlock x:Name="errorText"
                               Foreground="#FFA9B5BB"
                               FontSize="11"
                               TextWrapping="Wrap"
                               TextAlignment="Center"
                               MaxWidth="380"
                               HorizontalAlignment="Center"/>
                    <Border x:Name="reloadButton"
                            Background="#FF2A2A2A"
                            BorderBrush="#FF555555"
                            BorderThickness="1"
                            CornerRadius="3"
                            Padding="14,6"
                            Margin="0,12,0,0"
                            Cursor="Hand"
                            HorizontalAlignment="Center"
                            MouseLeftButtonUp="OnReloadClick">
                        <TextBlock Text="Reload"
                                   Foreground="#FFD0D0D0"
                                   FontSize="12"/>
                    </Border>
                </StackPanel>
            </Grid>
        </Grid>

        <!-- Setup mode: fields for URL, title, credentials, options.
             Mirrors the look of the MetadataDisplay setup panel so the two
             plugins feel like the same product family. -->
        <Viewbox x:Name="setupPanel"
                 Stretch="Uniform"
                 StretchDirection="DownOnly"
                 Margin="12"
                 Visibility="Collapsed">
            <StackPanel Orientation="Vertical" MaxWidth="560">
                <TextBlock Text="Web Viewer"
                           Foreground="#FFE6EAEC"
                           FontSize="14"
                           FontWeight="SemiBold"
                           HorizontalAlignment="Left"
                           Margin="0,0,0,4"/>
                <TextBlock x:Name="setupSubheader"
                           Foreground="#FF7A8388"
                           FontSize="11"
                           HorizontalAlignment="Left"
                           Margin="0,0,0,12"
                           Text="Embed a web page in this view item. Switch to Live to load."/>

                <!-- URL -->
                <TextBlock Text="URL *" Foreground="#FFCFD7DA" FontSize="12" Margin="0,0,0,2"/>
                <TextBox x:Name="urlBox"
                         Background="#FF2A2A2A" Foreground="#FFE6EDF3"
                         BorderBrush="#FF444444" BorderThickness="1"
                         CaretBrush="#FFE6EDF3"
                         Padding="6,5" FontSize="12"
                         Height="28"
                         VerticalContentAlignment="Center"
                         Margin="0,0,0,10"/>

                <!-- Title row -->
                <Grid Margin="0,0,0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Title" Foreground="#FFCFD7DA" FontSize="12" Margin="0,0,0,2"/>
                        <TextBox x:Name="titleBox"
                                 Background="#FF2A2A2A" Foreground="#FFE6EDF3"
                                 BorderBrush="#FF444444" BorderThickness="1"
                                 CaretBrush="#FFE6EDF3"
                                 Padding="6,5" FontSize="12"
                                 Height="28"
                                 VerticalContentAlignment="Center"/>
                    </StackPanel>
                    <CheckBox x:Name="showTitleCheck"
                              Grid.Column="1"
                              Content="Show"
                              Foreground="#FFCFD7DA"
                              VerticalAlignment="Bottom"
                              Margin="10,0,0,4"/>
                </Grid>

                <!-- Credentials -->
                <TextBlock Text="Credentials (optional, used for HTTP Basic auth)"
                           Foreground="#FF7A8388" FontSize="11" Margin="0,4,0,4"/>
                <Grid Margin="0,0,0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" Margin="0,0,5,0">
                        <TextBlock Text="User" Foreground="#FFCFD7DA" FontSize="12" Margin="0,0,0,2"/>
                        <TextBox x:Name="userBox"
                                 Background="#FF2A2A2A" Foreground="#FFE6EDF3"
                                 BorderBrush="#FF444444" BorderThickness="1"
                                 CaretBrush="#FFE6EDF3"
                                 Padding="6,5" FontSize="12"
                                 Height="28"
                                 VerticalContentAlignment="Center"/>
                    </StackPanel>
                    <StackPanel Grid.Column="1" Margin="5,0,0,0">
                        <TextBlock Text="Password" Foreground="#FFCFD7DA" FontSize="12" Margin="0,0,0,2"/>
                        <PasswordBox x:Name="passBox"
                                     Background="#FF2A2A2A" Foreground="#FFE6EDF3"
                                     BorderBrush="#FF444444" BorderThickness="1"
                                     Padding="6,5" FontSize="12"
                                     Height="28"
                                     VerticalContentAlignment="Center"/>
                    </StackPanel>
                </Grid>

                <CheckBox x:Name="autoAcceptCertsCheck"
                          Content="Auto-accept invalid TLS certificates"
                          Foreground="#FFCFD7DA"
                          Margin="0,2,0,4"/>
                <CheckBox x:Name="autoLoginCheck"
                          Content="Auto-fill credentials on basic-auth prompt"
                          Foreground="#FFCFD7DA"
                          Margin="0,0,0,12"/>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" Margin="0,4,0,0">
                    <Border x:Name="saveButton"
                            Background="#FF2A2A2A"
                            BorderBrush="#FF555555"
                            BorderThickness="1"
                            CornerRadius="3"
                            Padding="14,6"
                            Cursor="Hand"
                            Margin="0,0,8,0"
                            MouseLeftButtonUp="OnSaveClick">
                        <TextBlock Text="Save"
                                   Foreground="#FFD0D0D0"
                                   FontSize="12"/>
                    </Border>
                    <Border x:Name="testButton"
                            Background="#FF2A2A2A"
                            BorderBrush="#FF555555"
                            BorderThickness="1"
                            CornerRadius="3"
                            Padding="14,6"
                            Cursor="Hand"
                            MouseLeftButtonUp="OnTestClick">
                        <TextBlock Text="Test in browser"
                                   Foreground="#FFD0D0D0"
                                   FontSize="12"/>
                    </Border>
                </StackPanel>
                <TextBlock x:Name="setupHint"
                           Foreground="#FF7A8388"
                           FontSize="11"
                           Margin="0,8,0,0"
                           Visibility="Collapsed"
                           TextWrapping="Wrap"/>
            </StackPanel>
        </Viewbox>
    </Grid>
</external:ViewItemWpfUserControl>
