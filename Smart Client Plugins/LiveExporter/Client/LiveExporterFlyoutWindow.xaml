<Window x:Class="LiveExporter.Client.LiveExporterFlyoutWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Live Exporter"
        WindowStyle="ToolWindow"
        ResizeMode="CanResize"
        Background="#FF1B1B1B"
        Topmost="True"
        ShowInTaskbar="False"
        FontFamily="Segoe UI"
        Width="780" Height="620"
        MinWidth="540" MinHeight="420">

    <Window.Resources>
        <SolidColorBrush x:Key="ScBg"        Color="#FF1B1B1B"/>
        <SolidColorBrush x:Key="ScSurface"   Color="#FF2A2A2A"/>
        <SolidColorBrush x:Key="ScSurfaceHi" Color="#FF353535"/>
        <SolidColorBrush x:Key="ScBorder"    Color="#FF3C3C3C"/>
        <SolidColorBrush x:Key="ScText"      Color="#FFE6E6E6"/>
        <SolidColorBrush x:Key="ScSubtle"    Color="#FF8C8C8C"/>
        <SolidColorBrush x:Key="ScAccent"    Color="#FF2A8FE0"/>
        <SolidColorBrush x:Key="ScAccentHi"  Color="#FF3FA0EF"/>
        <SolidColorBrush x:Key="ScGood"      Color="#FF38B660"/>
        <SolidColorBrush x:Key="ScBad"       Color="#FFE05A4F"/>

        <Style x:Key="ChipButton" TargetType="Button">
            <Setter Property="Background"      Value="{StaticResource ScSurface}"/>
            <Setter Property="Foreground"      Value="{StaticResource ScText}"/>
            <Setter Property="BorderBrush"     Value="{StaticResource ScBorder}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontSize"        Value="12"/>
            <Setter Property="Padding"         Value="10,6"/>
            <Setter Property="Margin"          Value="3"/>
            <Setter Property="MinWidth"        Value="90"/>
            <Setter Property="MinHeight"       Value="32"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                Padding="{TemplateBinding Padding}"
                                SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="{StaticResource ScSurfaceHi}"/>
                                <Setter TargetName="bd" Property="BorderBrush" Value="{StaticResource ScAccent}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="{StaticResource ScAccent}"/>
                                <Setter TargetName="bd" Property="BorderBrush" Value="{StaticResource ScAccent}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="bd" Property="Opacity" Value="0.5"/>
                                <Setter Property="Cursor" Value="Arrow"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PrimaryButton" TargetType="Button" BasedOn="{StaticResource ChipButton}">
            <Setter Property="Background"  Value="{StaticResource ScAccent}"/>
            <Setter Property="BorderBrush" Value="{StaticResource ScAccent}"/>
            <Setter Property="Foreground"  Value="White"/>
            <Setter Property="FontWeight"  Value="SemiBold"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                Padding="{TemplateBinding Padding}"
                                SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="{StaticResource ScAccentHi}"/>
                                <Setter TargetName="bd" Property="BorderBrush" Value="{StaticResource ScAccentHi}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="bd" Property="Opacity" Value="0.45"/>
                                <Setter Property="Cursor" Value="Arrow"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="LabelText" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource ScSubtle}"/>
            <Setter Property="FontSize"   Value="11"/>
        </Style>
        <Style x:Key="ValueText" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource ScText}"/>
            <Setter Property="FontSize"   Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>
    </Window.Resources>

    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header: camera name + hint -->
        <DockPanel Grid.Row="0" Margin="0,0,0,8">
            <TextBlock x:Name="cameraNameText"
                       Text="(no camera selected)"
                       Foreground="{StaticResource ScText}"
                       FontSize="14"
                       FontWeight="SemiBold"
                       TextTrimming="CharacterEllipsis"
                       VerticalAlignment="Center"
                       DockPanel.Dock="Left"/>
            <TextBlock Text="Click a tile, Map, or Smart Map item to load it."
                       Style="{StaticResource LabelText}"
                       VerticalAlignment="Center"
                       HorizontalAlignment="Right"/>
        </DockPanel>

        <!-- Video host -->
        <Border Grid.Row="1"
                Background="Black"
                BorderBrush="{StaticResource ScBorder}"
                BorderThickness="1"
                MinHeight="220">
            <Grid x:Name="videoHost"/>
        </Border>

        <!-- Scrubber host -->
        <Border Grid.Row="2"
                Background="#FF161616"
                BorderBrush="{StaticResource ScBorder}"
                BorderThickness="1,0,1,1"
                MinHeight="56">
            <Grid x:Name="scrubberHost"/>
        </Border>

        <!-- Captured times -->
        <Grid Grid.Row="3" Margin="0,10,0,4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0" Orientation="Horizontal">
                <TextBlock Text="START" Style="{StaticResource LabelText}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                <TextBlock x:Name="startTimeText"
                           Text="(not set)"
                           Style="{StaticResource ValueText}"
                           VerticalAlignment="Center"/>
            </StackPanel>
            <StackPanel Grid.Column="1" Orientation="Horizontal">
                <TextBlock Text="END" Style="{StaticResource LabelText}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                <TextBlock x:Name="endTimeText"
                           Text="(not set)"
                           Style="{StaticResource ValueText}"
                           VerticalAlignment="Center"/>
            </StackPanel>
        </Grid>

        <!-- Chip buttons row -->
        <Grid Grid.Row="4" Margin="0,4,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Button Grid.Column="0"
                    x:Name="setStartButton"
                    Content="Set start"
                    Style="{StaticResource ChipButton}"
                    Margin="0,0,3,0"
                    Click="OnSetStartClick"
                    ToolTip="Snapshot the current scrubber time as the export start."/>
            <Button Grid.Column="1"
                    x:Name="setEndButton"
                    Content="Set end"
                    Style="{StaticResource ChipButton}"
                    Margin="3,0,3,0"
                    Click="OnSetEndClick"
                    ToolTip="Snapshot the current scrubber time as the export end."/>
            <Button Grid.Column="2"
                    x:Name="addButton"
                    Content="Add to Export"
                    Style="{StaticResource PrimaryButton}"
                    Margin="3,0,3,0"
                    Click="OnAddClick"
                    ToolTip="Send (camera, start to end) to the Smart Client export list."/>
            <Button Grid.Column="3"
                    x:Name="resetButton"
                    Content="Reset"
                    Style="{StaticResource ChipButton}"
                    Margin="3,0,0,0"
                    Click="OnResetClick"
                    ToolTip="Clear the captured start and end."/>
        </Grid>

        <!-- Status -->
        <TextBlock Grid.Row="5"
                   x:Name="statusText"
                   Text=""
                   Style="{StaticResource LabelText}"
                   Margin="0,8,0,0"
                   TextWrapping="Wrap"/>
    </Grid>
</Window>
