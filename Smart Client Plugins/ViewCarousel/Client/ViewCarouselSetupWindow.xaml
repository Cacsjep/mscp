<Window x:Class="ViewCarousel.Client.ViewCarouselSetupWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Set up view carousel" Width="900" Height="572"
        WindowStartupLocation="CenterOwner"
        Background="#FF14181B" ResizeMode="CanResizeWithGrip">
    <Window.Resources>
        <Style TargetType="Button">
            <Setter Property="Background" Value="#FF3A3F44"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#FF555555"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="14,6"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="MinHeight" Value="28"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="3" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#FF4A5058"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#FF2A2F34"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Background" Value="#FF2A2D30"/>
                                <Setter Property="Foreground" Value="#FF666666"/>
                                <Setter Property="BorderBrush" Value="#FF3A3A3A"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="TreeViewItem">
            <Setter Property="Foreground" Value="#FFE6EDF3"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Padding" Value="2,2"/>
            <Setter Property="IsExpanded" Value="True"/>
            <Style.Resources>
                <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}" Color="#FF2A4A6B"/>
                <SolidColorBrush x:Key="{x:Static SystemColors.HighlightTextBrushKey}" Color="White"/>
                <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightBrushKey}" Color="#FF2A3A4B"/>
                <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightTextBrushKey}" Color="#FFE6EDF3"/>
            </Style.Resources>
        </Style>
    </Window.Resources>

    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Main two-column area -->
        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Left: Available views -->
            <DockPanel Grid.Column="0">
                <TextBlock DockPanel.Dock="Top" Text="Views" Foreground="White"
                           FontSize="13" FontWeight="SemiBold" Margin="0,0,0,6"/>
                <Border BorderBrush="#FF30363D" BorderThickness="1" CornerRadius="4" Background="#FF0D1117">
                    <TreeView x:Name="viewTree" Background="Transparent" BorderThickness="0"
                              SelectedItemChanged="ViewTree_SelectedItemChanged"/>
                </Border>
            </DockPanel>

            <!-- Middle: Add/Remove buttons -->
            <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="10,20,10,0">
                <Button x:Name="btnAdd" Content="Add"
                        Click="OnAddClick" IsEnabled="False" Margin="0,0,0,6"/>
                <Button x:Name="btnRemove" Content="Remove"
                        Click="OnRemoveClick" IsEnabled="False" Margin="0,0,0,6"/>
                <Button Content="Remove all"
                        Click="OnRemoveAllClick"/>
            </StackPanel>

            <!-- Right: Selected views -->
            <DockPanel Grid.Column="2">
                <TextBlock DockPanel.Dock="Top" Text="Selected views" Foreground="White"
                           FontSize="13" FontWeight="SemiBold" Margin="0,0,0,6"/>
                <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,6,0,0">
                    <Button x:Name="btnMoveUp" Content="Move up"
                            Click="OnMoveUpClick" IsEnabled="False" Margin="0,0,6,0"/>
                    <Button x:Name="btnMoveDown" Content="Move down"
                            Click="OnMoveDownClick" IsEnabled="False"/>
                </StackPanel>
                <Border BorderBrush="#FF30363D" BorderThickness="1" CornerRadius="4" Background="#FF0D1117">
                    <ListView x:Name="selectedList" Background="Transparent" BorderThickness="0"
                              Foreground="#FFE6EDF3" FontSize="13"
                              SelectionChanged="SelectedList_SelectionChanged">
                        <ListView.View>
                            <GridView>
                                <GridViewColumn Header="Name" Width="240"
                                                DisplayMemberBinding="{Binding ViewName}"/>
                                <GridViewColumn Header="Time" Width="120"
                                                DisplayMemberBinding="{Binding TimeDisplay}"/>
                            </GridView>
                        </ListView.View>
                    </ListView>
                </Border>
            </DockPanel>
        </Grid>

        <!-- Bottom settings row -->
        <Grid Grid.Row="1" Margin="0,12,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Default time -->
            <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Text="Default carousel time" Foreground="#FFB0B0B0" FontSize="12"
                           VerticalAlignment="Center" Margin="0,0,8,0"/>
                <TextBox x:Name="txtDefaultTime" Width="50" Background="#FF0D1117" Foreground="White"
                         BorderBrush="#FF30363D" Padding="4,2" FontSize="12" MaxLength="3"
                         VerticalContentAlignment="Center" TextChanged="OnDefaultTimeChanged"
                         LostFocus="OnDefaultTimeLostFocus" PreviewTextInput="OnTimePreviewTextInput"/>
                <TextBlock Text="seconds" Foreground="#FFB0B0B0" FontSize="12"
                           VerticalAlignment="Center" Margin="6,0,0,0"/>
            </StackPanel>

            <!-- Per-view time -->
            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                <TextBlock Text="Time for selected view" Foreground="#FFB0B0B0" FontSize="12"
                           Margin="0,0,0,4"/>
                <StackPanel Orientation="Horizontal">
                    <RadioButton x:Name="rbDefault" Content="Default" Foreground="#FFE6EDF3" FontSize="12"
                                 IsChecked="True" Checked="OnTimeRadioChanged" Margin="0,0,16,0"/>
                    <RadioButton x:Name="rbCustom" Foreground="#FFE6EDF3" FontSize="12"
                                 Checked="OnTimeRadioChanged"/>
                    <TextBox x:Name="txtCustomTime" Width="50" Background="#FF0D1117" Foreground="White"
                             BorderBrush="#FF30363D" Padding="4,2" FontSize="12" MaxLength="3"
                             IsEnabled="False" VerticalContentAlignment="Center"
                             LostFocus="OnCustomTimeLostFocus" PreviewTextInput="OnTimePreviewTextInput"/>
                    <TextBlock Text="seconds" Foreground="#FFB0B0B0" FontSize="12"
                               VerticalAlignment="Center" Margin="6,0,0,0"/>
                </StackPanel>
            </StackPanel>
        </Grid>

        <!-- OK / Cancel -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="Ok" Click="OnOkClick" MinWidth="80" MinHeight="32"
                    Background="#FF238636" Foreground="White" BorderBrush="#FF2EA043"
                    Padding="18,6" Cursor="Hand" FontSize="12" Margin="0,0,8,0"/>
            <Button Content="Cancel" Click="OnCancelClick" MinWidth="80" MinHeight="32"
                    Padding="18,6" FontSize="12"/>
        </StackPanel>
    </Grid>
</Window>
