<Window
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    x:Class="TodoList.Client.TodoListTextInputDialog"
    Title="Input"
    Width="420" Height="180"
    MinWidth="320" MinHeight="160"
    WindowStartupLocation="CenterOwner"
    ResizeMode="NoResize"
    Background="#FF1E1E1E"
    Foreground="#FFD0D0D0"
    FontSize="13"
    ShowInTaskbar="False">
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/TodoList;component/Client/Themes/Buttons.xaml"/>
            </ResourceDictionary.MergedDictionaries>
            <Style TargetType="TextBox" BasedOn="{StaticResource DarkTextBox}"/>
        </ResourceDictionary>
    </Window.Resources>
    <Grid Margin="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   x:Name="promptText"
                   Text="Enter value:"
                   Margin="0,0,0,8"
                   Foreground="#FFD0D0D0"/>

        <TextBox Grid.Row="1"
                 x:Name="inputBox"
                 VerticalAlignment="Top"/>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="Cancel"
                    Style="{StaticResource SmallButton}"
                    Click="OnCancelClick"
                    Padding="18,6"
                    Margin="0,0,6,0"/>
            <Button Content="OK"
                    Style="{StaticResource PrimaryButton}"
                    Click="OnOkClick"
                    Padding="18,6"
                    IsDefault="True"/>
        </StackPanel>
    </Grid>
</Window>
