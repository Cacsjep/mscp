<Window
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    x:Class="TodoList.Client.TodoListTemplatePickerWindow"
    Title="Pick template"
    Width="380" Height="420"
    MinWidth="320" MinHeight="300"
    WindowStartupLocation="CenterOwner"
    Background="#FF1E1E1E"
    Foreground="#FFD0D0D0"
    FontSize="13"
    ShowInTaskbar="False">
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/TodoList;component/Client/Themes/Buttons.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   Text="Select a template to start a shift:"
                   Margin="0,0,0,8"
                   Foreground="#FFD0D0D0"/>

        <ListBox x:Name="templateList"
                 Grid.Row="1"
                 Background="#FF2A2A2A"
                 Foreground="#FFE0E0E0"
                 BorderBrush="#FF444444"
                 BorderThickness="1"
                 SelectionMode="Single"
                 MouseDoubleClick="OnListDoubleClick">
            <ListBox.ItemContainerStyle>
                <Style TargetType="ListBoxItem">
                    <Setter Property="Padding" Value="8,4"/>
                    <Setter Property="Background" Value="#FF2A2A2A"/>
                    <Setter Property="Foreground" Value="#FFE0E0E0"/>
                </Style>
            </ListBox.ItemContainerStyle>
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <StackPanel>
                        <TextBlock Text="{Binding Name}" FontWeight="SemiBold" Foreground="#FFE0E0E0"/>
                        <TextBlock Text="{Binding TaskSummary}" Foreground="#FF888888" FontSize="11"/>
                    </StackPanel>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
            <Button Content="Cancel"
                    Style="{StaticResource SmallButton}"
                    Click="OnCancelClick"
                    Padding="18,6"
                    Margin="0,0,6,0"/>
            <Button Content="Start"
                    Style="{StaticResource PrimaryButton}"
                    Click="OnStartClick"
                    Padding="18,6"
                    IsDefault="True"/>
        </StackPanel>
    </Grid>
</Window>
