<Window x:Class="WebView.Client.AddUserEntryWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Add Website"
        Width="420" SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#FF1C2326">

    <Window.Resources>
        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#FFD0D0D0"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
        <Style x:Key="FieldInput" TargetType="TextBox">
            <Setter Property="Background" Value="#FF2A2A2A"/>
            <Setter Property="Foreground" Value="#FFE6EDF3"/>
            <Setter Property="BorderBrush" Value="#FF444444"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CaretBrush" Value="#FFE6EDF3"/>
            <Setter Property="Padding" Value="6,5"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Height" Value="28"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
        <Style x:Key="DialogButton" TargetType="Button">
            <Setter Property="Padding" Value="16,5"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="3"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Opacity" Value="0.85"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <StackPanel Margin="16,14">
        <!-- Name -->
        <Grid Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="75"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Style="{StaticResource FieldLabel}">
                <Run Text="Name"/><Run Text=" *" Foreground="#FFFF6B6B"/>
            </TextBlock>
            <TextBox x:Name="nameBox" Grid.Column="1" Style="{StaticResource FieldInput}"/>
        </Grid>

        <!-- URL -->
        <Grid Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="75"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Style="{StaticResource FieldLabel}">
                <Run Text="URL"/><Run Text=" *" Foreground="#FFFF6B6B"/>
            </TextBlock>
            <TextBox x:Name="urlBox" Grid.Column="1" Style="{StaticResource FieldInput}" Text="https://"/>
        </Grid>

        <!-- Username -->
        <Grid Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="75"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Text="User" Style="{StaticResource FieldLabel}"/>
            <TextBox x:Name="userBox" Grid.Column="1" Style="{StaticResource FieldInput}"/>
        </Grid>

        <!-- Password -->
        <Grid Margin="0,0,0,4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="75"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Text="Password" Style="{StaticResource FieldLabel}"/>
            <PasswordBox x:Name="passBox" Grid.Column="1"
                         Background="#FF2A2A2A" Foreground="#FFE6EDF3"
                         BorderBrush="#FF444444" BorderThickness="1"
                         Padding="6,5" FontSize="12"
                         Height="28"
                         VerticalContentAlignment="Center"/>
        </Grid>

        <!-- Error message -->
        <TextBlock x:Name="errorText"
                   Foreground="#FFFF6B6B" FontSize="11" Margin="75,2,0,0"
                   TextWrapping="Wrap" Visibility="Collapsed"/>

        <!-- Buttons -->
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="Cancel"
                    Style="{StaticResource DialogButton}"
                    Background="#FF3A3F44" Foreground="#FFE6EDF3" BorderBrush="#FF555555"
                    Click="OnCancel" Margin="0,0,8,0"/>
            <Button Content="Add"
                    Style="{StaticResource DialogButton}"
                    Background="#FF238636" Foreground="White" BorderBrush="#FF2EA043"
                    FontWeight="SemiBold" Click="OnAdd"/>
        </StackPanel>
    </StackPanel>
</Window>
