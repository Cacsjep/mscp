<external:ViewItemWpfUserControl
    xmlns:external="clr-namespace:VideoOS.Platform.Client;assembly=VideoOS.Platform"
    x:Class="SystemStatus.Client.CameraUserStatusViewItemWpfUserControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    mc:Ignorable="d"
    d:DesignHeight="500" d:DesignWidth="360">

    <external:ViewItemWpfUserControl.Resources>
        <SolidColorBrush x:Key="Bg"     Color="#FF1B1B1B"/>
        <SolidColorBrush x:Key="Text"   Color="#FFE6E6E6"/>
        <SolidColorBrush x:Key="Subtle" Color="#FF9A9A9A"/>
        <SolidColorBrush x:Key="Border" Color="#FF3C3C3C"/>
        <SolidColorBrush x:Key="Accent" Color="#FF2A8FE0"/>

        <Style x:Key="SectionLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource Text}"/>
            <Setter Property="FontSize"   Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin"     Value="2,0,0,6"/>
        </Style>

        <!-- One "Name ........ X / Y Devices" row; the online count X is accented blue. -->
        <DataTemplate x:Key="FolderRow">
            <DockPanel Margin="0,5">
                <TextBlock DockPanel.Dock="Right" Margin="8,0,0,0" VerticalAlignment="Center" FontSize="12"><Run Text="{Binding Online, Mode=OneWay}" Foreground="{StaticResource Accent}" FontWeight="SemiBold"/><Run Text=" / " Foreground="{StaticResource Subtle}"/><Run Text="{Binding Total, Mode=OneWay}" Foreground="{StaticResource Subtle}"/><Run Text=" Devices" Foreground="{StaticResource Subtle}"/></TextBlock>
                <TextBlock Text="{Binding Folder}" Foreground="{StaticResource Text}" FontSize="13"
                           TextTrimming="CharacterEllipsis" VerticalAlignment="Center"/>
            </DockPanel>
        </DataTemplate>

        <DataTemplate x:Key="RoleRow">
            <DockPanel Margin="0,5">
                <TextBlock DockPanel.Dock="Right" Margin="8,0,0,0" VerticalAlignment="Center" FontSize="12"><Run Text="{Binding LoggedIn, Mode=OneWay}" Foreground="{StaticResource Accent}" FontWeight="SemiBold"/><Run Text=" / " Foreground="{StaticResource Subtle}"/><Run Text="{Binding Total, Mode=OneWay}" Foreground="{StaticResource Subtle}"/><Run Text=" Users" Foreground="{StaticResource Subtle}"/></TextBlock>
                <TextBlock Text="{Binding Role}" Foreground="{StaticResource Text}" FontSize="13"
                           TextTrimming="CharacterEllipsis" VerticalAlignment="Center"/>
            </DockPanel>
        </DataTemplate>
    </external:ViewItemWpfUserControl.Resources>

    <Border Background="{StaticResource Bg}">
        <Grid Margin="14">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="12"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Folders : Cameras -->
            <Grid Grid.Row="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <TextBlock Grid.Row="0" Text="CAMERA FOLDERS" Style="{StaticResource SectionLabel}"/>
                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                    <ItemsControl x:Name="folderList">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <ContentPresenter Content="{Binding}" ContentTemplate="{StaticResource FolderRow}"/>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>

            <!-- Roles : Users -->
            <Grid Grid.Row="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <TextBlock Grid.Row="0" Text="ROLES" Style="{StaticResource SectionLabel}"/>
                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                    <ItemsControl x:Name="roleList">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <ContentPresenter Content="{Binding}" ContentTemplate="{StaticResource RoleRow}"/>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>

            <!-- Empty / loading overlay -->
            <TextBlock x:Name="emptyLabel" Grid.RowSpan="3" Text="Loading…" Foreground="{StaticResource Subtle}"
                       FontSize="13" HorizontalAlignment="Center" VerticalAlignment="Center" Visibility="Collapsed"/>
        </Grid>
    </Border>
</external:ViewItemWpfUserControl>
