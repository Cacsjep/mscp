<Window x:Class="SystemStatus.Client.StatusFlyoutWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="System Status"
        WindowStyle="None"
        AllowsTransparency="True"
        ShowInTaskbar="True"
        ResizeMode="NoResize"
        SizeToContent="Height"
        Width="580"
        Background="Transparent"
        Topmost="True"
        FontFamily="Segoe UI"
        WindowStartupLocation="Manual"
        MouseLeftButtonDown="OnHeaderMouseDown">

    <Window.Resources>
        <!-- Smart Client palette -->
        <SolidColorBrush x:Key="ScBg"        Color="#FF1B1B1B"/>
        <SolidColorBrush x:Key="ScSurface"   Color="#FF2A2A2A"/>
        <SolidColorBrush x:Key="ScSurfaceHi" Color="#FF353535"/>
        <SolidColorBrush x:Key="ScBorder"    Color="#FF3C3C3C"/>
        <SolidColorBrush x:Key="ScText"      Color="#FFE6E6E6"/>
        <SolidColorBrush x:Key="ScSubtle"    Color="#FF8C8C8C"/>
        <SolidColorBrush x:Key="ScAccent"    Color="#FF2A8FE0"/>
        <SolidColorBrush x:Key="DotOnline"   Color="#FF3FB950"/>
        <SolidColorBrush x:Key="DotOffline"  Color="#FFE04545"/>

        <!-- Small filter button (text-like, button-ish on hover) -->
        <Style x:Key="FilterButton" TargetType="Button">
            <Setter Property="Background"      Value="Transparent"/>
            <Setter Property="Foreground"      Value="{StaticResource ScSubtle}"/>
            <Setter Property="BorderBrush"     Value="{StaticResource ScBorder}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontSize"        Value="11"/>
            <Setter Property="Padding"         Value="8,3"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="3" Padding="{TemplateBinding Padding}" SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="{StaticResource ScSurfaceHi}"/>
                                <Setter TargetName="bd" Property="BorderBrush" Value="{StaticResource ScAccent}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="HeaderText" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource ScText}"/>
            <Setter Property="FontSize"   Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>
        <Style x:Key="SectionLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource ScSubtle}"/>
            <Setter Property="FontSize"   Value="11"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin"     Value="0,0,0,4"/>
        </Style>
        <Style x:Key="RowText" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource ScText}"/>
            <Setter Property="FontSize"   Value="12"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
        </Style>
        <Style x:Key="RowSubText" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource ScSubtle}"/>
            <Setter Property="FontSize"   Value="11"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <!-- Close button (header X) -->
        <Style x:Key="CloseButton" TargetType="Button">
            <Setter Property="Background"  Value="Transparent"/>
            <Setter Property="Foreground"  Value="{StaticResource ScSubtle}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize"    Value="14"/>
            <Setter Property="Cursor"      Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{TemplateBinding Background}" SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="{StaticResource ScSurfaceHi}"/>
                                <Setter Property="Foreground" Value="{StaticResource ScText}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Virtualizing list (handles ~1000 cameras without building 1000 visuals).
             Rows look like plain text; on hover they get a subtle button-like background. -->
        <Style x:Key="StatusListItem" TargetType="ListBoxItem">
            <Setter Property="Foreground" Value="{StaticResource ScText}"/>
            <Setter Property="Padding"    Value="6,4"/>
            <Setter Property="Margin"     Value="0,1"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="bd" Background="Transparent" CornerRadius="3"
                                Padding="{TemplateBinding Padding}" SnapsToDevicePixels="True">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="{StaticResource ScSurfaceHi}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="StatusList" TargetType="ListBox">
            <Setter Property="Background"      Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding"         Value="0"/>
            <Setter Property="ItemContainerStyle" Value="{StaticResource StatusListItem}"/>
            <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Auto"/>
            <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled"/>
            <Setter Property="VirtualizingStackPanel.IsVirtualizing" Value="True"/>
            <Setter Property="VirtualizingStackPanel.VirtualizationMode" Value="Recycling"/>
        </Style>

        <!-- Camera row -->
        <DataTemplate x:Key="CameraTemplate">
            <Grid Margin="0,3">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Ellipse x:Name="dot" Grid.Column="0" Width="9" Height="9"
                         HorizontalAlignment="Left" VerticalAlignment="Center"
                         Fill="{StaticResource DotOffline}"/>
                <TextBlock Grid.Column="1" Text="{Binding Name}" Style="{StaticResource RowText}"/>
                <TextBlock x:Name="status" Grid.Column="2" Text="{Binding StatusText}"
                           Style="{StaticResource RowSubText}" Margin="8,0,0,0"/>
            </Grid>
            <DataTemplate.Triggers>
                <DataTrigger Binding="{Binding Online}" Value="True">
                    <Setter TargetName="dot" Property="Fill" Value="{StaticResource DotOnline}"/>
                    <Setter TargetName="status" Property="Foreground" Value="{StaticResource DotOnline}"/>
                </DataTrigger>
            </DataTemplate.Triggers>
        </DataTemplate>

        <!-- User row: user name + client type (Smart Client / Management Client / ...) -->
        <DataTemplate x:Key="UserTemplate">
            <Grid Margin="0,3">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="{Binding DisplayName}" Style="{StaticResource RowText}"/>
                <TextBlock Grid.Column="1" Text="{Binding Secondary}" Style="{StaticResource RowSubText}" Margin="8,0,0,0"/>
            </Grid>
        </DataTemplate>
    </Window.Resources>

    <Border Background="{StaticResource ScBg}"
            BorderBrush="{StaticResource ScBorder}"
            BorderThickness="1"
            Padding="16">
        <Border.Effect>
            <DropShadowEffect BlurRadius="24" ShadowDepth="4" Opacity="0.6" Color="Black"/>
        </Border.Effect>
        <StackPanel>

            <!-- Header (drag handle) -->
            <Border x:Name="headerBar" Background="Transparent" Margin="0,0,0,12" Cursor="SizeAll">
                <DockPanel>
                    <TextBlock Text="System Status" Style="{StaticResource HeaderText}"
                               DockPanel.Dock="Left" VerticalAlignment="Center"/>
                    <Button x:Name="closeButton" Content="&#x2715;" Width="28" Height="28" Padding="0"
                            DockPanel.Dock="Right" HorizontalAlignment="Right"
                            Style="{StaticResource CloseButton}" Click="OnCloseClick" ToolTip="Close (Esc)"/>
                </DockPanel>
            </Border>

            <!-- Cameras -->
            <DockPanel Margin="0,0,0,4">
                <Button x:Name="offlineToggle" DockPanel.Dock="Right" Content="Show only offline"
                        Style="{StaticResource FilterButton}" Click="OnToggleOffline"/>
                <TextBlock x:Name="camerasLabel" Text="CAMERAS" Style="{StaticResource SectionLabel}"
                           VerticalAlignment="Center" Margin="0"/>
            </DockPanel>
            <ListBox x:Name="camerasList" Style="{StaticResource StatusList}"
                     ItemTemplate="{StaticResource CameraTemplate}"
                     MaxHeight="260" Margin="0,0,0,12"/>

            <!-- Users -->
            <TextBlock x:Name="usersLabel" Text="USERS" Style="{StaticResource SectionLabel}"/>
            <ListBox x:Name="usersList" Style="{StaticResource StatusList}"
                     ItemTemplate="{StaticResource UserTemplate}"
                     MaxHeight="200"/>

        </StackPanel>
    </Border>
</Window>
