<Window x:Class="SystemStatus.Client.SystemHealthWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:SystemStatus.Client"
        xmlns:fa5="http://schemas.fontawesome.com/icons/"
        Title="System Health"
        WindowStyle="None"
        AllowsTransparency="True"
        ShowInTaskbar="True"
        Background="Transparent"
        FontFamily="Segoe UI"
        WindowStartupLocation="CenterScreen"
        MinWidth="820" MinHeight="520"
        MouseLeftButtonDown="OnHeaderMouseDown">

    <Window.Resources>
        <SolidColorBrush x:Key="ScBg"        Color="#FF1B1B1B"/>
        <SolidColorBrush x:Key="ScSurface"   Color="#FF2A2A2A"/>
        <SolidColorBrush x:Key="ScSurfaceHi" Color="#FF353535"/>
        <SolidColorBrush x:Key="ScBorder"    Color="#FF3C3C3C"/>
        <SolidColorBrush x:Key="ScText"      Color="#FFE6E6E6"/>
        <SolidColorBrush x:Key="ScSubtle"    Color="#FF8C8C8C"/>
        <SolidColorBrush x:Key="ScAccent"    Color="#FF2A8FE0"/>
        <SolidColorBrush x:Key="DotOnline"   Color="#FF3FB950"/>
        <SolidColorBrush x:Key="DotOffline"  Color="#FFE04545"/>
        <SolidColorBrush x:Key="DotWarn"     Color="#FFE0A23F"/>

        <local:BoolToBrushConverter x:Key="OnlineDot"
            TrueBrush="{StaticResource DotOnline}" FalseBrush="{StaticResource DotOffline}"/>
        <local:BoolToBrushConverter x:Key="OkDot"
            TrueBrush="{StaticResource DotOnline}" FalseBrush="{StaticResource DotOffline}"/>
        <local:BoolToVisibilityConverter x:Key="NotToVis" Invert="True"/>
        <local:PercentToBrushConverter x:Key="PctBrush"/>

        <!-- Flat storage-usage bar (colored by PercentToBrushConverter). -->
        <Style x:Key="UsageBar" TargetType="ProgressBar">
            <Setter Property="Minimum" Value="0"/>
            <Setter Property="Maximum" Value="100"/>
            <Setter Property="Height" Value="14"/>
            <Setter Property="Background" Value="#33000000"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ProgressBar">
                        <Border Background="{TemplateBinding Background}" CornerRadius="3" SnapsToDevicePixels="True">
                            <Grid x:Name="PART_Track">
                                <Border x:Name="PART_Indicator" HorizontalAlignment="Left"
                                        Background="{TemplateBinding Foreground}" CornerRadius="3"/>
                            </Grid>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="HeaderText" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource ScText}"/>
            <Setter Property="FontSize"   Value="15"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>
        <Style x:Key="SectionLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource ScText}"/>
            <Setter Property="FontSize"   Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
        <Style x:Key="SummaryLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource ScSubtle}"/>
            <Setter Property="FontSize"   Value="11"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin"     Value="10,0,0,0"/>
        </Style>

        <Style x:Key="FilterButton" TargetType="Button">
            <Setter Property="Background"      Value="Transparent"/>
            <Setter Property="Foreground"      Value="{StaticResource ScSubtle}"/>
            <Setter Property="BorderBrush"     Value="{StaticResource ScBorder}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontSize"        Value="11"/>
            <Setter Property="Padding"         Value="10,3"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="3" Padding="{TemplateBinding Padding}" SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="{StaticResource ScSurfaceHi}"/>
                                <Setter TargetName="bd" Property="BorderBrush" Value="{StaticResource ScAccent}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="CloseButton" TargetType="Button">
            <Setter Property="Background"  Value="Transparent"/>
            <Setter Property="Foreground"  Value="{StaticResource ScSubtle}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize"    Value="14"/>
            <Setter Property="Cursor"      Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{TemplateBinding Background}" SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="{StaticResource ScSurfaceHi}"/>
                                <Setter Property="Foreground" Value="{StaticResource ScText}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="GridHeader" TargetType="{x:Type DataGridColumnHeader}">
            <Setter Property="Background"  Value="{StaticResource ScSurface}"/>
            <Setter Property="Foreground"  Value="{StaticResource ScSubtle}"/>
            <Setter Property="FontSize"    Value="11"/>
            <Setter Property="FontWeight"  Value="SemiBold"/>
            <Setter Property="Padding"     Value="8,6"/>
            <Setter Property="BorderBrush" Value="{StaticResource ScBorder}"/>
            <Setter Property="BorderThickness" Value="0,0,1,1"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type DataGridColumnHeader}">
                        <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}" Padding="{TemplateBinding Padding}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <ContentPresenter VerticalAlignment="Center"
                                                  HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"/>
                                <Path x:Name="SortArrow" Grid.Column="1" Width="8" Height="5" Margin="6,1,0,0"
                                      Stretch="Fill" Fill="{StaticResource ScText}" Visibility="Collapsed"
                                      VerticalAlignment="Center" RenderTransformOrigin="0.5,0.5"
                                      Data="M0,0 L8,0 L4,5 Z"/>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="SortDirection" Value="Descending">
                                <Setter TargetName="SortArrow" Property="Visibility" Value="Visible"/>
                            </Trigger>
                            <Trigger Property="SortDirection" Value="Ascending">
                                <Setter TargetName="SortArrow" Property="Visibility" Value="Visible"/>
                                <Setter TargetName="SortArrow" Property="RenderTransform">
                                    <Setter.Value><RotateTransform Angle="180"/></Setter.Value>
                                </Setter>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="GridRow" TargetType="{x:Type DataGridRow}">
            <Setter Property="Background"  Value="Transparent"/>
            <Setter Property="Foreground"  Value="{StaticResource ScText}"/>
            <Style.Triggers>
                <Trigger Property="AlternationIndex" Value="1">
                    <Setter Property="Background" Value="#0DFFFFFF"/>
                </Trigger>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{StaticResource ScSurfaceHi}"/>
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#332A8FE0"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="GridCell" TargetType="{x:Type DataGridCell}">
            <Setter Property="Background"  Value="Transparent"/>
            <Setter Property="Foreground"  Value="{StaticResource ScText}"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="FontSize"    Value="12"/>
            <Setter Property="Padding"     Value="8,5"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type DataGridCell}">
                        <Border Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}"
                                SnapsToDevicePixels="True">
                            <ContentPresenter VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Shared DataGrid look -->
        <Style x:Key="HealthGrid" TargetType="DataGrid">
            <Setter Property="AutoGenerateColumns" Value="False"/>
            <Setter Property="IsReadOnly" Value="True"/>
            <Setter Property="HeadersVisibility" Value="Column"/>
            <Setter Property="CanUserAddRows" Value="False"/>
            <Setter Property="CanUserResizeRows" Value="False"/>
            <Setter Property="CanUserSortColumns" Value="True"/>
            <Setter Property="SelectionMode" Value="Single"/>
            <Setter Property="SelectionUnit" Value="FullRow"/>
            <Setter Property="GridLinesVisibility" Value="Horizontal"/>
            <Setter Property="HorizontalGridLinesBrush" Value="{StaticResource ScBorder}"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="RowBackground" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="{StaticResource ScBorder}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Foreground" Value="{StaticResource ScText}"/>
            <Setter Property="AlternationCount" Value="2"/>
            <Setter Property="EnableRowVirtualization" Value="True"/>
            <Setter Property="ColumnHeaderStyle" Value="{StaticResource GridHeader}"/>
            <Setter Property="RowStyle" Value="{StaticResource GridRow}"/>
            <Setter Property="CellStyle" Value="{StaticResource GridCell}"/>
            <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Auto"/>
            <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Auto"/>
        </Style>

        <!-- Group header (used when cameras are grouped by recorder / streams by camera). -->
        <Style x:Key="GroupContainer" TargetType="{x:Type GroupItem}">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type GroupItem}">
                        <Expander IsExpanded="True" Background="Transparent" BorderThickness="0"
                                  Foreground="{StaticResource ScText}" Margin="0,2,0,0">
                            <Expander.Header>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="{Binding Name}" FontWeight="SemiBold"
                                               Foreground="{StaticResource ScAccent}" FontSize="12"/>
                                    <TextBlock Text="{Binding ItemCount}" Foreground="{StaticResource ScSubtle}"
                                               FontSize="11" Margin="8,0,2,0"/>
                                    <TextBlock Text="items" Foreground="{StaticResource ScSubtle}" FontSize="11"/>
                                </StackPanel>
                            </Expander.Header>
                            <ItemsPresenter/>
                        </Expander>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DarkSearch" TargetType="TextBox">
            <Setter Property="Background"  Value="{StaticResource ScSurface}"/>
            <Setter Property="Foreground"  Value="{StaticResource ScText}"/>
            <Setter Property="CaretBrush"  Value="{StaticResource ScText}"/>
            <Setter Property="BorderBrush" Value="{StaticResource ScBorder}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding"     Value="6,3"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="FontSize"    Value="12"/>
        </Style>

        <Style x:Key="VSplitter" TargetType="GridSplitter">
            <Setter Property="Height" Value="6"/>
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Cursor" Value="SizeNS"/>
        </Style>
    </Window.Resources>

    <Border Background="{StaticResource ScBg}" BorderBrush="{StaticResource ScBorder}" BorderThickness="1">
        <Border.Effect>
            <DropShadowEffect BlurRadius="24" ShadowDepth="4" Opacity="0.6" Color="Black"/>
        </Border.Effect>
        <Grid Margin="16">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>            <!-- header -->
                <RowDefinition Height="1.3*" MinHeight="90"/>  <!-- recording servers -->
                <RowDefinition Height="Auto"/>            <!-- splitter -->
                <RowDefinition Height="3*"   MinHeight="140"/> <!-- cameras -->
                <RowDefinition Height="Auto"/>            <!-- splitter -->
                <RowDefinition Height="1*"   MinHeight="70"/>  <!-- users -->
                <RowDefinition Height="Auto"/>            <!-- errors -->
            </Grid.RowDefinitions>

            <!-- Header -->
            <Border x:Name="headerBar" Grid.Row="0" Background="Transparent" Margin="0,0,0,12" Cursor="SizeAll">
                <DockPanel>
                    <TextBlock Text="System Health" Style="{StaticResource HeaderText}"
                               DockPanel.Dock="Left" VerticalAlignment="Center"/>
                    <Button x:Name="closeButton" Content="&#x2715;" Width="28" Height="28" Padding="0"
                            DockPanel.Dock="Right" HorizontalAlignment="Right"
                            Style="{StaticResource CloseButton}" Click="OnCloseClick" ToolTip="Close (Esc)"/>
                    <Button x:Name="refreshButton" DockPanel.Dock="Right" Content="Refresh" Margin="0,0,8,0"
                            Style="{StaticResource FilterButton}" Click="OnRefreshClick"/>
                    <Button x:Name="autoButton" DockPanel.Dock="Right" Margin="0,0,8,0"
                            Style="{StaticResource FilterButton}" Click="OnAutoToggleClick"
                            ToolTip="Toggle live auto-refresh (every 2s)">
                        <StackPanel Orientation="Horizontal">
                            <fa5:ImageAwesome x:Name="autoIcon" Icon="Solid_Sync" Width="10" Height="10"
                                              Foreground="White" Margin="0,0,5,0"/>
                            <TextBlock x:Name="autoText" Text="Auto 2s" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <TextBlock x:Name="overallSummary" Style="{StaticResource SummaryLabel}" Margin="16,0,0,0"
                               TextTrimming="CharacterEllipsis"/>
                </DockPanel>
            </Border>

            <!-- Recording Servers -->
            <Grid Grid.Row="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <DockPanel Grid.Row="0" Margin="0,0,0,4">
                    <TextBlock Text="RECORDING SERVERS" Style="{StaticResource SectionLabel}" DockPanel.Dock="Left"/>
                    <Button DockPanel.Dock="Right" Style="{StaticResource FilterButton}" Click="OnExportServers"
                            ToolTip="Export recording servers to CSV">
                        <fa5:ImageAwesome Icon="Solid_FileCsv" Width="11" Height="11" Foreground="{StaticResource ScSubtle}"/>
                    </Button>
                    <TextBlock x:Name="serversSummary" Style="{StaticResource SummaryLabel}" DockPanel.Dock="Left"/>
                </DockPanel>
                <DataGrid x:Name="serversGrid" Grid.Row="1" Style="{StaticResource HealthGrid}">
                    <DataGrid.Columns>
                        <DataGridTemplateColumn Header="" Width="26" CanUserSort="False">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Ellipse Width="9" Height="9" HorizontalAlignment="Center"
                                             Fill="{Binding RecorderOk, Converter={StaticResource OkDot}}"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTextColumn Header="RECORDER" Binding="{Binding RecorderHost}" Width="180"/>
                        <DataGridTextColumn Header="STATE"    Binding="{Binding State}" Width="Auto"/>
                        <DataGridTextColumn Header="STORAGE"  Binding="{Binding StorageName}" Width="1.2*"/>
                        <DataGridTextColumn Header="PATH"     Binding="{Binding Path}" Width="1.8*"/>
                        <DataGridTemplateColumn Header="STORAGE USAGE" Width="200" SortMemberPath="UsedPercentValue">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Grid Width="184" HorizontalAlignment="Left" ToolTip="{Binding UsageTooltip}">
                                        <ProgressBar Style="{StaticResource UsageBar}" Value="{Binding UsedPercentValue, Mode=OneWay}"
                                                     Foreground="{Binding UsedPercentValue, Converter={StaticResource PctBrush}}"/>
                                        <TextBlock Text="{Binding UsedPercent}" FontSize="10" FontWeight="SemiBold"
                                                   Foreground="White" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                    </Grid>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>

            <GridSplitter Grid.Row="2" Style="{StaticResource VSplitter}"/>

            <!-- Cameras -->
            <Grid Grid.Row="3">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <DockPanel Grid.Row="0" Margin="0,0,0,4" LastChildFill="False">
                    <TextBlock Text="CAMERAS" Style="{StaticResource SectionLabel}" DockPanel.Dock="Left"/>
                    <Border DockPanel.Dock="Left" Width="1" Background="{StaticResource ScBorder}" Margin="12,2,12,2"/>
                    <Button x:Name="modeCameras" DockPanel.Dock="Left" Content="Cameras" Tag="Cameras"
                            Style="{StaticResource FilterButton}" Click="OnViewModeClick"/>
                    <Button x:Name="modeStreams" DockPanel.Dock="Left" Content="Streams" Tag="Streams"
                            Style="{StaticResource FilterButton}" Click="OnViewModeClick" Margin="4,0,0,0"/>
                    <Button x:Name="groupButton" DockPanel.Dock="Left" Content="Group"
                            Style="{StaticResource FilterButton}" Click="OnGroupToggleClick" Margin="12,0,0,0"
                            ToolTip="Group cameras by recorder / streams by camera"/>
                    <TextBlock x:Name="camerasSummary" Style="{StaticResource SummaryLabel}" DockPanel.Dock="Left"/>
                    <!-- Right side: export at the far right (matches the other tables), then filters. -->
                    <Button DockPanel.Dock="Right" Style="{StaticResource FilterButton}" Click="OnExportCameras"
                            ToolTip="Export the current camera/stream view to CSV">
                        <fa5:ImageAwesome Icon="Solid_FileCsv" Width="11" Height="11" Foreground="{StaticResource ScSubtle}"/>
                    </Button>
                    <Button x:Name="fltOffline" DockPanel.Dock="Right" Content="Offline" Tag="Offline"
                            Style="{StaticResource FilterButton}" Click="OnStatusFilterClick" Margin="4,0,10,0"/>
                    <Button x:Name="fltOnline" DockPanel.Dock="Right" Content="Online" Tag="Online"
                            Style="{StaticResource FilterButton}" Click="OnStatusFilterClick" Margin="4,0,0,0"/>
                    <Button x:Name="fltAll" DockPanel.Dock="Right" Content="All" Tag="All"
                            Style="{StaticResource FilterButton}" Click="OnStatusFilterClick" Margin="4,0,0,0"/>
                    <TextBox x:Name="cameraFilter" DockPanel.Dock="Right" Width="220" Margin="6,0,4,0"
                             Style="{StaticResource DarkSearch}" TextChanged="OnCameraFilterTextChanged"/>
                    <TextBlock DockPanel.Dock="Right" Text="Filter" Style="{StaticResource SummaryLabel}"/>
                </DockPanel>
                <DataGrid x:Name="camerasGrid" Grid.Row="1" Style="{StaticResource HealthGrid}"
                          VirtualizingStackPanel.IsVirtualizing="True"
                          VirtualizingStackPanel.VirtualizationMode="Recycling">
                    <DataGrid.Columns>
                        <DataGridTemplateColumn Header="" Width="26" SortMemberPath="Online" CanUserSort="True">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Ellipse Width="9" Height="9" HorizontalAlignment="Center"
                                             Fill="{Binding Online, Converter={StaticResource OnlineDot}}"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTextColumn Header="CAMERA"     Binding="{Binding Name}" Width="300"/>
                        <DataGridTextColumn Header="RECORDER"   Binding="{Binding RecorderHost}" Width="180"/>
                        <DataGridTextColumn Header="STREAMS"    Binding="{Binding StreamCountText}" SortMemberPath="StreamCount" Width="Auto"/>
                        <DataGridTextColumn Header="RESOLUTION" Binding="{Binding Resolution}" SortMemberPath="PixelValue" Width="Auto"/>
                        <DataGridTextColumn Header="CODEC"      Binding="{Binding Codec}" Width="Auto"/>
                        <DataGridTextColumn Header="FPS"        Binding="{Binding Fps}" SortMemberPath="FpsValue" Width="Auto"/>
                        <DataGridTextColumn Header="BITRATE"    Binding="{Binding Bitrate}" SortMemberPath="BitrateValue" Width="Auto"/>
                        <DataGridTextColumn Header="STORAGE USED" Binding="{Binding UsedSpaceText}" SortMemberPath="UsedSpaceBytes" Width="Auto"/>
                        <DataGridTextColumn Header="STORAGE %" Binding="{Binding StoragePercentText}" SortMemberPath="StoragePercentValue" Width="Auto"/>
                        <DataGridTextColumn Header="FIRST REC"  Binding="{Binding FirstRecordingText}" CanUserSort="False" Width="Auto"/>
                        <DataGridTextColumn Header="LAST REC"   Binding="{Binding LastRecordingText}"  CanUserSort="False" Width="Auto"/>
                        <DataGridTextColumn Header="SPAN"       Binding="{Binding SpanText}" SortMemberPath="SpanDaysValue" Width="*"/>
                    </DataGrid.Columns>
                </DataGrid>

                <!-- Streams mode: flat list of every stream across all cameras. -->
                <DataGrid x:Name="streamsGrid" Grid.Row="1" Style="{StaticResource HealthGrid}" Visibility="Collapsed"
                          VirtualizingStackPanel.IsVirtualizing="True"
                          VirtualizingStackPanel.VirtualizationMode="Recycling">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="CAMERA"     Binding="{Binding CameraName}" Width="300"/>
                        <DataGridTextColumn Header="RECORDER"   Binding="{Binding RecorderName}" Width="180"/>
                        <DataGridTextColumn Header="STREAM"     Binding="{Binding StreamName}" Width="1*"/>
                        <DataGridTextColumn Header="RESOLUTION" Binding="{Binding Resolution}" SortMemberPath="Width" Width="Auto"/>
                        <DataGridTextColumn Header="CODEC"      Binding="{Binding Codec}" Width="Auto"/>
                        <DataGridTextColumn Header="FPS"        Binding="{Binding FpsText}" SortMemberPath="Fps" Width="Auto"/>
                        <DataGridTextColumn Header="REQ. FPS"   Binding="{Binding FpsRequestedText}" SortMemberPath="FpsRequested" Width="Auto"/>
                        <DataGridTextColumn Header="BITRATE"    Binding="{Binding BitrateText}" SortMemberPath="Bps" Width="Auto"/>
                        <DataGridTextColumn Header="ROLE"       Binding="{Binding RoleText}" Width="Auto"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>

            <GridSplitter Grid.Row="4" Style="{StaticResource VSplitter}"/>

            <!-- Users -->
            <Grid Grid.Row="5">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <DockPanel Grid.Row="0" Margin="0,0,0,4">
                    <TextBlock Text="USERS" Style="{StaticResource SectionLabel}" DockPanel.Dock="Left"/>
                    <Button DockPanel.Dock="Right" Style="{StaticResource FilterButton}" Click="OnExportUsers"
                            ToolTip="Export users to CSV">
                        <fa5:ImageAwesome Icon="Solid_FileCsv" Width="11" Height="11" Foreground="{StaticResource ScSubtle}"/>
                    </Button>
                    <TextBlock x:Name="usersSummary" Style="{StaticResource SummaryLabel}" DockPanel.Dock="Left"/>
                </DockPanel>
                <DataGrid x:Name="usersGrid" Grid.Row="1" Style="{StaticResource HealthGrid}">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="USER" Binding="{Binding DisplayName}" Width="2*"/>
                        <DataGridTextColumn Header="CLIENT" Binding="{Binding Secondary}" Width="1.5*"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>

            <!-- Errors -->
            <Border x:Name="errorBox" Grid.Row="6" Margin="0,10,0,0" Padding="10,8"
                    Background="#1AE04545" BorderBrush="#55E04545" BorderThickness="1"
                    CornerRadius="3" Visibility="Collapsed">
                <TextBlock x:Name="errorText" Foreground="#FFE89A9A" FontSize="11" TextWrapping="Wrap"/>
            </Border>

            <!-- Loading overlay spanning the data area -->
            <Border x:Name="overlay" Grid.Row="1" Grid.RowSpan="6" Background="#CC1B1B1B" Visibility="Collapsed">
                <TextBlock x:Name="overlayText" Text="Loading…" Foreground="{StaticResource ScSubtle}"
                           FontSize="14" HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
        </Grid>
    </Border>
</Window>
