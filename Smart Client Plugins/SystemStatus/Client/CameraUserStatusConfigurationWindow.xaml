<Window
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="clr-namespace:SystemStatus.Client"
    x:Class="SystemStatus.Client.CameraUserStatusConfigurationWindow"
    Title="Folder &amp; Role - Configuration"
    Width="860" Height="780" MinWidth="720" MinHeight="520"
    ResizeMode="CanResize"
    WindowStartupLocation="CenterOwner"
    Background="#FF1E1E1E" Foreground="#FFD0D0D0" FontSize="13">

    <Window.Resources>
        <SolidColorBrush x:Key="Panel"  Color="#FF262626"/>
        <SolidColorBrush x:Key="Stroke" Color="#FF3C3C3C"/>
        <SolidColorBrush x:Key="Sub"    Color="#FF9A9A9A"/>

        <!-- Section framing, ported from MetadataDisplay (title + rounded container). -->
        <Style x:Key="SectionTitle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#FFE6EAEC"/>
            <Setter Property="Margin" Value="0,0,0,10"/>
        </Style>
        <Style x:Key="SectionContainer" TargetType="Border">
            <Setter Property="BorderBrush" Value="#555"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="4"/>
            <Setter Property="Padding" Value="15"/>
            <Setter Property="Margin" Value="0,0,0,14"/>
        </Style>

        <Style x:Key="Hint" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource Sub}"/>
            <Setter Property="FontSize" Value="11"/>
        </Style>
        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#FFD0D0D0"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="#FFD0D0D0"/>
            <Setter Property="Margin" Value="0,3"/>
        </Style>
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="#FFD0D0D0"/>
        </Style>
        <Style x:Key="DarkBox" TargetType="TextBox">
            <Setter Property="Background" Value="#FF2A2A2A"/>
            <Setter Property="Foreground" Value="#FFD0D0D0"/>
            <Setter Property="BorderBrush" Value="{StaticResource Stroke}"/>
            <Setter Property="Padding" Value="5,2"/>
            <Setter Property="CaretBrush" Value="#FFD0D0D0"/>
        </Style>

        <!-- Dark ComboBox (ported from MetadataDisplay so the dropdowns match the theme). -->
        <Style x:Key="DarkComboBoxItem" TargetType="ComboBoxItem">
            <Setter Property="Background" Value="#FF2A2A2A"/>
            <Setter Property="Foreground" Value="#FFD0D0D0"/>
            <Setter Property="Padding" Value="6,4"/>
            <Setter Property="SnapsToDevicePixels" Value="True"/>
            <Setter Property="OverridesDefaultStyle" Value="True"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBoxItem">
                        <Border x:Name="bd" Background="#FF2A2A2A"
                                Padding="{TemplateBinding Padding}" SnapsToDevicePixels="True">
                            <ContentPresenter VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#FF3399FF"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <ControlTemplate x:Key="DarkComboBoxToggle" TargetType="ToggleButton">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition/>
                    <ColumnDefinition Width="20"/>
                </Grid.ColumnDefinitions>
                <Border x:Name="Border" Grid.ColumnSpan="2" Background="#FF2A2A2A"
                        BorderBrush="#FF444444" BorderThickness="1" CornerRadius="0"/>
                <Border Grid.Column="0" Background="#FF2A2A2A" Margin="1"/>
                <Path Grid.Column="1" Data="M 0 0 L 4 4 L 8 0 Z" Fill="#FFD0D0D0"
                      HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Grid>
        </ControlTemplate>
        <Style x:Key="DarkComboBox" TargetType="ComboBox">
            <Setter Property="Foreground" Value="#FFD0D0D0"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="MinHeight" Value="24"/>
            <Setter Property="ItemContainerStyle" Value="{StaticResource DarkComboBoxItem}"/>
            <Setter Property="SnapsToDevicePixels" Value="True"/>
            <Setter Property="OverridesDefaultStyle" Value="True"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <ToggleButton Template="{StaticResource DarkComboBoxToggle}"
                                          IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                          Focusable="False" ClickMode="Press"/>
                            <ContentPresenter IsHitTestVisible="False"
                                              Content="{TemplateBinding SelectionBoxItem}"
                                              ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                              Margin="6,4,24,4" VerticalAlignment="Center"
                                              HorizontalAlignment="Left"/>
                            <Popup IsOpen="{TemplateBinding IsDropDownOpen}" Placement="Bottom"
                                   Focusable="False" AllowsTransparency="True" PopupAnimation="Slide">
                                <Grid MinWidth="{TemplateBinding ActualWidth}" MaxHeight="{TemplateBinding MaxDropDownHeight}"
                                      SnapsToDevicePixels="True">
                                    <Border Background="#FF2A2A2A" BorderBrush="#FF444444" BorderThickness="1">
                                        <ScrollViewer SnapsToDevicePixels="True">
                                            <StackPanel IsItemsHost="True" KeyboardNavigation.DirectionalNavigation="Contained"/>
                                        </ScrollViewer>
                                    </Border>
                                </Grid>
                            </Popup>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="ComboBox" BasedOn="{StaticResource DarkComboBox}"/>
        <Style TargetType="ComboBoxItem" BasedOn="{StaticResource DarkComboBoxItem}"/>

        <!-- Dark buttons, ported from MetadataDisplay. -->
        <Style x:Key="SmallButton" TargetType="Button">
            <Setter Property="Background" Value="#FF2A2A2A"/>
            <Setter Property="Foreground" Value="#FFD0D0D0"/>
            <Setter Property="BorderBrush" Value="#FF444444"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="12,4"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="3"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#FF363636"/>
                                <Setter TargetName="bd" Property="BorderBrush" Value="#FF555555"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#FF404040"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="bd" Property="Opacity" Value="0.5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="Button" BasedOn="{StaticResource SmallButton}"/>
    </Window.Resources>

    <Grid Margin="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="440"/>
            <ColumnDefinition Width="14"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ── Left: settings ─────────────────────────────────────────── -->
        <ScrollViewer Grid.Row="0" Grid.Column="0" VerticalScrollBarVisibility="Auto" Padding="0,0,8,0">
            <StackPanel>

                <TextBlock Text="Selection" Style="{StaticResource SectionTitle}"/>
                <Border Style="{StaticResource SectionContainer}">
                    <StackPanel>
                        <CheckBox x:Name="chkIndividual"
                                  Content="Show only the folders / roles I pick below"/>
                        <TextBlock Style="{StaticResource Hint}" Margin="0,0,0,8"
                                   Text="Off shows every folder and role."/>
                        <CheckBox x:Name="chkPrefix" Content="Show recording-server prefix in folder names"/>
                        <Grid x:Name="selectionGrid" Margin="0,8,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="10"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="150"/>
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0" Grid.Column="0" Text="Folders" FontWeight="SemiBold" Margin="0,0,0,4"/>
                            <TextBlock Grid.Row="0" Grid.Column="2" Text="Roles" FontWeight="SemiBold" Margin="0,0,0,4"/>
                            <Border Grid.Row="1" Grid.Column="0" Background="{StaticResource Panel}" BorderBrush="{StaticResource Stroke}" BorderThickness="1">
                                <ScrollViewer VerticalScrollBarVisibility="Auto">
                                    <StackPanel x:Name="folderPanel" Margin="6"/>
                                </ScrollViewer>
                            </Border>
                            <Border Grid.Row="1" Grid.Column="2" Background="{StaticResource Panel}" BorderBrush="{StaticResource Stroke}" BorderThickness="1">
                                <ScrollViewer VerticalScrollBarVisibility="Auto">
                                    <StackPanel x:Name="rolePanel" Margin="6"/>
                                </ScrollViewer>
                            </Border>
                        </Grid>
                    </StackPanel>
                </Border>

                <TextBlock Text="Sections" Style="{StaticResource SectionTitle}"/>
                <Border Style="{StaticResource SectionContainer}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Render mode" Style="{StaticResource FieldLabel}" Margin="0,4,10,4"/>
                        <ComboBox  Grid.Row="0" Grid.Column="1" x:Name="cmbRender" Margin="0,4">
                            <ComboBoxItem Content="List"/>
                            <ComboBoxItem Content="Dashboard"/>
                        </ComboBox>

                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Show" Style="{StaticResource FieldLabel}" Margin="0,4,10,4"/>
                        <ComboBox  Grid.Row="1" Grid.Column="1" x:Name="cmbDisplay" Margin="0,4">
                            <ComboBoxItem Content="Show all"/>
                            <ComboBoxItem Content="Cameras only"/>
                            <ComboBoxItem Content="Roles only"/>
                        </ComboBox>

                        <TextBlock Grid.Row="2" Grid.Column="0" Text="Sort rows" Style="{StaticResource FieldLabel}" Margin="0,4,10,4"/>
                        <ComboBox  Grid.Row="2" Grid.Column="1" x:Name="cmbSort" Margin="0,4">
                            <ComboBoxItem Content="Alphabetical"/>
                            <ComboBoxItem Content="Most offline first"/>
                        </ComboBox>

                        <TextBlock Grid.Row="3" Grid.Column="0" x:Name="lblDensity" Text="Row spacing" Style="{StaticResource FieldLabel}" Margin="0,4,10,4"/>
                        <ComboBox  Grid.Row="3" Grid.Column="1" x:Name="cmbDensity" Margin="0,4">
                            <ComboBoxItem Content="Comfortable"/>
                            <ComboBoxItem Content="Compact"/>
                        </ComboBox>

                        <CheckBox Grid.Row="4" Grid.Column="1" x:Name="chkFoldersFirst"
                                  Content="Folders section on top" Margin="0,6,0,0"/>
                    </Grid>
                </Border>

                <TextBlock Text="Style" Style="{StaticResource SectionTitle}"/>
                <Border Style="{StaticResource SectionContainer}">
                    <StackPanel>
                        <CheckBox x:Name="chkSuffix" Content="Show &quot;Devices&quot; / &quot;Users&quot; labels after the count"/>
                        <Grid Margin="0,8,0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Text size" Style="{StaticResource FieldLabel}" Margin="0,0,10,0"/>
                            <Slider Grid.Column="1" x:Name="sldTextSize" Minimum="10" Maximum="22"
                                    TickFrequency="1" IsSnapToTickEnabled="True" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="2" x:Name="lblTextSize" Width="28" TextAlignment="Right"
                                       VerticalAlignment="Center" Margin="8,0,0,0"/>
                        </Grid>

                        <Grid Margin="0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="90"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Count color" Style="{StaticResource FieldLabel}" Margin="0,0,10,0"/>
                            <TextBox Grid.Column="1" x:Name="txtCountColor" Style="{StaticResource DarkBox}"/>
                            <Border Grid.Column="2" x:Name="countSwatch" Width="22" Height="22" Margin="8,0,0,0"
                                    BorderBrush="{StaticResource Stroke}" BorderThickness="1"/>
                        </Grid>

                        <CheckBox x:Name="chkHighlight" Margin="0,6,0,0"
                                  Content="Color the count when some are offline"/>
                        <Grid Margin="0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="90"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Offline color" Style="{StaticResource FieldLabel}" Margin="0,0,10,0"/>
                            <TextBox Grid.Column="1" x:Name="txtOfflineColor" Style="{StaticResource DarkBox}"/>
                            <Border Grid.Column="2" x:Name="offlineSwatch" Width="22" Height="22" Margin="8,0,0,0"
                                    BorderBrush="{StaticResource Stroke}" BorderThickness="1"/>
                        </Grid>

                        <!-- Dashboard-only: card minimum width (cards grow past it to fit names). -->
                        <StackPanel x:Name="cardSizePanel">
                            <Border Height="1" Background="{StaticResource Stroke}" Margin="0,10,0,8"/>
                            <Grid Margin="0,2">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Card min width" Style="{StaticResource FieldLabel}" Margin="0,0,10,0"/>
                                <Slider Grid.Column="1" x:Name="sldCardMin" Minimum="100" Maximum="360"
                                        TickFrequency="10" IsSnapToTickEnabled="True" VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="2" x:Name="lblCardMin" Width="34" TextAlignment="Right"
                                           VerticalAlignment="Center" Margin="8,0,0,0"/>
                            </Grid>
                        </StackPanel>
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>

        <!-- ── Right: live preview ────────────────────────────────────── -->
        <DockPanel Grid.Row="0" Grid.Column="2">
            <TextBlock DockPanel.Dock="Top" Text="PREVIEW" Style="{StaticResource Hint}" Margin="0,0,0,6"/>
            <Border Background="#FF1B1B1B" BorderBrush="{StaticResource Stroke}" BorderThickness="1">
                <local:CameraUserStatusListView x:Name="preview" Margin="12"/>
            </Border>
        </DockPanel>

        <!-- ── Buttons ────────────────────────────────────────────────── -->
        <StackPanel Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="3" Orientation="Horizontal"
                    HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button x:Name="okButton" Content="OK" Width="90" Height="28" Margin="0,0,8,0" Click="OnOk"/>
            <Button x:Name="cancelButton" Content="Cancel" Width="90" Height="28" IsCancel="True" Click="OnCancel"/>
        </StackPanel>
    </Grid>
</Window>
