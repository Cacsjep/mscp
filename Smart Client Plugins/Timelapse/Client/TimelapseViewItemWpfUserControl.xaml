<external:ViewItemWpfUserControl
    xmlns:external="clr-namespace:VideoOS.Platform.Client;assembly=VideoOS.Platform"
    x:Class="Timelapse.Client.TimelapseViewItemWpfUserControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:fa5="http://schemas.fontawesome.com/icons/"
    mc:Ignorable="d"
    d:DesignHeight="650"
    d:DesignWidth="1000">
    <external:ViewItemWpfUserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>

        <!-- Dark tooltip for plain-string content. Wraps at 340 px so text never clips.
             The template uses a TextBlock bound to Content instead of ContentPresenter because
             WPF's ContentPresenter does NOT honor TextWrapping for auto-generated string TextBlocks. -->
        <Style TargetType="ToolTip">
            <Setter Property="OverridesDefaultStyle" Value="True"/>
            <Setter Property="HasDropShadow" Value="True"/>
            <Setter Property="Placement" Value="Right"/>
            <Setter Property="HorizontalOffset" Value="-2"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToolTip">
                        <Border Background="#FF2A2A2A"
                                BorderBrush="#FF444444"
                                BorderThickness="1"
                                Padding="10,8"
                                CornerRadius="2">
                            <TextBlock Text="{TemplateBinding Content}"
                                       TextWrapping="Wrap"
                                       MaxWidth="340"
                                       Foreground="#FFD0D0D0"
                                       FontSize="12"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Rich-content tooltip (StackPanel, multiple TextBlocks) for the Mode help icon. -->
        <Style x:Key="RichToolTip" TargetType="ToolTip" BasedOn="{StaticResource {x:Type ToolTip}}">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToolTip">
                        <Border Background="#FF2A2A2A"
                                BorderBrush="#FF444444"
                                BorderThickness="1"
                                Padding="10,8"
                                CornerRadius="2"
                                MaxWidth="360">
                            <Border.Resources>
                                <Style TargetType="TextBlock">
                                    <Setter Property="TextWrapping" Value="Wrap"/>
                                    <Setter Property="Foreground" Value="#FFD0D0D0"/>
                                    <Setter Property="FontSize" Value="12"/>
                                </Style>
                            </Border.Resources>
                            <ContentPresenter/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <!-- Keep tooltips open while the cursor hovers the anchor (default WPF auto-hides after 5 s). -->
        <Style x:Key="PersistentToolTipHost" TargetType="FrameworkElement">
            <Setter Property="ToolTipService.ShowDuration" Value="60000"/>
            <Setter Property="ToolTipService.InitialShowDelay" Value="150"/>
            <Setter Property="ToolTipService.BetweenShowDelay" Value="0"/>
        </Style>

        <!-- Dark Button Style (from SCRemoteControl) -->
        <Style x:Key="DarkButton" TargetType="Button">
            <Setter Property="Background" Value="#FF2A2A2A"/>
            <Setter Property="Foreground" Value="#FFD0D0D0"/>
            <Setter Property="BorderBrush" Value="#FF444444"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="3"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#FF363636"/>
                                <Setter TargetName="bd" Property="BorderBrush" Value="#FF555555"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#FF404040"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="bd" Property="Opacity" Value="0.5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Green Action Button -->
        <Style x:Key="GreenButton" TargetType="Button" BasedOn="{StaticResource DarkButton}">
            <Setter Property="Background" Value="#FF238636"/>
            <Setter Property="BorderBrush" Value="#FF2EA043"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="1"
                                CornerRadius="3"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#FF2EA043"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#FF1A7F37"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="bd" Property="Opacity" Value="0.5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="LabelText" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#FF8B949E"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Margin" Value="0,0,0,4"/>
        </Style>

        <!-- Dark ComboBox Styles (from SCRemoteControl) -->
        <Style x:Key="DarkComboBoxItem" TargetType="ComboBoxItem">
            <Setter Property="Background" Value="#FF2A2A2A"/>
            <Setter Property="Foreground" Value="#FFD0D0D0"/>
            <Setter Property="Padding" Value="6,4"/>
            <Setter Property="SnapsToDevicePixels" Value="True"/>
            <Setter Property="OverridesDefaultStyle" Value="True"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBoxItem">
                        <Border x:Name="bd" Background="#FF2A2A2A"
                                Padding="{TemplateBinding Padding}" SnapsToDevicePixels="True">
                            <ContentPresenter VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#FF3399FF"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="IsSelected" Value="True"/>
                                    <Condition Property="IsHighlighted" Value="False"/>
                                </MultiTrigger.Conditions>
                                <Setter TargetName="bd" Property="Background" Value="#FF333333"/>
                                <Setter Property="Foreground" Value="White"/>
                            </MultiTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <ControlTemplate x:Key="DarkComboBoxToggle" TargetType="ToggleButton">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition/>
                    <ColumnDefinition Width="20"/>
                </Grid.ColumnDefinitions>
                <Border x:Name="Border" Grid.ColumnSpan="2" Background="#FF2A2A2A"
                        BorderBrush="#FF444444" BorderThickness="1" CornerRadius="0"/>
                <Border Grid.Column="0" Background="#FF2A2A2A" Margin="1"/>
                <Path Grid.Column="1" Data="M 0 0 L 4 4 L 8 0 Z" Fill="#FFD0D0D0"
                      HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Grid>
        </ControlTemplate>
        <Style x:Key="DarkComboBox" TargetType="ComboBox">
            <Setter Property="Foreground" Value="#FFD0D0D0"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="MinHeight" Value="28"/>
            <Setter Property="ItemContainerStyle" Value="{StaticResource DarkComboBoxItem}"/>
            <Setter Property="SnapsToDevicePixels" Value="True"/>
            <Setter Property="OverridesDefaultStyle" Value="True"/>
            <!-- Keep tooltips open as long as the mouse hovers the combo. -->
            <Setter Property="ToolTipService.ShowDuration" Value="60000"/>
            <Setter Property="ToolTipService.InitialShowDelay" Value="150"/>
            <Setter Property="ToolTipService.BetweenShowDelay" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <ToggleButton Template="{StaticResource DarkComboBoxToggle}"
                                          IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                          Focusable="False" ClickMode="Press"/>
                            <ContentPresenter IsHitTestVisible="False"
                                              Content="{TemplateBinding SelectionBoxItem}"
                                              ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                              Margin="6,4,24,4" VerticalAlignment="Center"
                                              HorizontalAlignment="Left"/>
                            <Popup IsOpen="{TemplateBinding IsDropDownOpen}" Placement="Bottom"
                                   Focusable="False" AllowsTransparency="True" PopupAnimation="Slide">
                                <Grid MinWidth="{TemplateBinding ActualWidth}" MaxHeight="{TemplateBinding MaxDropDownHeight}"
                                      SnapsToDevicePixels="True">
                                    <Border Background="#FF2A2A2A" BorderBrush="#FF444444" BorderThickness="1">
                                        <ScrollViewer SnapsToDevicePixels="True">
                                            <StackPanel IsItemsHost="True" KeyboardNavigation.DirectionalNavigation="Contained"/>
                                        </ScrollViewer>
                                    </Border>
                                </Grid>
                            </Popup>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <!-- Dark Slider Style -->
        <Style x:Key="DarkSlider" TargetType="Slider">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Slider">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto" MinHeight="{TemplateBinding MinHeight}"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <Border x:Name="TrackBackground" Grid.Row="1" Height="4" CornerRadius="2"
                                    Background="#FF333333" Margin="5,0"/>
                            <Track x:Name="PART_Track" Grid.Row="1">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Command="Slider.DecreaseLarge" Style="{x:Null}">
                                        <RepeatButton.Template>
                                            <ControlTemplate TargetType="RepeatButton">
                                                <Border Height="4" CornerRadius="2" Background="#FF3399FF"/>
                                            </ControlTemplate>
                                        </RepeatButton.Template>
                                    </RepeatButton>
                                </Track.DecreaseRepeatButton>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Command="Slider.IncreaseLarge" Style="{x:Null}">
                                        <RepeatButton.Template>
                                            <ControlTemplate TargetType="RepeatButton">
                                                <Border Background="Transparent"/>
                                            </ControlTemplate>
                                        </RepeatButton.Template>
                                    </RepeatButton>
                                </Track.IncreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb>
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="Thumb">
                                                <Ellipse x:Name="thumbEllipse" Width="14" Height="14"
                                                         Fill="#FFD0D0D0" Stroke="#FF555555" StrokeThickness="1"/>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="thumbEllipse" Property="Fill" Value="White"/>
                                                    </Trigger>
                                                    <Trigger Property="IsDragging" Value="True">
                                                        <Setter TargetName="thumbEllipse" Property="Fill" Value="#FF3399FF"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </external:ViewItemWpfUserControl.Resources>

    <Grid Background="#FF1C2326">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="380"/>
                <ColumnDefinition Width="1"/>
                <ColumnDefinition Width="*" MinWidth="300"/>
            </Grid.ColumnDefinitions>

            <!-- Left panel: Configuration (fixed width, not resizable) -->
            <Border Grid.Column="0" Background="#FF1C2326">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="12,8">
                        <!-- Camera Selection -->
                        <TextBlock Text="CAMERAS" Style="{StaticResource LabelText}" FontWeight="SemiBold" Margin="0,0,0,8"/>
                        <Button x:Name="addCameraButton" Content="+ Add Camera" Style="{StaticResource DarkButton}"
                                Click="OnAddCameraClick" HorizontalAlignment="Stretch" Margin="0,0,0,6"/>
                        <ListBox x:Name="cameraListBox" Background="#FF2D333B" BorderBrush="#FF444C56"
                                 Foreground="White" MinHeight="60" MaxHeight="200" FontSize="12">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Name}" Foreground="White" VerticalAlignment="Center"
                                               TextTrimming="CharacterEllipsis" FontSize="12" Margin="2"/>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                        <Grid Margin="0,4,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock x:Name="cameraCountText" Text="0 camera(s) selected (max 9)"
                                       Foreground="#FF666666" FontSize="10" VerticalAlignment="Center"/>
                            <Button Grid.Column="1" Content="Clear" Style="{StaticResource DarkButton}"
                                    Click="OnClearCamerasClick" FontSize="10" Padding="8,2"/>
                        </Grid>

                        <Separator Background="#FF30363D" Margin="0,12"/>

                        <!-- Time Range -->
                        <TextBlock Text="TIME RANGE" Style="{StaticResource LabelText}" FontWeight="SemiBold" Margin="0,0,0,8"/>

                        <TextBlock Text="Preset" Style="{StaticResource LabelText}"/>
                        <ComboBox x:Name="timePresetCombo" Style="{StaticResource DarkComboBox}" Margin="0,0,0,8"/>

                        <!-- Two-column layout for start/end -->
                        <Grid Margin="0,0,0,6">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="12"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <!-- Start column -->
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Start Date" Style="{StaticResource LabelText}"/>
                                <DatePicker x:Name="startDatePicker" Background="#FF2D333B" BorderBrush="#FF444C56"
                                            FontSize="11" Margin="0,0,0,6"/>
                                <TextBlock Text="Start Time" Style="{StaticResource LabelText}"/>
                                <Grid Margin="0,0,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="4"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <ComboBox x:Name="startHourCombo" Style="{StaticResource DarkComboBox}"/>
                                    <ComboBox x:Name="startMinuteCombo" Grid.Column="2" Style="{StaticResource DarkComboBox}"/>
                                </Grid>
                            </StackPanel>

                            <!-- End column -->
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="End Date" Style="{StaticResource LabelText}"/>
                                <DatePicker x:Name="endDatePicker" Background="#FF2D333B" BorderBrush="#FF444C56"
                                            FontSize="11" Margin="0,0,0,6"/>
                                <TextBlock Text="End Time" Style="{StaticResource LabelText}"/>
                                <Grid Margin="0,0,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="4"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <ComboBox x:Name="endHourCombo" Style="{StaticResource DarkComboBox}"/>
                                    <ComboBox x:Name="endMinuteCombo" Grid.Column="2" Style="{StaticResource DarkComboBox}"/>
                                </Grid>
                            </StackPanel>
                        </Grid>

                        <!-- Daily window: restrict frames to a time-of-day window per day -->
                        <CheckBox x:Name="dailyWindowCheck" Content="Apply time window per day"
                                  Foreground="#FFD0D0D0" FontSize="12" Margin="0,4,0,4"
                                  IsChecked="False"
                                  ToolTipService.ShowDuration="60000" ToolTipService.InitialShowDelay="150">
                            <CheckBox.ToolTip>
                                <ToolTip Style="{StaticResource RichToolTip}">
                                    <TextBlock TextWrapping="Wrap" MaxWidth="340">When checked, only frames whose time-of-day falls inside <Run FontWeight="Bold">Daily Start</Run> .. <Run FontWeight="Bold">Daily End</Run> are included, repeated every day across the date range. Useful for daylight-only timelapses (e.g. 2 weeks, 08:00-17:00 each day). Wrapping windows like 22:00-06:00 are supported for night-only timelapses.</TextBlock>
                                </ToolTip>
                            </CheckBox.ToolTip>
                        </CheckBox>

                        <Grid x:Name="dailyWindowFields" Margin="0,0,0,0" Visibility="Collapsed">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="12"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Daily Start" Style="{StaticResource LabelText}"/>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="4"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <ComboBox x:Name="dailyStartHourCombo" Style="{StaticResource DarkComboBox}"/>
                                    <ComboBox x:Name="dailyStartMinuteCombo" Grid.Column="2" Style="{StaticResource DarkComboBox}"/>
                                </Grid>
                            </StackPanel>

                            <StackPanel Grid.Column="2">
                                <TextBlock Text="Daily End" Style="{StaticResource LabelText}"/>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="4"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <ComboBox x:Name="dailyEndHourCombo" Style="{StaticResource DarkComboBox}"/>
                                    <ComboBox x:Name="dailyEndMinuteCombo" Grid.Column="2" Style="{StaticResource DarkComboBox}"/>
                                </Grid>
                            </StackPanel>
                        </Grid>

                        <Separator Background="#FF30363D" Margin="0,12"/>

                        <!-- Settings - two column -->
                        <TextBlock Text="SETTINGS" Style="{StaticResource LabelText}" FontWeight="SemiBold" Margin="0,0,0,8"/>

                        <TextBlock Text="Mode" Style="{StaticResource LabelText}"/>
                        <ComboBox x:Name="modeCombo" Style="{StaticResource DarkComboBox}" Margin="0,0,0,8"
                                  ToolTip="Continuous: permanent recordings, e.g. construction site. Event-based: motion or trigger-driven recordings, sampled per event."/>

                        <!-- Continuous-only fields -->
                        <Grid x:Name="continuousFields" Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="12"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Grid.Column="0" Text="Frame Interval" Style="{StaticResource LabelText}"/>
                            <ComboBox x:Name="intervalCombo" Grid.Row="1" Grid.Column="0" Style="{StaticResource DarkComboBox}" Margin="0,0,0,0"
                                      ToolTip="Spacing between sampled frames across the selected time range. Smaller intervals yield smoother but longer timelapses. Gaps with no recording are skipped automatically."/>
                        </Grid>

                        <!-- Event-only fields -->
                        <Grid x:Name="eventFields" Margin="0,0,0,8" Visibility="Collapsed">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="12"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Grid.Column="0" Text="Interval per event" Style="{StaticResource LabelText}"/>
                            <ComboBox x:Name="eventIntervalCombo" Grid.Row="1" Grid.Column="0" Style="{StaticResource DarkComboBox}" Margin="0,0,0,8">
                                <ComboBox.ToolTip>
                                    <ToolTip Style="{StaticResource RichToolTip}">
                                        <TextBlock TextWrapping="Wrap" MaxWidth="340">Time between sampled frames inside each recording event. The first frame is always included, then additional frames every N seconds until <Run FontWeight="Bold">Max frames / event</Run> is reached.</TextBlock>
                                    </ToolTip>
                                </ComboBox.ToolTip>
                            </ComboBox>

                            <TextBlock Grid.Row="0" Grid.Column="2" Text="Max frames / event" Style="{StaticResource LabelText}"/>
                            <ComboBox x:Name="maxPerEventCombo" Grid.Row="1" Grid.Column="2" Style="{StaticResource DarkComboBox}" Margin="0,0,0,8">
                                <ComboBox.ToolTip>
                                    <ToolTip Style="{StaticResource RichToolTip}">
                                        <TextBlock TextWrapping="Wrap" MaxWidth="340">Upper bound on frames taken from a single event. Prevents one long recording from dominating the timelapse. A 20 s clip with <Run FontWeight="Bold">Interval per event</Run> of 2 s gives 10 frames. The cap only kicks in for longer events.</TextBlock>
                                    </ToolTip>
                                </ComboBox.ToolTip>
                            </ComboBox>

                            <TextBlock Grid.Row="2" Grid.Column="0" Text="Min frames / event" Style="{StaticResource LabelText}"/>
                            <ComboBox x:Name="minPerEventCombo" Grid.Row="3" Grid.Column="0" Style="{StaticResource DarkComboBox}">
                                <ComboBox.ToolTip>
                                    <ToolTip Style="{StaticResource RichToolTip}">
                                        <TextBlock TextWrapping="Wrap" MaxWidth="340">Lower bound on frames per event. If an event is too short for <Run FontWeight="Bold">Interval per event</Run> to produce this many frames, they are distributed evenly across its duration instead.</TextBlock>
                                    </ToolTip>
                                </ComboBox.ToolTip>
                            </ComboBox>
                        </Grid>

                        <!-- Shared FPS/Resolution -->
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="12"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Grid.Column="0" Text="Output FPS" Style="{StaticResource LabelText}"/>
                            <ComboBox x:Name="fpsCombo" Grid.Row="1" Grid.Column="0" Style="{StaticResource DarkComboBox}" Margin="0,0,0,8"
                                      ToolTip="Playback speed of the generated MP4. Total frames ÷ FPS = video length. Lower FPS plays better for short frame counts. 24 to 30 feels like a normal video but requires more frames."/>

                            <TextBlock Grid.Row="0" Grid.Column="2" Text="Resolution" Style="{StaticResource LabelText}"/>
                            <ComboBox x:Name="resolutionCombo" Grid.Row="1" Grid.Column="2" Style="{StaticResource DarkComboBox}" Margin="0,0,0,8"
                                      ToolTip="Scale applied to each camera frame before it is placed in the grid. Half / Quarter shrinks the output file and speeds up encoding at the cost of image detail."/>
                        </Grid>

                        <Separator Background="#FF30363D" Margin="0,12"/>

                        <!-- Timestamp Overlay -->
                        <Expander Header="Timestamp Overlay" Foreground="#FF8B949E" FontSize="12" IsExpanded="False" Margin="0,0,0,8">
                            <StackPanel Margin="0,8,0,0">
                                <CheckBox x:Name="showTimestampCheck" Content="Show Timestamp"
                                          Foreground="#FFD0D0D0" FontSize="12" Margin="0,0,0,8"
                                          IsChecked="False"
                                          ToolTipService.ShowDuration="60000" ToolTipService.InitialShowDelay="150"
                                          ToolTip="Burns the wall-clock timestamp of each source frame onto the output video. Useful for construction-site timelapses so viewers can tell which time of day a frame was captured."/>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="12"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Position" Style="{StaticResource LabelText}"/>
                                    <ComboBox x:Name="tsPositionCombo" Grid.Row="1" Grid.Column="0" Style="{StaticResource DarkComboBox}" Margin="0,0,0,8"
                                              ToolTip="Corner of the full canvas where the timestamp is drawn. Applies to the whole grid, not per camera cell."/>

                                    <TextBlock Grid.Row="0" Grid.Column="2" Text="Format" Style="{StaticResource LabelText}"/>
                                    <ComboBox x:Name="tsFormatCombo" Grid.Row="1" Grid.Column="2" Style="{StaticResource DarkComboBox}" Margin="0,0,0,8">
                                        <ComboBox.ToolTip>
                                            <ToolTip Style="{StaticResource RichToolTip}">
                                                <TextBlock TextWrapping="Wrap" MaxWidth="340">Date/time format for the overlay. <Run FontWeight="Bold">Time only</Run> is useful when the date is already in the filename. <Run FontWeight="Bold">Date + Time</Run> is the safest default for evidence.</TextBlock>
                                            </ToolTip>
                                        </ComboBox.ToolTip>
                                    </ComboBox>

                                    <TextBlock Grid.Row="2" Grid.Column="0" Text="Color" Style="{StaticResource LabelText}"/>
                                    <ComboBox x:Name="tsColorCombo" Grid.Row="3" Grid.Column="0" Style="{StaticResource DarkComboBox}" Margin="0,0,0,8"
                                              ToolTip="Color of the overlay text. Pick a color with high contrast against your typical scene."/>

                                    <TextBlock Grid.Row="2" Grid.Column="2" Text="Background" Style="{StaticResource LabelText}"/>
                                    <ComboBox x:Name="tsBgCombo" Grid.Row="3" Grid.Column="2" Style="{StaticResource DarkComboBox}" Margin="0,0,0,8">
                                        <ComboBox.ToolTip>
                                            <ToolTip Style="{StaticResource RichToolTip}">
                                                <TextBlock TextWrapping="Wrap" MaxWidth="340">Semi-transparent rectangle drawn behind the text so it stays readable when the scene brightness changes. Select <Run FontWeight="Bold">None</Run> for no background.</TextBlock>
                                            </ToolTip>
                                        </ComboBox.ToolTip>
                                    </ComboBox>

                                    <TextBlock Grid.Row="4" Grid.Column="0" Text="Font Size" Style="{StaticResource LabelText}"/>
                                    <ComboBox x:Name="tsFontSizeCombo" Grid.Row="5" Grid.Column="0" Style="{StaticResource DarkComboBox}"
                                              ToolTip="Pixel size of the overlay text. Choose larger sizes for 4K canvases or when the timelapse will be viewed on small screens."/>
                                </Grid>
                            </StackPanel>
                        </Expander>

                        <Separator Background="#FF30363D" Margin="0,4"/>

                        <!-- Advanced Section (collapsible) -->
                        <Expander Header="Advanced" Foreground="#FF8B949E" FontSize="12" IsExpanded="False" Margin="0,0,0,8">
                            <StackPanel Margin="0,8,0,0">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="12"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Max Workers" Style="{StaticResource LabelText}"/>
                                    <ComboBox x:Name="workersCombo" Grid.Row="1" Grid.Column="0" Style="{StaticResource DarkComboBox}" Margin="0,0,0,8"
                                              ToolTip="Number of parallel frame-fetch threads. More workers speed up generation when the recording server and network can keep up, but too many can overload the server and slow things down. 5 is a good default."/>

                                    <TextBlock Grid.Row="0" Grid.Column="2" Text="Batch Size" Style="{StaticResource LabelText}"/>
                                    <ComboBox x:Name="batchSizeCombo" Grid.Row="1" Grid.Column="2" Style="{StaticResource DarkComboBox}" Margin="0,0,0,8"
                                              ToolTip="How many frames are fetched before being handed to the FFmpeg encoder. Larger batches use more memory but let fetch and encode overlap better. 50 is fine for most cases."/>

                                    <TextBlock Grid.Row="2" Grid.Column="0" Text="Event Merge Gap" Style="{StaticResource LabelText}"/>
                                    <ComboBox x:Name="mergeGapCombo" Grid.Row="3" Grid.Column="0" Style="{StaticResource DarkComboBox}">
                                        <ComboBox.ToolTip>
                                            <ToolTip Style="{StaticResource RichToolTip}">
                                                <TextBlock TextWrapping="Wrap" MaxWidth="340">Event-based mode only. Two recording blocks separated by less than this gap are merged into one event, so you don't get duplicate <Run FontWeight="Bold">first frames</Run> when the server fragments a continuous motion into several short sequences.</TextBlock>
                                            </ToolTip>
                                        </ComboBox.ToolTip>
                                    </ComboBox>
                                </Grid>
                            </StackPanel>
                        </Expander>

                        <Separator Background="#FF30363D" Margin="0,4"/>

                        <!-- Action Buttons -->
                        <Button x:Name="generateButton" Content="&#9654; Generate Timelapse" Style="{StaticResource GreenButton}"
                                Click="OnGenerateClick" HorizontalAlignment="Stretch" Padding="12,10" Margin="0,8,0,6"/>
                        <Button x:Name="cancelButton" Content="Cancel" Style="{StaticResource DarkButton}"
                                Click="OnCancelClick" HorizontalAlignment="Stretch" Visibility="Collapsed" Margin="0,0,0,6"/>
                        <Button x:Name="saveButton" Content="&#128190; Save As..." Style="{StaticResource DarkButton}"
                                Click="OnSaveClick" HorizontalAlignment="Stretch" Visibility="Collapsed"/>
                    </StackPanel>
                </ScrollViewer>
            </Border>

            <!-- Divider line (not resizable) -->
            <Border Grid.Column="1" Background="#FF30363D"/>

            <!-- Right panel: Preview / Playback -->
            <DockPanel Grid.Column="2">
                <!-- Progress bar -->
                <ProgressBar x:Name="progressBar" DockPanel.Dock="Bottom" Height="4"
                             Background="#FF30363D" Foreground="#FF238636"
                             Visibility="Collapsed" Minimum="0"/>

                <!-- Playback controls bar -->
                <Border x:Name="playbackControls" DockPanel.Dock="Bottom" Background="#FF252A2E"
                        Padding="12,6" Visibility="Collapsed" BorderBrush="#FF30363D" BorderThickness="0,1,0,0">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Orientation="Horizontal">
                            <Button x:Name="playPauseButton" Content="&#9654;" Style="{StaticResource DarkButton}"
                                    Click="OnPlayPauseClick" FontSize="14" Padding="8,4" Margin="0,0,4,0"/>
                            <Button x:Name="stopButton" Content="&#9632;" Style="{StaticResource DarkButton}"
                                    Click="OnStopClick" FontSize="14" Padding="8,4"/>
                        </StackPanel>
                        <Slider x:Name="seekSlider" Grid.Column="1" VerticalAlignment="Center" Margin="12,0"
                                Minimum="0" Maximum="100" ValueChanged="OnSeekChanged" IsEnabled="False"
                                Style="{StaticResource DarkSlider}"/>
                        <TextBlock x:Name="playbackTimeText" Grid.Column="2" Foreground="#FF8B949E"
                                   FontSize="11" VerticalAlignment="Center" Text="00:00 / 00:00"/>
                        <Button x:Name="closePreviewButton" Grid.Column="3" Content="&#10005;"
                                Style="{StaticResource DarkButton}"
                                Click="OnClosePreviewClick" FontSize="14" Padding="8,4" Margin="12,0,0,0"
                                ToolTip="Close preview and return to configuration"/>
                    </Grid>
                </Border>

                <!-- Video player / placeholder -->
                <Grid Background="#FF0D1117">
                    <!-- MediaElement for playback -->
                    <MediaElement x:Name="mediaPlayer" LoadedBehavior="Manual" UnloadedBehavior="Close"
                                  ScrubbingEnabled="True" Stretch="Uniform"
                                  MediaOpened="OnMediaOpened" MediaEnded="OnMediaEnded"
                                  Visibility="Collapsed"/>

                    <!-- Generation progress placeholder -->
                    <StackPanel x:Name="progressPanel" VerticalAlignment="Center" HorizontalAlignment="Center"
                                Visibility="Collapsed">
                        <TextBlock x:Name="progressStepText" Text="Preparing..."
                                   Foreground="White" FontSize="14" HorizontalAlignment="Center" Margin="0,0,0,8"/>
                        <TextBlock x:Name="progressDetailText" Text=""
                                   Foreground="#FF8B949E" FontSize="12" HorizontalAlignment="Center" Margin="0,0,0,12"
                                   TextWrapping="Wrap" TextAlignment="Center" MaxWidth="400"/>
                        <ProgressBar x:Name="detailProgressBar" Width="300" Height="8"
                                     Background="#FF30363D" Foreground="#FF238636" Minimum="0"/>
                    </StackPanel>

                    <!-- Idle placeholder: hero icon, preflight card, estimate card -->
                    <ScrollViewer x:Name="idlePlaceholder" VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled" Padding="40,24">
                        <StackPanel HorizontalAlignment="Center" MaxWidth="560">

                            <!-- Hero icon: spinning during preflight, static clock otherwise -->
                            <Grid HorizontalAlignment="Center" Margin="0,0,0,18" Width="64" Height="64">
                                <fa5:ImageAwesome x:Name="idleClockIcon" Icon="Regular_Clock"
                                                  Foreground="#FF58A6FF" Width="54" Height="54"/>
                                <fa5:ImageAwesome x:Name="idleSpinnerIcon" Icon="Solid_CircleNotch" Spin="True" SpinDuration="1.2"
                                                  Foreground="#FF58A6FF" Width="58" Height="58"
                                                  Visibility="Collapsed"/>
                            </Grid>

                            <!-- Default hint (no cameras/range) -->
                            <TextBlock x:Name="idleHintText"
                                       Text="Select cameras and time range, then click Generate"
                                       Foreground="#FFB1BAC4" FontSize="15" HorizontalAlignment="Center"
                                       TextAlignment="Center" TextWrapping="Wrap" Margin="0,0,0,4"/>

                            <!-- Preflight card: sequences found -->
                            <Border x:Name="preflightCard" Visibility="Collapsed"
                                    Background="#FF21262D" BorderBrush="#FF30363D" BorderThickness="1"
                                    CornerRadius="6" Padding="18,14" Margin="0,18,0,0" MinWidth="420">
                                <StackPanel>
                                    <TextBlock Text="RECORDING SEQUENCES" Foreground="#FF666666"
                                               FontSize="10" FontWeight="SemiBold" Margin="0,0,0,10"/>

                                    <!-- Headline metrics row -->
                                    <Grid Margin="0,0,0,10">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>

                                        <StackPanel Grid.Column="0">
                                            <TextBlock x:Name="preflightSeqCount" Text="0"
                                                       Foreground="#FFE6EDF3" FontSize="22" FontWeight="SemiBold"/>
                                            <TextBlock Text="sequences" Foreground="#FF8B949E" FontSize="11"/>
                                        </StackPanel>
                                        <StackPanel Grid.Column="1">
                                            <TextBlock x:Name="preflightRecorded" Text="0s"
                                                       Foreground="#FFE6EDF3" FontSize="22" FontWeight="SemiBold"/>
                                            <TextBlock Text="recorded" Foreground="#FF8B949E" FontSize="11"/>
                                        </StackPanel>
                                        <StackPanel Grid.Column="2">
                                            <TextBlock x:Name="preflightCoverage" Text="0%"
                                                       Foreground="#FFE6EDF3" FontSize="22" FontWeight="SemiBold"/>
                                            <TextBlock Text="coverage (max)" Foreground="#FF8B949E" FontSize="11"/>
                                        </StackPanel>
                                    </Grid>

                                    <Separator Background="#FF30363D" Margin="0,4,0,8"/>

                                    <!-- Per-camera expandable breakdown -->
                                    <Expander x:Name="preflightExpander"
                                              Foreground="#FF8B949E" FontSize="12" IsExpanded="False">
                                        <Expander.Header>
                                            <TextBlock Text="Per-camera breakdown" Foreground="#FF8B949E" FontSize="12"/>
                                        </Expander.Header>
                                        <StackPanel x:Name="preflightPerCameraPanel" Margin="0,8,0,0"/>
                                    </Expander>

                                    <!-- Loading indicator (row) -->
                                    <StackPanel x:Name="preflightLoadingRow" Orientation="Horizontal"
                                                Visibility="Collapsed" Margin="0,4,0,0">
                                        <fa5:ImageAwesome Icon="Solid_CircleNotch" Spin="True" SpinDuration="1.2"
                                                          Foreground="#FF58A6FF" Width="12" Height="12"
                                                          VerticalAlignment="Center"/>
                                        <TextBlock Text="Querying server..." Foreground="#FF8B949E"
                                                   FontSize="11" VerticalAlignment="Center" Margin="6,0,0,0"/>
                                    </StackPanel>
                                </StackPanel>
                            </Border>

                            <!-- Output estimate card -->
                            <Border x:Name="estimateCard" Visibility="Collapsed"
                                    Background="#FF21262D" BorderBrush="#FF30363D" BorderThickness="1"
                                    CornerRadius="6" Padding="18,14" Margin="0,12,0,0" MinWidth="420">
                                <StackPanel>
                                    <TextBlock Text="OUTPUT ESTIMATE" Foreground="#FF666666"
                                               FontSize="10" FontWeight="SemiBold" Margin="0,0,0,10"/>

                                    <Grid x:Name="estimateGrid">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="110"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>

                                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Cameras" Foreground="#FF8B949E" FontSize="12" Margin="0,2,0,3"/>
                                        <TextBlock Grid.Row="0" Grid.Column="1" x:Name="estCameras" Foreground="#FFE6EDF3" FontSize="13" Margin="0,2,0,3"/>

                                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Layout" Foreground="#FF8B949E" FontSize="12" Margin="0,2,0,3"/>
                                        <TextBlock Grid.Row="1" Grid.Column="1" x:Name="estLayout" Foreground="#FFE6EDF3" FontSize="13" Margin="0,2,0,3"/>

                                        <TextBlock Grid.Row="2" Grid.Column="0" Text="Resolution" Foreground="#FF8B949E" FontSize="12" Margin="0,2,0,3"/>
                                        <TextBlock Grid.Row="2" Grid.Column="1" x:Name="estResolution" Foreground="#FFE6EDF3" FontSize="13" Margin="0,2,0,3"/>

                                        <TextBlock Grid.Row="3" Grid.Column="0" Text="Time Span" Foreground="#FF8B949E" FontSize="12" Margin="0,2,0,3"/>
                                        <TextBlock Grid.Row="3" Grid.Column="1" x:Name="estTimeSpan" Foreground="#FFE6EDF3" FontSize="13" Margin="0,2,0,3" TextWrapping="Wrap"/>

                                        <Separator Grid.Row="4" Grid.ColumnSpan="2" Background="#FF30363D" Margin="0,8"/>

                                        <TextBlock Grid.Row="5" Grid.Column="0" Text="Frames" Foreground="#FF8B949E" FontSize="12" Margin="0,2,0,3"/>
                                        <TextBlock Grid.Row="5" Grid.Column="1" x:Name="estFrames" Foreground="#FF58A6FF" FontSize="14" FontWeight="SemiBold" Margin="0,2,0,3"/>

                                        <TextBlock Grid.Row="6" Grid.Column="0" Text="Video" Foreground="#FF8B949E" FontSize="12" Margin="0,2,0,3"/>
                                        <TextBlock Grid.Row="6" Grid.Column="1" x:Name="estVideo" Foreground="#FF58A6FF" FontSize="14" FontWeight="SemiBold" Margin="0,2,0,3"/>
                                    </Grid>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>
                </Grid>
            </DockPanel>
        </Grid>
    </Grid>

</external:ViewItemWpfUserControl>
