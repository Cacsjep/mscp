<external:PropertiesWpfUserControl
    xmlns:external="clr-namespace:VideoOS.Platform.Client;assembly=VideoOS.Platform"
    x:Class="RemoteManager.Client.RemoteManagerPropertiesWpfUserControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <StackPanel Margin="10">
        <GroupBox Header="Remote Manager Settings" Foreground="White">
            <StackPanel Margin="8">
                <CheckBox x:Name="autoAcceptCertsCheckBox"
                          Content="Auto-accept self-signed SSL certificates"
                          Foreground="White"
                          Margin="0,4"/>
            </StackPanel>
        </GroupBox>
    </StackPanel>
</external:PropertiesWpfUserControl>
