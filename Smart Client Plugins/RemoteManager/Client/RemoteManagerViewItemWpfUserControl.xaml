<external:ViewItemWpfUserControl
    xmlns:external="clr-namespace:VideoOS.Platform.Client;assembly=VideoOS.Platform"
    x:Class="RemoteManager.Client.RemoteManagerViewItemWpfUserControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
    xmlns:fa5="http://schemas.fontawesome.com/icons/"
    xmlns:wfi="clr-namespace:System.Windows.Forms.Integration;assembly=WindowsFormsIntegration">

    <external:ViewItemWpfUserControl.Resources>
        <!-- Dark button template -->
        <Style x:Key="DarkButton" TargetType="Button">
            <Setter Property="Background" Value="#FF3A3F44"/>
            <Setter Property="Foreground" Value="#FFE6EDF3"/>
            <Setter Property="BorderBrush" Value="#FF555555"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="3"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#FF4A5058"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#FF2A2F34"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Copy button style -->
        <Style x:Key="CopyButton" TargetType="Button" BasedOn="{StaticResource DarkButton}">
            <Setter Property="Padding" Value="6,3"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="MinWidth" Value="45"/>
        </Style>

        <!-- Tab close button -->
        <Style x:Key="TabCloseButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#FFFF6B6B"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Width" Value="18"/>
            <Setter Property="Height" Value="18"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="2"
                                Padding="0">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#33FF6B6B"/>
                                <Setter Property="Foreground" Value="#FFFF4444"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Icon button (toolbar) -->
        <Style x:Key="IconButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#FF8B949E"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd"
                                Background="{TemplateBinding Background}"
                                CornerRadius="3"
                                Width="{TemplateBinding Width}"
                                Height="{TemplateBinding Height}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#FF363636"/>
                                <Setter Property="Foreground" Value="#FFE6EDF3"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#FF404040"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Search textbox style -->
        <Style x:Key="SearchBox" TargetType="TextBox">
            <Setter Property="Background" Value="#FF2A2A2A"/>
            <Setter Property="Foreground" Value="#FFE6EDF3"/>
            <Setter Property="BorderBrush" Value="#FF444444"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="6,5"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="CaretBrush" Value="#FFE6EDF3"/>
        </Style>

        <!-- ListBox style for device list -->
        <Style x:Key="DeviceListStyle" TargetType="ListBox">
            <Setter Property="Background" Value="#FF1C2326"/>
            <Setter Property="Foreground" Value="#FFE6EDF3"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled"/>
        </Style>

        <!-- ListBoxItem style -->
        <Style TargetType="ListBoxItem">
            <Setter Property="Foreground" Value="#FFE6EDF3"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Padding" Value="6,5"/>
            <Setter Property="Margin" Value="0"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="Bd"
                                Background="Transparent"
                                BorderBrush="Transparent"
                                BorderThickness="0,0,0,1"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#FF252A2E"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#FF2A4A6B"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Dark tooltip style -->
        <Style TargetType="ToolTip">
            <Setter Property="Background" Value="#FF2A2A2A"/>
            <Setter Property="Foreground" Value="#FFE6EDF3"/>
            <Setter Property="BorderBrush" Value="#FF444444"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToolTip">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="3"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </external:ViewItemWpfUserControl.Resources>

    <Grid Background="#FF1C2326">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="280" MinWidth="200"/>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- LEFT PANEL: Search + Filter + Device List + Settings -->
        <Grid Grid.Column="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Search + Toolbar -->
            <Grid Grid.Row="0" Background="#FF252A2E" Margin="0" Height="38">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <!-- Search box -->
                <Grid Grid.Column="0" Margin="6,5,4,5">
                    <TextBox x:Name="searchBox"
                             Style="{StaticResource SearchBox}"
                             VerticalAlignment="Stretch"
                             TextChanged="OnSearchTextChanged"
                             ToolTip="Search by name or IP address"/>
                    <TextBlock x:Name="searchPlaceholder"
                               Text="Search..."
                               Foreground="#FF555555"
                               FontSize="12"
                               Padding="8,6"
                               IsHitTestVisible="False"
                               VerticalAlignment="Center"
                               Visibility="Visible"/>
                </Grid>
                <!-- Add button with dropdown -->
                <Button x:Name="addButton" Grid.Column="1" Width="28" Height="28"
                        VerticalAlignment="Center"
                        Style="{StaticResource IconButton}"
                        Click="OnAddButtonClicked" ToolTip="Add entry">
                    <fa5:ImageAwesome Icon="Solid_Plus" Width="11" Height="11"
                                      Foreground="#FF2196F3"/>
                </Button>
                <!-- Refresh button -->
                <Button Grid.Column="2" Width="28" Height="28"
                        VerticalAlignment="Center"
                        Style="{StaticResource IconButton}"
                        Click="OnRefreshClicked" ToolTip="Refresh devices"
                        Margin="2,0,0,0">
                    <fa5:ImageAwesome Icon="Solid_SyncAlt" Width="12" Height="12"
                                      Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"/>
                </Button>
                <!-- Close all tabs button -->
                <Button Grid.Column="3" Width="28" Height="28"
                        VerticalAlignment="Center"
                        Style="{StaticResource IconButton}"
                        Click="OnCloseAllTabs" ToolTip="Close all tabs"
                        Margin="2,0,4,0">
                    <fa5:ImageAwesome Icon="Solid_TimesCircle" Width="12" Height="12"
                                      Foreground="#FFF44336"/>
                </Button>
            </Grid>

            <!-- Tag Filter Bar -->
            <Border Grid.Row="1" Background="#FF1E2428" Padding="6,4" BorderBrush="#FF30363D" BorderThickness="0,0,0,1">
                <WrapPanel x:Name="tagFilterPanel" Orientation="Horizontal"/>
            </Border>


            <!-- Device List -->
            <ListBox x:Name="deviceList"
                     Grid.Row="2"
                     Style="{StaticResource DeviceListStyle}"
                     Padding="0,4,0,4"/>

            <!-- Loading overlay -->
            <Border x:Name="loadingOverlay"
                    Grid.Row="2"
                    Background="#CC1C2326"
                    Visibility="Visible">
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                    <TextBlock Text="Loading devices..."
                               Foreground="#FFE6EDF3"
                               FontSize="13"
                               HorizontalAlignment="Center"/>
                </StackPanel>
            </Border>

            <!-- Settings bar -->
            <Border Grid.Row="3"
                    Background="#FF252A2E"
                    BorderBrush="#FF30363D"
                    BorderThickness="0,1,0,0"
                    Padding="8,5">
                <CheckBox x:Name="autoAcceptCertsCheckBox"
                          Content="Accept untrusted SSL"
                          Foreground="#FF8B949E"
                          FontSize="11"
                          IsChecked="True"
                          Checked="OnAutoAcceptCertsChanged"
                          Unchecked="OnAutoAcceptCertsChanged"/>
            </Border>
        </Grid>

        <!-- Splitter -->
        <GridSplitter Grid.Column="1"
                      Width="3"
                      Background="#FF30363D"
                      HorizontalAlignment="Center"
                      VerticalAlignment="Stretch"/>

        <!-- RIGHT PANEL: Credential bar + Tabbed Browser -->
        <Grid Grid.Column="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Credential Bar -->
            <Border x:Name="credentialBar"
                    Grid.Row="0"
                    Background="#FF252A2E"
                    Padding="10,8"
                    Visibility="Collapsed">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Device name -->
                    <TextBlock x:Name="deviceNameText"
                               Grid.Column="0"
                               Text="Device"
                               Foreground="#FF3399FF"
                               FontSize="13"
                               FontWeight="SemiBold"
                               VerticalAlignment="Center"
                               Margin="0,0,20,0"/>

                    <!-- Username -->
                    <TextBlock Grid.Column="1"
                               Text="User:"
                               Foreground="#FF8B949E"
                               FontSize="12"
                               VerticalAlignment="Center"
                               Margin="0,0,6,0"/>
                    <Border Grid.Column="2"
                            Background="#FF2A2A2A"
                            BorderBrush="#FF444444"
                            BorderThickness="1"
                            CornerRadius="3"
                            Padding="8,3"
                            Margin="0,0,4,0">
                        <TextBlock x:Name="usernameText"
                                   Text=""
                                   Foreground="#FFE6EDF3"
                                   FontSize="12"
                                   VerticalAlignment="Center"/>
                    </Border>
                    <Button Grid.Column="3"
                            Style="{StaticResource CopyButton}"
                            Content="Copy"
                            Click="OnCopyUsername"
                            Margin="0,0,16,0"/>

                    <!-- Password -->
                    <TextBlock Grid.Column="4"
                               Text="Pass:"
                               Foreground="#FF8B949E"
                               FontSize="12"
                               VerticalAlignment="Center"
                               Margin="0,0,6,0"/>
                    <Border Grid.Column="5"
                            Background="#FF2A2A2A"
                            BorderBrush="#FF444444"
                            BorderThickness="1"
                            CornerRadius="3"
                            Padding="8,3"
                            Margin="0,0,4,0">
                        <TextBlock x:Name="passwordText"
                                   Text=""
                                   Foreground="#FFE6EDF3"
                                   FontSize="12"
                                   VerticalAlignment="Center"/>
                    </Border>
                    <Button Grid.Column="6"
                            Style="{StaticResource CopyButton}"
                            Content="Copy"
                            Click="OnCopyPassword"
                            Margin="0,0,4,0"/>
                    <Button x:Name="togglePasswordButton"
                            Grid.Column="7"
                            Style="{StaticResource CopyButton}"
                            Content="Show"
                            Click="OnTogglePassword"
                            Margin="0,0,0,0"/>
                </Grid>
            </Border>

            <!-- Tab Strip -->
            <Border Grid.Row="1"
                    Background="#FF0D1117"
                    Padding="0">
                <ScrollViewer HorizontalScrollBarVisibility="Auto"
                              VerticalScrollBarVisibility="Disabled">
                    <StackPanel x:Name="tabStrip"
                                Orientation="Horizontal"/>
                </ScrollViewer>
            </Border>

            <!-- Browser Content Area -->
            <Grid x:Name="browserHost" Grid.Row="2" Background="#FF1C2326">
                <!-- Welcome / empty state -->
                <StackPanel x:Name="welcomePanel"
                            VerticalAlignment="Center"
                            HorizontalAlignment="Center"
                            Visibility="Visible">
                    <TextBlock Text="Remote Manager"
                               Foreground="#FFE6EDF3"
                               FontSize="22"
                               FontWeight="Bold"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,8"/>
                    <TextBlock Text="Select a device from the list or add a new connection"
                               Foreground="#FF8B949E"
                               FontSize="13"
                               HorizontalAlignment="Center"/>
                </StackPanel>
            </Grid>
        </Grid>
    </Grid>
</external:ViewItemWpfUserControl>
