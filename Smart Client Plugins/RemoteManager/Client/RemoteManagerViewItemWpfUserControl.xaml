<external:ViewItemWpfUserControl
    xmlns:external="clr-namespace:VideoOS.Platform.Client;assembly=VideoOS.Platform"
    x:Class="RemoteManager.Client.RemoteManagerViewItemWpfUserControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
    xmlns:fa5="http://schemas.fontawesome.com/icons/"
    xmlns:wfi="clr-namespace:System.Windows.Forms.Integration;assembly=WindowsFormsIntegration"
    xmlns:local="clr-namespace:RemoteManager.Client">

    <external:ViewItemWpfUserControl.Resources>
        <!-- Converters -->
        <local:NodeTypeToIconConverter x:Key="NodeIconConverter"/>
        <local:NodeTypeToColorConverter x:Key="NodeColorConverter"/>
        <local:BoolToVisibilityConverter x:Key="BoolToVisConverter"/>

        <!-- WinUI 3 Dark Theme Brushes -->
        <SolidColorBrush x:Key="SubtleFillSecondary" Color="#0FFFFFFF"/>
        <SolidColorBrush x:Key="SelectedBrush" Color="#0FFFFFFF"/>
        <SolidColorBrush x:Key="SelectedHoverBrush" Color="#15FFFFFF"/>
        <SolidColorBrush x:Key="AccentBrush" Color="#60CDFF"/>
        <SolidColorBrush x:Key="TextPrimaryBrush" Color="#FFFFFFFF"/>
        <SolidColorBrush x:Key="TextSecondaryBrush" Color="#C5FFFFFF"/>
        <SolidColorBrush x:Key="TextTertiaryBrush" Color="#87FFFFFF"/>
        <SolidColorBrush x:Key="StrokeBrush" Color="#12FFFFFF"/>

        <!-- Dark button template -->
        <Style x:Key="DarkButton" TargetType="Button">
            <Setter Property="Background" Value="#FF3A3F44"/>
            <Setter Property="Foreground" Value="#FFE6EDF3"/>
            <Setter Property="BorderBrush" Value="#FF555555"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="3"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#FF4A5058"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#FF2A2F34"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Copy button style -->
        <Style x:Key="CopyButton" TargetType="Button" BasedOn="{StaticResource DarkButton}">
            <Setter Property="Padding" Value="6,3"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="MinWidth" Value="45"/>
        </Style>

        <!-- Tab close button -->
        <Style x:Key="TabCloseButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#FFFF6B6B"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Width" Value="18"/>
            <Setter Property="Height" Value="18"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="2"
                                Padding="0">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#33FF6B6B"/>
                                <Setter Property="Foreground" Value="#FFFF4444"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Icon button (toolbar) -->
        <Style x:Key="IconButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#FF8B949E"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd"
                                Background="{TemplateBinding Background}"
                                CornerRadius="3"
                                Width="{TemplateBinding Width}"
                                Height="{TemplateBinding Height}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#FF363636"/>
                                <Setter Property="Foreground" Value="#FFE6EDF3"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#FF404040"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Search textbox style -->
        <Style x:Key="SearchBox" TargetType="TextBox">
            <Setter Property="Background" Value="#FF2A2A2A"/>
            <Setter Property="Foreground" Value="#FFE6EDF3"/>
            <Setter Property="BorderBrush" Value="#FF444444"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="6,5"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="CaretBrush" Value="#FFE6EDF3"/>
        </Style>

        <!-- WinUI 3 Chevron toggle -->
        <Style x:Key="ChevronToggle" TargetType="ToggleButton">
            <Setter Property="Focusable" Value="False"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border Background="Transparent" Width="20" Height="32">
                            <Path x:Name="Arrow"
                                  Stroke="{StaticResource TextTertiaryBrush}"
                                  StrokeThickness="1.2"
                                  StrokeStartLineCap="Round"
                                  StrokeEndLineCap="Round"
                                  StrokeLineJoin="Round"
                                  Fill="Transparent"
                                  HorizontalAlignment="Center"
                                  VerticalAlignment="Center"
                                  Data="M 3 1 L 7 5 L 3 9"
                                  RenderTransformOrigin="0.5,0.5">
                                <Path.RenderTransform>
                                    <RotateTransform Angle="0"/>
                                </Path.RenderTransform>
                            </Path>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Arrow" Property="RenderTransform">
                                    <Setter.Value>
                                        <RotateTransform Angle="90"/>
                                    </Setter.Value>
                                </Setter>
                                <Setter TargetName="Arrow" Property="Stroke" Value="{StaticResource TextSecondaryBrush}"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Arrow" Property="Stroke" Value="{StaticResource TextPrimaryBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Dark tooltip style -->
        <Style TargetType="ToolTip">
            <Setter Property="Background" Value="#FF2A2A2A"/>
            <Setter Property="Foreground" Value="#FFE6EDF3"/>
            <Setter Property="BorderBrush" Value="#FF444444"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToolTip">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="3"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </external:ViewItemWpfUserControl.Resources>

    <Grid Background="#FF1C2326">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="320" MinWidth="220"/>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- LEFT PANEL: Search + Tree + Settings -->
        <Grid Grid.Column="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Search + Toolbar -->
            <Grid Grid.Row="0" Background="#FF252A2E" Margin="0" Height="38">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <!-- Search box -->
                <Grid Grid.Column="0" Margin="6,5,4,5">
                    <TextBox x:Name="searchBox"
                             Style="{StaticResource SearchBox}"
                             VerticalAlignment="Stretch"
                             TextChanged="OnSearchTextChanged"
                             ToolTip="Search by name or IP address"/>
                    <TextBlock x:Name="searchPlaceholder"
                               Text="Search..."
                               Foreground="#FF555555"
                               FontSize="12"
                               Padding="8,6"
                               IsHitTestVisible="False"
                               VerticalAlignment="Center"
                               Visibility="Visible"/>
                </Grid>
                <!-- Refresh button -->
                <Button Grid.Column="1" Width="28" Height="28"
                        VerticalAlignment="Center"
                        Style="{StaticResource IconButton}"
                        Click="OnRefreshClicked" ToolTip="Refresh devices"
                        Margin="2,0,0,0">
                    <fa5:ImageAwesome Icon="Solid_SyncAlt" Width="12" Height="12"
                                      Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"/>
                </Button>
                <!-- Close all tabs button -->
                <Button Grid.Column="2" Width="28" Height="28"
                        VerticalAlignment="Center"
                        Style="{StaticResource IconButton}"
                        Click="OnCloseAllTabs" ToolTip="Close all tabs"
                        Margin="2,0,4,0">
                    <fa5:ImageAwesome Icon="Solid_TimesCircle" Width="12" Height="12"
                                      Foreground="#FFF44336"/>
                </Button>
            </Grid>

            <!-- Tree View -->
            <TreeView x:Name="deviceTree"
                      Grid.Row="1"
                      Background="#FF1C2326"
                      BorderThickness="0"
                      Padding="0,4,0,4"
                      AllowDrop="True"
                      FontFamily="Segoe UI"
                      FontSize="12"
                      Foreground="{StaticResource TextPrimaryBrush}"
                      ScrollViewer.HorizontalScrollBarVisibility="Disabled">

                <TreeView.ItemTemplate>
                    <HierarchicalDataTemplate ItemsSource="{Binding Children}">
                        <StackPanel Orientation="Horizontal" Margin="0,0,8,0">
                            <fa5:ImageAwesome Icon="{Binding NodeType, Converter={StaticResource NodeIconConverter}}"
                                              Foreground="{Binding NodeType, Converter={StaticResource NodeColorConverter}}"
                                              Width="12" Height="12"
                                              Margin="0,0,8,0"
                                              VerticalAlignment="Center"/>
                            <TextBlock Text="{Binding Name}"
                                       VerticalAlignment="Center"
                                       TextTrimming="CharacterEllipsis"/>
                        </StackPanel>
                    </HierarchicalDataTemplate>
                </TreeView.ItemTemplate>

                <TreeView.Resources>
                    <Style TargetType="TreeViewItem">
                        <Setter Property="IsExpanded" Value="{Binding IsExpanded, Mode=TwoWay}"/>
                        <Setter Property="Visibility" Value="{Binding IsVisible, Converter={StaticResource BoolToVisConverter}}"/>
                        <Setter Property="AllowDrop" Value="True"/>
                        <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
                        <EventSetter Event="PreviewMouseLeftButtonDown" Handler="TreeViewItem_PreviewMouseDown"/>
                        <EventSetter Event="PreviewMouseLeftButtonUp" Handler="TreeViewItem_PreviewMouseUp"/>
                        <EventSetter Event="MouseMove" Handler="TreeViewItem_MouseMove"/>
                        <EventSetter Event="DragOver" Handler="TreeViewItem_DragOver"/>
                        <EventSetter Event="Drop" Handler="TreeViewItem_Drop"/>
                        <EventSetter Event="DragLeave" Handler="TreeViewItem_DragLeave"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="TreeViewItem">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>

                                        <!-- Drop indicator line -->
                                        <Border x:Name="DropIndicator"
                                                Grid.Row="0"
                                                Height="2"
                                                Background="{StaticResource AccentBrush}"
                                                CornerRadius="1"
                                                Margin="24,0,4,0"
                                                Visibility="Collapsed"/>

                                        <!-- Row -->
                                        <Border x:Name="RowBorder"
                                                Grid.Row="1"
                                                Background="Transparent"
                                                BorderBrush="Transparent"
                                                BorderThickness="1"
                                                CornerRadius="4"
                                                Margin="3,1,3,1"
                                                Padding="0,0,8,0"
                                                MinHeight="32">
                                            <Grid VerticalAlignment="Center">
                                                <!-- Selection indicator bar -->
                                                <Border x:Name="SelectionBar"
                                                        HorizontalAlignment="Left"
                                                        VerticalAlignment="Center"
                                                        Width="3"
                                                        Height="16"
                                                        CornerRadius="1.5"
                                                        Background="Transparent"/>
                                                <DockPanel Margin="7,0,0,0" VerticalAlignment="Center">
                                                    <ToggleButton x:Name="Expander"
                                                                  DockPanel.Dock="Left"
                                                                  Style="{StaticResource ChevronToggle}"
                                                                  IsChecked="{Binding IsExpanded, RelativeSource={RelativeSource TemplatedParent}}"
                                                                  ClickMode="Press"/>
                                                    <ContentPresenter x:Name="PART_Header"
                                                                      ContentSource="Header"
                                                                      VerticalAlignment="Center"
                                                                      HorizontalAlignment="Stretch"/>
                                                </DockPanel>
                                            </Grid>
                                        </Border>

                                        <!-- Children -->
                                        <ItemsPresenter x:Name="ItemsHost" Grid.Row="2" Margin="8,0,0,0"/>
                                    </Grid>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsExpanded" Value="False">
                                            <Setter TargetName="ItemsHost" Property="Visibility" Value="Collapsed"/>
                                        </Trigger>
                                        <Trigger Property="HasItems" Value="False">
                                            <Setter TargetName="Expander" Property="Visibility" Value="Hidden"/>
                                        </Trigger>
                                        <!-- Hover -->
                                        <Trigger SourceName="RowBorder" Property="IsMouseOver" Value="True">
                                            <Setter TargetName="RowBorder" Property="Background" Value="{StaticResource SubtleFillSecondary}"/>
                                        </Trigger>
                                        <!-- Selected -->
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter TargetName="RowBorder" Property="Background" Value="{StaticResource SelectedBrush}"/>
                                            <Setter TargetName="RowBorder" Property="BorderBrush" Value="{StaticResource StrokeBrush}"/>
                                            <Setter TargetName="SelectionBar" Property="Background" Value="{StaticResource AccentBrush}"/>
                                        </Trigger>
                                        <!-- Selected + Hover -->
                                        <MultiTrigger>
                                            <MultiTrigger.Conditions>
                                                <Condition Property="IsSelected" Value="True"/>
                                                <Condition SourceName="RowBorder" Property="IsMouseOver" Value="True"/>
                                            </MultiTrigger.Conditions>
                                            <Setter TargetName="RowBorder" Property="Background" Value="{StaticResource SelectedHoverBrush}"/>
                                        </MultiTrigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </TreeView.Resources>
            </TreeView>

            <!-- Loading overlay -->
            <Border x:Name="loadingOverlay"
                    Grid.Row="1"
                    Background="#CC1C2326"
                    Visibility="Visible">
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                    <TextBlock Text="Loading devices..."
                               Foreground="#FFE6EDF3"
                               FontSize="13"
                               HorizontalAlignment="Center"/>
                </StackPanel>
            </Border>

            <!-- Settings bar -->
            <Border Grid.Row="2"
                    Background="#FF252A2E"
                    BorderBrush="#FF30363D"
                    BorderThickness="0,1,0,0"
                    Padding="8,5">
                <CheckBox x:Name="autoAcceptCertsCheckBox"
                          Content="Accept untrusted SSL"
                          Foreground="#FF8B949E"
                          FontSize="11"
                          IsChecked="True"
                          Checked="OnAutoAcceptCertsChanged"
                          Unchecked="OnAutoAcceptCertsChanged"/>
            </Border>
        </Grid>

        <!-- Splitter -->
        <GridSplitter Grid.Column="1"
                      Width="3"
                      Background="#FF30363D"
                      HorizontalAlignment="Center"
                      VerticalAlignment="Stretch"/>

        <!-- RIGHT PANEL: Credential bar + Tabbed Browser -->
        <Grid Grid.Column="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Credential Bar -->
            <Border x:Name="credentialBar"
                    Grid.Row="0"
                    Background="#FF252A2E"
                    Padding="10,8"
                    Visibility="Collapsed">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Device name -->
                    <TextBlock x:Name="deviceNameText"
                               Grid.Column="0"
                               Text="Device"
                               Foreground="#FF3399FF"
                               FontSize="13"
                               FontWeight="SemiBold"
                               VerticalAlignment="Center"
                               Margin="0,0,20,0"/>

                    <!-- Username -->
                    <TextBlock Grid.Column="1"
                               Text="User:"
                               Foreground="#FF8B949E"
                               FontSize="12"
                               VerticalAlignment="Center"
                               Margin="0,0,6,0"/>
                    <Border Grid.Column="2"
                            Background="#FF2A2A2A"
                            BorderBrush="#FF444444"
                            BorderThickness="1"
                            CornerRadius="3"
                            Padding="8,3"
                            Margin="0,0,4,0">
                        <TextBlock x:Name="usernameText"
                                   Text=""
                                   Foreground="#FFE6EDF3"
                                   FontSize="12"
                                   VerticalAlignment="Center"/>
                    </Border>
                    <Button Grid.Column="3"
                            Style="{StaticResource CopyButton}"
                            Content="Copy"
                            Click="OnCopyUsername"
                            Margin="0,0,16,0"/>

                    <!-- Password -->
                    <TextBlock Grid.Column="4"
                               Text="Pass:"
                               Foreground="#FF8B949E"
                               FontSize="12"
                               VerticalAlignment="Center"
                               Margin="0,0,6,0"/>
                    <Border Grid.Column="5"
                            Background="#FF2A2A2A"
                            BorderBrush="#FF444444"
                            BorderThickness="1"
                            CornerRadius="3"
                            Padding="8,3"
                            Margin="0,0,4,0">
                        <TextBlock x:Name="passwordText"
                                   Text=""
                                   Foreground="#FFE6EDF3"
                                   FontSize="12"
                                   VerticalAlignment="Center"/>
                    </Border>
                    <Button Grid.Column="6"
                            Style="{StaticResource CopyButton}"
                            Content="Copy"
                            Click="OnCopyPassword"
                            Margin="0,0,4,0"/>
                    <Button x:Name="togglePasswordButton"
                            Grid.Column="7"
                            Style="{StaticResource CopyButton}"
                            Content="Show"
                            Click="OnTogglePassword"
                            Margin="0,0,0,0"/>
                </Grid>
            </Border>

            <!-- Tab Strip -->
            <Border Grid.Row="1"
                    Background="#FF0D1117"
                    Padding="0">
                <ScrollViewer HorizontalScrollBarVisibility="Auto"
                              VerticalScrollBarVisibility="Disabled">
                    <StackPanel x:Name="tabStrip"
                                Orientation="Horizontal"/>
                </ScrollViewer>
            </Border>

            <!-- Browser Content Area -->
            <Grid x:Name="browserHost" Grid.Row="2" Background="#FF1C2326">
                <!-- Welcome / empty state -->
                <StackPanel x:Name="welcomePanel"
                            VerticalAlignment="Center"
                            HorizontalAlignment="Center"
                            Visibility="Visible">
                    <TextBlock Text="Remote Manager"
                               Foreground="#FFE6EDF3"
                               FontSize="22"
                               FontWeight="Bold"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,8"/>
                    <TextBlock Text="Select a device from the tree or add a new connection"
                               Foreground="#FF8B949E"
                               FontSize="13"
                               HorizontalAlignment="Center"/>
                </StackPanel>
            </Grid>
        </Grid>
    </Grid>
</external:ViewItemWpfUserControl>
